# Debug tests
variable x: Exacto = 10.0
variable y: Exacto = 3.0

escribir("x:")
escribir(x)
escribir("y:")
escribir(y)
escribir("x / y:")
escribir(x / y)

# Test abs
importar "std/matematica"
variable num: Exacto = -42.5
escribir("num:")
escribir(num)

# Simple comparison
escribir("num < 0:")
escribir(num < 0)

# abs
variable absoluto: Exacto = abs(num)
escribir("abs(num):")
escribir(absoluto)
