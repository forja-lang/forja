/// Simulación Monte Carlo
/// Conceptos: simulación, probabilidad, números aleatorios, estimación
/// Nivel: avanzado

importar "std/io"

// La simulación Monte Carlo usa muestreo aleatorio repetido para
// estimar resultados numéricos. Aquí estimamos áreas y probabilidades.

funcion pseudo_aleatorio(semilla) -> Decimal {
    variable a = 1664525
    variable c = 1013904223
    semilla = (a * semilla + c)
    retornar semilla
}

funcion generar_punto() -> Decimal {
    variable t = tiempo_actual()
    variable x = t - truncar(t / 10.0) * 10.0
    si (x < 0) { x = -x }
    x = x / 10.0
    retornar x
}

funcion estimar_area_circulo(puntos_total) -> Decimal {
    variable dentro = 0
    variable i = 0
    mientras (i < puntos_total) {
        variable x = generar_punto() * 2.0 - 1.0
        variable y = generar_punto() * 2.0 - 1.0
        si (x * x + y * y <= 1.0) {
            dentro = dentro + 1
        }
        i = i + 1
    }
    variable proporcion = dentro
    variable area_estimada = 4.0 * proporcion / puntos_total
    retornar area_estimada
}

funcion estimar_pi_montecarlo(puntos_total) -> Decimal {
    retornar estimar_area_circulo(puntos_total)
}

funcion probabilidad_suma_dados(simulaciones) -> Decimal {
    variable exitos = 0
    variable i = 0
    mientras (i < simulaciones) {
        variable d1 = 1 + (i * 7) % 6
        variable d2 = 1 + (i * 13 + 5) % 6
        si (d1 + d2 == 7) {
            exitos = exitos + 1
        }
        i = i + 1
    }
    retornar exitos / simulaciones
}

funcion estimar_area_bajo_curva(puntos_total) -> Decimal {
    variable dentro = 0
    variable i = 0
    mientras (i < puntos_total) {
        variable x = generar_punto()
        variable y = generar_punto()
        variable fx = x * x
        si (y <= fx) {
            dentro = dentro + 1
        }
        i = i + 1
    }
    retornar dentro / puntos_total
}

funcion main() {
    escribir("=== SIMULACIÓN MONTE CARLO ===\n")
    escribir("Usando muestreo aleatorio para estimar valores.\n")

    escribir("--- 1. Estimar π (área del círculo) ---")
    variable estimacion_pi = estimar_pi_montecarlo(1000)
    escribir("  π ≈ ${estimacion_pi}")

    escribir("")
    escribir("--- 2. Probabilidad suma de dados = 7 ---")
    variable prob = probabilidad_suma_dados(1000)
    escribir("  P(suma=7) ≈ ${prob} (esperado: ~0.1667)")

    escribir("")
    escribir("--- 3. Área bajo f(x)=x² en [0,1] ---")
    variable area = estimar_area_bajo_curva(1000)
    escribir("  Área ≈ ${area} (esperado: 0.3333)")
}

main()
