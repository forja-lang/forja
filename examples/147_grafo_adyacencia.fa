/// Grafo con matriz de adyacencia
/// Conceptos: grafo, matriz de adyacencia, vértices, aristas, DFS, BFS
/// Nivel: avanzado

importar "std/io"

clase GrafoMatriz {
    vertices
    matriz
    tamano

    constructor(n) {
        este.tamano = n
        este.vertices = []
        este.matriz = []
        variable i = 0
        mientras (i < n) {
            este.matriz[i] = []
            variable j = 0
            mientras (j < n) {
                este.matriz[i][j] = 0
                j = j + 1
            }
            i = i + 1
        }
    }

    funcion agregar_vertice(nombre) {
        este.vertices[longitud(este.vertices)] = nombre
    }

    funcion agregar_arista(origen, destino) {
        este.matriz[origen][destino] = 1
        este.matriz[destino][origen] = 1  // no dirigido
    }

    funcion mostrar_matriz() {
        escribir("  Matriz de adyacencia:\n")
        variable encabezado = "    "
        variable i = 0
        mientras (i < este.tamano) {
            encabezado = encabezado + este.vertices[i] + " "
            i = i + 1
        }
        escribir("  ${encabezado}")

        variable j = 0
        mientras (j < este.tamano) {
            variable fila = "  ${este.vertices[j]}  "
            variable k = 0
            mientras (k < este.tamano) {
                fila = fila + "${este.matriz[j][k]}  "
                k = k + 1
            }
            escribir("${fila}")
            j = j + 1
        }
    }

    funcion dfs(inicio, visitados) {
        visitados[inicio] = verdadero
        escribir("  Visitando: ${este.vertices[inicio]}")

        variable i = 0
        mientras (i < este.tamano) {
            si (este.matriz[inicio][i] == 1 && !visitados[i]) {
                este.dfs(i, visitados)
            }
            i = i + 1
        }
    }

    funcion recorrer_dfs(inicio) {
        variable visitados = []
        variable i = 0
        mientras (i < este.tamano) {
            visitados[i] = falso
            i = i + 1
        }
        escribir("Recorrido DFS desde ${este.vertices[inicio]}:")
        este.dfs(inicio, visitados)
    }
}

funcion main() {
    escribir("=== Grafo con Matriz de Adyacencia ===\n")

    variable grafo = nuevo GrafoMatriz(5)
    grafo.agregar_vertice("A")
    grafo.agregar_vertice("B")
    grafo.agregar_vertice("C")
    grafo.agregar_vertice("D")
    grafo.agregar_vertice("E")

    grafo.agregar_arista(0, 1)  // A-B
    grafo.agregar_arista(0, 2)  // A-C
    grafo.agregar_arista(1, 3)  // B-D
    grafo.agregar_arista(2, 3)  // C-D
    grafo.agregar_arista(3, 4)  // D-E

    grafo.mostrar_matriz()

    escribir("")
    grafo.recorrer_dfs(0)

    escribir("")
    escribir("La matriz de adyacencia es O(V²) en memoria.")
}

main()
