/// Juego: Adivina el número secreto
/// Conceptos: entrada/salida, aleatoriedad, bucles, condicionales, números aleatorios
/// Nivel: básico

importar "std/io"

// El clásico juego de adivinar un número secreto entre 1 y 100.
// El programa genera un número aleatorio y el jugador debe adivinarlo
// recibiendo pistas de "mayor" o "menor".

funcion generar_aleatorio(maximo) -> Entero {
    // Simula un número aleatorio usando el tiempo
    variable tiempo = tiempo_actual()
    variable semilla = tiempo % maximo
    si (semilla < 1) {
        semilla = 1
    }
    retornar semilla
}

funcion jugar() {
    escribir("=== ADIVINA EL NÚMERO SECRETO ===\n")
    escribir("Estoy pensando en un número entre 1 y 100.\n")
    escribir("¿Podrás adivinarlo?\n")

    constante MAXIMO = 100
    variable secreto = generar_aleatorio(MAXIMO)
    variable intentos = 0
    variable adivinado = falso

    mientras (!adivinado) {
        escribir("")
        variable entrada = pedir_numero("Tu adivinanza: ")
        intentos = intentos + 1

        si (entrada < secreto) {
            escribir("  ¡Más alto! El número es MAYOR.")
        } sino {
            si (entrada > secreto) {
                escribir("  ¡Más bajo! El número es MENOR.")
            } sino {
                escribir("  ¡CORRECTO! 🎉 Adivinaste en ${intentos} intentos.")
                adivinado = verdadero
            }
        }
    }

    escribir("")
    escribir("Gracias por jugar!")
}

funcion main() {
    jugar()
}

main()
