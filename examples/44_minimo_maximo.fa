// 🎓 Lección 44: Mínimo y máximo (con variables)

variable numeros = [34, 12, 89, 5, 67]

variable min = numeros[0]
variable max = numeros[0]

si (numeros[1] < min) { min = numeros[1] }
si (numeros[1] > max) { max = numeros[1] }
si (numeros[2] < min) { min = numeros[2] }
si (numeros[2] > max) { max = numeros[2] }
si (numeros[3] < min) { min = numeros[3] }
si (numeros[3] > max) { max = numeros[3] }
si (numeros[4] < min) { min = numeros[4] }
si (numeros[4] > max) { max = numeros[4] }

escribir("Array: " + numeros)
escribir("Mínimo: " + min)
escribir("Máximo: " + max)
