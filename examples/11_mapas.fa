// 🎓 Lección 11: Mapas (diccionarios)
// Los mapas guardan pares clave→valor, como un diccionario.

variable persona = {"nombre": "Ana", "edad": 25, "ciudad": "Lima"}

escribir(persona["nombre"])   // Ana
escribir(persona["edad"])     // 25
escribir(persona["ciudad"])   // Lima

// Se pueden modificar:
persona["edad"] = 26
escribir(persona["edad"])     // 26
