// 🎓 Lección 11: Mapas (diccionarios)
// Ejecutar con: forja run examples/11_mapas.fa --vm vm
// Los mapas guardan pares clave→valor

variable persona = {"nombre": "Ana", "edad": 25, "ciudad": "Lima"}

// Con VM clásica (--vm vm), los mapas funcionan
escribir(persona["nombre"])
escribir(persona["edad"])
escribir(persona["ciudad"])
