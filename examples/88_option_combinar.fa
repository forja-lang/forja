/// Combinar múltiples Opcion
/// Conceptos: múltiples Some/None, composición, valores opcionales
/// Nivel: intermedio

importar "std/io"

// Trabajar con múltiples valores opcionales simultáneamente

funcion buscar_en_lista(lista, objetivo) -> Opcion<Entero> {
    variable i = 0
    mientras (i < longitud(lista)) {
        si (lista[i] == objetivo) {
            retornar Some(i)
        }
        i = i + 1
    }
    retornar None
}

funcion primer_elem(lista) -> Opcion<Entero> {
    si (longitud(lista) > 0) {
        retornar Some(lista[0])
    }
    retornar None
}

funcion ultimo_elem(lista) -> Opcion<Entero> {
    variable n = longitud(lista)
    si (n > 0) {
        retornar Some(lista[n - 1])
    }
    retornar None
}

funcion combinar_opciones(a, b) {
    escribir("Combinando opciones:")
    
    coincidir (a) {
        caso Some(va) -> {
            coincidir (b) {
                caso Some(vb) -> {
                    escribir("  Ambos tienen valor: ${va} y ${vb}")
                }
                caso None -> {
                    escribir("  Solo A tiene valor: ${va}")
                }
            }
        }
        caso None -> {
            coincidir (b) {
                caso Some(vb) -> {
                    escribir("  Solo B tiene valor: ${vb}")
                }
                caso None -> {
                    escribir("  Ninguno tiene valor")
                }
            }
        }
    }
}

funcion main() {
    escribir("=== Combinar Opciones ===\n")
    
    variable lista1 = [10, 20, 30]
    variable lista2 = []
    
    variable a = primer_elem(lista1)
    variable b = ultimo_elem(lista1)
    variable c = primer_elem(lista2)
    
    combinar_opciones(a, b)
    escribir("")
    combinar_opciones(a, c)
    escribir("")
    combinar_opciones(c, c)
}

main()
