/// Estadística: Media, Mediana, Moda, Desviación
/// Conceptos: estadística descriptiva, arrays, ordenamiento, análisis de datos
/// Nivel: intermedio

importar "std/io"

// Implementación de funciones estadísticas básicas:
// media, mediana, moda, varianza, desviación estándar.

funcion ordenar_array(arr) {
    variable n = longitud(arr)
    variable i = 0
    mientras (i < n) {
        variable j = i + 1
        mientras (j < n) {
            si (arr[i] > arr[j]) {
                variable temp = arr[i]
                arr[i] = arr[j]
                arr[j] = temp
            }
            j = j + 1
        }
        i = i + 1
    }
    retornar arr
}

funcion media(arr) -> Decimal {
    variable suma = 0.0
    variable i = 0
    variable n = longitud(arr)
    mientras (i < n) {
        suma = suma + arr[i]
        i = i + 1
    }
    si (n > 0) {
        retornar suma / n
    }
    retornar 0.0
}

funcion mediana(arr) -> Decimal {
    variable ordenado = ordenar_array(arr)
    variable n = longitud(ordenado)
    si (n > 0) {
        si (n % 2 == 1) {
            retornar ordenado[n / 2]
        } sino {
            retornar (ordenado[n / 2 - 1] + ordenado[n / 2]) / 2.0
        }
    }
    retornar 0.0
}

funcion moda(arr) {
    variable frecuencias = []
    variable valores = []
    variable max_freq = 0
    variable i = 0
    mientras (i < longitud(arr)) {
        variable valor = arr[i]
        variable encontrado = falso
        variable j = 0
        mientras (j < longitud(valores)) {
            si (valores[j] == valor) {
                frecuencias[j] = frecuencias[j] + 1
                si (frecuencias[j] > max_freq) {
                    max_freq = frecuencias[j]
                }
                encontrado = verdadero
                j = longitud(valores)
            }
            j = j + 1
        }
        si (!encontrado) {
            variable idx = longitud(valores)
            valores[idx] = valor
            frecuencias[idx] = 1
            si (1 > max_freq) {
                max_freq = 1
            }
        }
        i = i + 1
    }
    retornar valores
}

funcion varianza(arr) -> Decimal {
    variable prom = media(arr)
    variable suma = 0.0
    variable i = 0
    variable n = longitud(arr)
    mientras (i < n) {
        variable diff = arr[i] - prom
        suma = suma + diff * diff
        i = i + 1
    }
    si (n > 1) {
        retornar suma / (n - 1)
    }
    retornar 0.0
}

funcion desviacion_estandar(arr) -> Decimal {
    variable v = varianza(arr)
    // Raíz cuadrada manual usando el método de Newton
    si (v <= 0) { retornar 0.0 }
    variable x = v
    variable i = 0
    mientras (i < 20) {
        si (x == 0) { x = 0.001 }
        x = (x + v / x) / 2.0
        i = i + 1
    }
    retornar x
}

funcion main() {
    escribir("=== ESTADÍSTICA DESCRIPTIVA ===\n")

    variable datos = [4, 8, 6, 5, 3, 8, 7, 5, 9, 4, 6, 7, 5, 8, 6]
    escribir("Datos: ${datos}")
    escribir("Cantidad: ${longitud(datos)}")
    escribir("Media: ${media(datos)}")
    escribir("Mediana: ${mediana(datos)}")
    escribir("Moda: ${moda(datos)}")
    escribir("Varianza: ${varianza(datos)}")
    escribir("Desviación Estándar: ${desviacion_estandar(datos)}")
    escribir("")
    escribir("La desviación estándar mide la dispersión de los datos.")
    escribir("Un valor bajo significa datos cercanos a la media.")
}

main()
