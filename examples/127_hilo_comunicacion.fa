/// Hilos comunicándose con canales
/// Conceptos: hilo, canal, enviar, recibir, comunicación entre hilos
/// Nivel: intermedio

importar "std/io"

// Los canales permiten que los hilos se comuniquen de forma segura

funcion main() {
    escribir("=== Hilos comunicándose con canales ===\n")

    variable tx, rx = canal()

    // Hilo que envía un mensaje
    variable h = hilo {
        escribir("  🧵 Hilo: preparando mensaje...")
        variable mensaje = "Hola desde el hilo!"
        tx.enviar(mensaje)
        escribir("  🧵 Hilo: mensaje enviado!")
        retornar 0
    }

    // Main recibe
    escribir("Main: esperando mensaje del hilo...\n")
    variable recibido = rx.recibir()
    escribir("Main: mensaje recibido: \"${recibido}\"\n")

    h.unir()

    escribir("Los canales son la forma principal de comunicación entre hilos.")
}

main()
