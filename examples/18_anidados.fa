// 🎓 Lección 18: Condicionales anidados
// Podemos poner si dentro de otro si

variable numero = 42

si (numero > 0) {
    si (numero > 10) {
        si (numero > 100) {
            escribir("Es un número grande")
        } sino {
            escribir("Es un número mediano")
        }
    } sino {
        escribir("Es un número pequeño positivo")
    }
} sino {
    si (numero == 0) {
        escribir("Es cero")
    } sino {
        escribir("Es negativo")
    }
}

// Más ejemplos de anidación
variable edad = 65
si (edad >= 18) {
    si (edad >= 60) {
        escribir("Es adulto mayor")
    } sino {
        escribir("Es adulto")
    }
} sino {
    escribir("Es menor de edad")
}
