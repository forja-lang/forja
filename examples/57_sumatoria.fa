// 🎓 Lección 57: Sumatorias
// Sumamos secuencias de números

// Sumar del 1 al 100
variable suma = 0
para (variable i = 1; i <= 100; i = i + 1) {
    suma = suma + i
}
escribir("Suma del 1 al 100: " + suma)

// Sumar solo pares del 1 al 20
variable sumaPares = 0
para (variable i = 2; i <= 20; i = i + 2) {
    sumaPares = sumaPares + i
}
escribir("Suma de pares del 1 al 20: " + sumaPares)

// Sumar impares del 1 al 19
variable sumaImpares = 0
para (variable i = 1; i < 20; i = i + 2) {
    sumaImpares = sumaImpares + i
}
escribir("Suma de impares del 1 al 19: " + sumaImpares)
