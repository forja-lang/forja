# Ejemplo: Sistema de Archivos
# Muestra todas las operaciones del módulo std/archivo
#
# Uso: forja ejecutar examples/208_archivos.fa

importar "std/archivo"

funcion prueba_completa_archivos() {
    imprimir("=== Prueba Completa - Sistema de Archivos ===")
    imprimir("")

    variable ruta_original = "_prueba_archivo.txt"
    variable ruta_copia = "_prueba_copia.txt"
    variable ruta_movido = "_prueba_movido.txt"
    variable ruta_directorio = "_prueba_directorio"
    variable contenido_esperado = "Hola desde Forja!\nLinea 2\nLinea 3"

    # ─── 1. ESCRIBIR ARCHIVO ─────────────────────────────────────────────
    imprimir("--- 1. escribir_archivo ---")
    variable res_esc = escribir_archivo(ruta_original, contenido_esperado)
    coincidir (res_esc) {
        caso Ok(_) -> {
            imprimir("  ✓ Archivo creado: " + ruta_original)
        }
        caso Error(e) -> {
            imprimir("  ERROR: " + e.mensaje)
            retornar
        }
    }

    # ─── 2. EXISTE ARCHIVO ───────────────────────────────────────────────
    imprimir("--- 2. existe_archivo ---")
    si (existe_archivo(ruta_original)) {
        imprimir("  ✓ El archivo existe")
    } sino {
        imprimir("  ✗ ERROR: Deberia existir")
    }

    # ─── 3. LEER ARCHIVO ─────────────────────────────────────────────────
    imprimir("--- 3. leer_archivo ---")
    variable res_lec = leer_archivo(ruta_original)
    coincidir (res_lec) {
        caso Ok(contenido) -> {
            si (contenido == contenido_esperado) {
                imprimir("  ✓ Contenido correcto (" + a_texto(longitud(contenido)) + " caracteres)")
            } sino {
                imprimir("  ✗ ERROR: Contenido no coincide")
                imprimir("  Esperado: '" + contenido_esperado + "'")
                imprimir("  Obtenido: '" + contenido + "'")
            }
        }
        caso Error(e) -> {
            imprimir("  ERROR: " + e.mensaje)
        }
    }

    # ─── 4. TAMAÑO ARCHIVO ───────────────────────────────────────────────
    imprimir("--- 4. tamano_archivo ---")
    variable res_tam = tamano_archivo(ruta_original)
    coincidir (res_tam) {
        caso Ok(tam) -> {
            imprimir("  ✓ Tamano: " + a_texto(tam) + " bytes")
        }
        caso Error(e) -> {
            imprimir("  ERROR: " + e.mensaje)
        }
    }

    # ─── 5. COPIAR ARCHIVO ───────────────────────────────────────────────
    imprimir("--- 5. copiar_archivo ---")
    variable res_cop = copiar_archivo(ruta_original, ruta_copia)
    coincidir (res_cop) {
        caso Ok(_) -> {
            si (existe_archivo(ruta_copia)) {
                imprimir("  ✓ Copia creada: " + ruta_copia)
            } sino {
                imprimir("  ✗ ERROR: La copia no existe")
            }
        }
        caso Error(e) -> {
            imprimir("  ERROR: " + e.mensaje)
        }
    }

    # ─── 6. MOVER ARCHIVO ────────────────────────────────────────────────
    imprimir("--- 6. mover_archivo ---")
    variable res_mov = mover_archivo(ruta_copia, ruta_movido)
    coincidir (res_mov) {
        caso Ok(_) -> {
            si (no existe_archivo(ruta_copia) && existe_archivo(ruta_movido)) {
                imprimir("  ✓ Archivo movido: " + ruta_copia + " -> " + ruta_movido)
            } sino {
                imprimir("  ✗ ERROR: El movimiento no se realizo correctamente")
            }
        }
        caso Error(e) -> {
            imprimir("  ERROR: " + e.mensaje)
        }
    }

    # ─── 7. INFORMACION DEL ARCHIVO ──────────────────────────────────────
    imprimir("--- 7. info_archivo ---")
    variable res_info = info_archivo(ruta_original)
    coincidir (res_info) {
        caso Ok(info) -> {
            imprimir("  ✓ Informacion: " + a_texto(info))
        }
        caso Error(e) -> {
            imprimir("  ERROR: " + e.mensaje)
        }
    }

    # ─── 8. ES DIRECTORIO ────────────────────────────────────────────────
    imprimir("--- 8. es_directorio ---")
    si (es_directorio(".")) {
        imprimir("  ✓ '.' es un directorio")
    } sino {
        imprimir("  ✗ ERROR: '.' deberia ser un directorio")
    }
    si (no es_directorio(ruta_original)) {
        imprimir("  ✓ '" + ruta_original + "' NO es un directorio (es archivo)")
    } sino {
        imprimir("  ✗ ERROR: '" + ruta_original + "' no deberia ser un directorio")
    }

    # ─── 9. CREAR DIRECTORIO ─────────────────────────────────────────────
    imprimir("--- 9. crear_directorio ---")
    variable res_crd = crear_directorio(ruta_directorio)
    coincidir (res_crd) {
        caso Ok(_) -> {
            si (existe_archivo(ruta_directorio) && es_directorio(ruta_directorio)) {
                imprimir("  ✓ Directorio creado: " + ruta_directorio)
            } sino {
                imprimir("  ✗ ERROR: El directorio no se creo correctamente")
            }
        }
        caso Error(e) -> {
            imprimir("  ERROR: " + e.mensaje)
        }
    }

    # ─── 10. LISTAR DIRECTORIO ───────────────────────────────────────────
    imprimir("--- 10. listar_directorio ---")
    variable res_lst = listar_directorio(".")
    coincidir (res_lst) {
        caso Ok(archivos) -> {
            imprimir("  ✓ Contenido del directorio actual (" + a_texto(longitud(archivos)) + " entradas):")
            variable i = 0
            mientras (i < longitud(archivos)) {
                si (i < 5) {
                    imprimir("    - " + archivos[i])
                } sino {
                    si (i == 5) {
                        imprimir("    - ... y " + a_texto(longitud(archivos) - 5) + " mas")
                    }
                }
                i = i + 1
            }
        }
        caso Error(e) -> {
            imprimir("  ERROR: " + e.mensaje)
        }
    }

    # ─── 11. ESCRIBIR ARCHIVO EN DIRECTORIO ──────────────────────────────
    imprimir("--- 11. Archivo dentro del directorio ---")
    variable ruta_en_dir = ruta_directorio + "/archivo_interno.txt"
    variable res_esc2 = escribir_archivo(ruta_en_dir, "contenido interno")
    coincidir (res_esc2) {
        caso Ok(_) -> {
            si (existe_archivo(ruta_en_dir)) {
                imprimir("  ✓ Archivo creado dentro del directorio")
                variable res_lec2 = leer_archivo(ruta_en_dir)
                coincidir (res_lec2) {
                    caso Ok(contenido) -> {
                        si (contenido == "contenido interno") {
                            imprimir("  ✓ Contenido verificado")
                        }
                    }
                    caso Error(_) -> {}
                }
                eliminar_archivo(ruta_en_dir)
                imprimir("  ✓ Archivo interno eliminado")
            }
        }
        caso Error(e) -> {
            imprimir("  ERROR: " + e.mensaje)
        }
    }

    # ─── 12. LIMPIEZA ────────────────────────────────────────────────────
    imprimir("--- 12. Limpieza ---")
    eliminar_archivo(ruta_original)
    eliminar_archivo(ruta_movido)
    eliminar_directorio(ruta_directorio)

    variable ok = verdadero
    si (existe_archivo(ruta_original)) { ok = falso }
    si (existe_archivo(ruta_movido)) { ok = falso }
    si (existe_archivo(ruta_directorio)) { ok = falso }
    si (ok) {
        imprimir("  ✓ Limpieza completada: todos los archivos temporales eliminados")
    } sino {
        imprimir("  ⚠ Algunos archivos temporales no se pudieron eliminar")
    }

    # ─── 13. MANEJO DE ERRORES ───────────────────────────────────────────
    imprimir("")
    imprimir("═══════════ Pruebas de Manejo de Errores ═══════════")
    imprimir("")

    # Error: archivo inexistente
    imprimir("--- Error: leer archivo inexistente ---")
    variable res_err1 = leer_archivo("_archivo_que_no_existe_12345.txt")
    coincidir (res_err1) {
        caso Error(e) -> {
            imprimir("  ✓ Error esperado: " + e.mensaje + " (codigo: " + a_texto(e.codigo) + ")")
        }
        caso Ok(_) -> {
            imprimir("  ✗ ERROR: Deberia haber fallado")
        }
    }

    # Error: copiar con ruta vacia
    imprimir("--- Error: copiar con ruta vacia ---")
    variable res_err2 = copiar_archivo("", "destino.txt")
    coincidir (res_err2) {
        caso Error(e) -> {
            imprimir("  ✓ Error esperado: " + e.mensaje + " (codigo: " + a_texto(e.codigo) + ")")
        }
        caso Ok(_) -> {}
    }

    # Error: mover con ruta vacia
    imprimir("--- Error: mover con ruta vacia ---")
    variable res_err3 = mover_archivo("origen.txt", "")
    coincidir (res_err3) {
        caso Error(e) -> {
            imprimir("  ✓ Error esperado: " + e.mensaje + " (codigo: " + a_texto(e.codigo) + ")")
        }
        caso Ok(_) -> {}
    }

    # Error: eliminar archivo inexistente
    imprimir("--- Error: eliminar archivo inexistente ---")
    variable res_err4 = eliminar_archivo("_no_existe_eliminar.txt")
    coincidir (res_err4) {
        caso Error(e) -> {
            imprimir("  ✓ Error esperado: " + e.mensaje + " (codigo: " + a_texto(e.codigo) + ")")
        }
        caso Ok(_) -> {}
    }

    # existe_archivo con ruta inexistente (nunca falla)
    imprimir("--- existe_archivo con ruta inexistente ---")
    si (no existe_archivo("_ruta_que_no_existe_999.txt")) {
        imprimir("  ✓ existe_archivo retorna falso correctamente")
    }

    imprimir("")
    imprimir("=== Prueba completada exitosamente ===")
}

prueba_completa_archivos()
