// 🎓 Lección 17: Operadores de comparación
// >, <, >=, <=, ==, !=

variable a = 10
variable b = 10
variable c = 5

escribir("a = " + a + ", b = " + b + ", c = " + c)

escribir("a == b? " + (a == b))  // verdadero
escribir("a != c? " + (a != c))  // verdadero
escribir("a > c? " + (a > c))    // verdadero
escribir("c < a? " + (c < a))    // verdadero
escribir("a >= b? " + (a >= b))  // verdadero
escribir("c <= a? " + (c <= a))  // verdadero

// Comparar con si
si (a >= b && b >= c) {
    escribir("a >= b >= c")
}
