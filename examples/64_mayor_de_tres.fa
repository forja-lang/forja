// 🎓 Lección 64: Mayor de tres números

funcion mayorDeTres(a: Entero, b: Entero, c: Entero) {
    variable mayor = a
    
    si (b > mayor) {
        mayor = b
    }
    si (c > mayor) {
        mayor = c
    }
    
    escribir("Números: " + a + ", " + b + ", " + c)
    escribir("El mayor es: " + mayor)
}

mayorDeTres(5, 9, 3)
mayorDeTres(100, 50, 75)
mayorDeTres(7, 7, 7)
