

funcion manejar_cliente(cliente) {
escribir("  ─────────────────────────")
variable info = sockets.obtener_info(cliente)
variable bienvenida = "Bienvenido al servidor Forja!
" + "Envíame un mensaje y te lo devolveré (eco).
" + "Escribe 'salir' para desconectarte.
> "
variable envio = sockets.enviar(cliente, bienvenida)
mientras (verdadero) {
variable datos = sockets.recibir(cliente, sockets.BUFFER_TAMANO)
    }
variable cerrar_res = sockets.cerrar(cliente)
escribir("")
}

funcion main() {
escribir("╔══════════════════════════════════════╗")
escribir("║       Servidor TCP Eco - Forja       ║")
escribir("╚══════════════════════════════════════╝")
escribir("")
variable resultado = sockets.escuchar(8080)
}

main()

