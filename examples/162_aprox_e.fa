/// Aproximación del número e
/// Conceptos: series infinitas, factorial, número de Euler, convergencia
/// Nivel: intermedio

importar "std/io"

// El número e (base de los logaritmos naturales) se puede aproximar
// mediante la serie: e = Σ (1/n!) para n = 0 hasta ∞

funcion factorial(n) -> Entero {
    si (n <= 1) {
        retornar 1
    }
    retornar n * factorial(n - 1)
}

funcion aproximar_e(terminos) -> Decimal {
    variable e = 1.0  // Primer término: 1/0! = 1
    variable i = 1
    mientras (i <= terminos) {
        e = e + 1.0 / factorial(i)
        i = i + 1
    }
    retornar e
}

funcion aproximar_e_limite(n) -> Decimal {
    // e = lim (1 + 1/n)^n cuando n → ∞
    variable base = 1.0 + 1.0 / n
    variable resultado = 1.0
    variable i = 0
    mientras (i < n) {
        resultado = resultado * base
        i = i + 1
    }
    retornar resultado
}

funcion calcular_error(aprox, real) -> Decimal {
    variable diff = aprox - real
    si (diff < 0) { diff = -diff }
    retornar diff
}

funcion main() {
    escribir("=== APROXIMACIÓN DEL NÚMERO e ===\n")
    constante E_REAL = 2.718281828459045

    escribir("Valor real de e ≈ ${E_REAL}\n")
    escribir("--- Método 1: Serie de Taylor (Σ 1/n!) ---\n")

    variable terminos = [1, 3, 5, 10, 15, 20]
    variable i = 0
    mientras (i < longitud(terminos)) {
        variable n = terminos[i]
        variable aprox = aproximar_e(n)
        variable error = calcular_error(aprox, E_REAL)
        escribir("  ${n} términos: e ≈ ${aprox}")
        escribir("    error: ${error}")
        i = i + 1
    }

    escribir("")
    escribir("--- Método 2: Límite (1 + 1/n)^n ---\n")

    variable limites = [10, 100, 1000, 10000, 100000]
    variable j = 0
    mientras (j < longitud(limites)) {
        variable n = limites[j]
        variable aprox = aproximar_e_limite(n)
        variable error = calcular_error(aprox, E_REAL)
        escribir("  n=${n}: e ≈ ${aprox}")
        escribir("    error: ${error}")
        j = j + 1
    }

    escribir("")
    escribir("La serie de Taylor converge mucho más rápido que el límite.")
    escribir("Con solo 20 términos obtenemos alta precisión.")
}

main()
