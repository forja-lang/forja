importar "gui"

// ─── Callbacks ────────────────────────────────────────────────────

funcion validar_login(usuario: Texto, contrasena: Texto) -> Texto {
    si (usuario == "") {
        retornar "  El usuario es obligatorio"
    }
    si (contrasena == "") {
        retornar "  La contrasena es obligatoria"
    }
    retornar "  Bienvenido, " + usuario + "!"
}

funcion limpiar() -> Texto {
    retornar ""
}

funcion main() {
    variable usuario = ""
    variable contrasena = ""
    variable resultado = ""

    columna_centrada(
        espacio(20),

        titulo("Iniciar Sesion"),
        espacio(5),
        etiqueta_color("Accede a tu cuenta", "gris"),
        espacio(30),

        etiqueta("  Usuario"),
        entrada_texto("usuario", "Ingresa tu usuario"),
        espacio(12),

        etiqueta("  Contrasena"),
        entrada_texto("contrasena", "Ingresa tu contrasena"),
        espacio(20),

        fila(
            boton("  INICIAR SESION  ", &validar_login),
            espacio(10),
            boton("  LIMPIAR  ", &limpiar)
        ),
        espacio(15),

        etiqueta_color("Olvidaste tu contrasena?", "azul"),
        espacio(25),

        separador(),
        espacio(10),
        etiqueta_color("Resultado:", "naranja"),
        escribir(resultado),

        espacio(30),
        etiqueta_color("Forja GUI Nativa  -  Xilem 0.4", "plateado"),
        espacio(20)
    )
}
