// ═══════════════════════════════════════════════════════════════════
//  FORJA LOGIN
//  Formulario de inicio de sesion con GUI nativa Xilem
//  Demuestra: etiqueta_color(), titulo(), placeholder en inputs
// ═══════════════════════════════════════════════════════════════════
//
//  Ejecutar (nativo):  forja ejecutar --native examples/211_login.fa
//  Ejecutar (normal):  forja ejecutar examples/211_login.fa
//
//  Requiere: cargo build --features gui
//
// ═══════════════════════════════════════════════════════════════════

importar "gui"

// ─── Callbacks ────────────────────────────────────────────────────

funcion validar_login(usuario: Texto, contrasena: Texto) -> Texto {
    si (usuario == "") {
        retornar "  El usuario es obligatorio"
    }
    si (contrasena == "") {
        retornar "  La contrasena es obligatoria"
    }
    retornar "  Bienvenido, " + usuario + "!"
}

funcion limpiar() -> Texto {
    retornar ""
}

// ─── Aplicacion principal ─────────────────────────────────────────

funcion main() {
    // ─── Variables de estado ─────────────────────────────────────
    variable usuario = ""
    variable contrasena = ""
    variable resultado = ""

    // ─── Interfaz ────────────────────────────────────────────────
    desplazable(
        columna(

            // ═══════════════════════════════════════════════════════
            //  HEADER
            // ═══════════════════════════════════════════════════════
            espacio(40),

            etiqueta("+----------------------------------------------------+"),
            titulo("  Iniciar Sesion"),
            etiqueta_color("  Accede a tu cuenta", "gris"),
            etiqueta("+----------------------------------------------------+"),
            espacio(35),

            // ═══════════════════════════════════════════════════════
            //  CAMPOS DEL FORMULARIO
            // ═══════════════════════════════════════════════════════
            etiqueta("  Usuario:"),
            entrada_texto("usuario", "Ingresa tu usuario"),
            espacio(15),

            etiqueta("  Contrasena:"),
            entrada_texto("contrasena", "Ingresa tu contrasena"),
            espacio(25),

            // ═══════════════════════════════════════════════════════
            //  BOTONES DE ACCION
            // ═══════════════════════════════════════════════════════
            fila(
                boton("  INICIAR SESION  ", &validar_login),
                espacio(15),
                boton("  LIMPIAR  ", &limpiar)
            ),
            espacio(15),

            etiqueta_color("> Olvidaste tu contrasena?", "azul"),
            espacio(25),

            // ═══════════════════════════════════════════════════════
            //  RESULTADO
            // ═══════════════════════════════════════════════════════
            separador(),
            espacio(10),

            etiqueta_color("  Resultado:", "naranja"),
            etiqueta("  +--------------------------------------------------+"),
            escribir(resultado),
            etiqueta("  +--------------------------------------------------+"),

            espacio(40),
            etiqueta_color("  Forja GUI Nativa  -  Xilem 0.4", "plateado"),
            espacio(20)
        )
    )
}
