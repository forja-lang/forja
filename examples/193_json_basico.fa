/// Procesamiento JSON-like
/// Conceptos: JSON, parseo, serialización, mapas anidados, formato de datos
/// Nivel: avanzado

importar "std/io"

// Procesamiento básico de datos en formato JSON.
// Forja no tiene JSON nativo, pero podemos simular su procesamiento
// usando mapas, arrays y conversiones de texto.

clase JSONParser {
    texto
    posicion

    constructor() {
        este.texto = ""
        este.posicion = 0
    }

    funcion init(texto_json) {
        este.texto = texto_json
        este.posicion = 0
    }

    funcion saltar_espacios() {
        mientras (este.posicion < longitud(este.texto)) {
            variable c = este.texto[este.posicion]
            si (c == ' ' || c == '\n' || c == '\t' || c == '\r') {
                este.posicion = este.posicion + 1
            } sino {
                retornar
            }
        }
    }

    funcion parsear() {
        este.saltar_espacios()
        si (este.posicion >= longitud(este.texto)) {
            retornar nulo
        }

        variable c = este.texto[este.posicion]
        si (c == '{') {
            retornar este.parsear_objeto()
        }
        si (c == '[') {
            retornar este.parsear_array()
        }
        si (c == '"') {
            retornar este.parsear_string()
        }
        retornar este.parsear_numero()
    }

    funcion parsear_objeto() {
        variable obj = []
        este.posicion = este.posicion + 1  // saltar '{'

        mientras (verdadero) {
            este.saltar_espacios()
            si (este.posicion >= longitud(este.texto)) { retornar obj }
            si (este.texto[este.posicion] == '}') {
                este.posicion = este.posicion + 1
                retornar obj
            }

            // Parsear key
            variable clave = este.parsear_string()

            este.saltar_espacios()
            si (este.texto[este.posicion] == ':') {
                este.posicion = este.posicion + 1
            }

            // Parsear value
                            variable valor = este.parsear()

            // Almacenar en formato clave-valor
            variable idx = longitud(obj)
            obj[idx] = clave + ":" + este.valor_a_texto(valor)

            este.saltar_espacios()
            si (este.texto[este.posicion] == ',') {
                este.posicion = este.posicion + 1
            } sino {
                si (este.texto[este.posicion] == '}') {
                    este.posicion = este.posicion + 1
                    retornar obj
                }
            }
        }
        retornar obj
    }

    funcion parsear_array() {
        variable arr = []
        este.posicion = este.posicion + 1  // saltar '['

        mientras (verdadero) {
            este.saltar_espacios()
            si (este.posicion >= longitud(este.texto)) { retornar arr }
            si (este.texto[este.posicion] == ']') {
                este.posicion = este.posicion + 1
                retornar arr
            }

            variable valor = este.parsear()
            variable idx = longitud(arr)
            arr[idx] = valor

            este.saltar_espacios()
            si (este.texto[este.posicion] == ',') {
                este.posicion = este.posicion + 1
            } sino {
                si (este.texto[este.posicion] == ']') {
                    este.posicion = este.posicion + 1
                    retornar arr
                }
            }
        }
        retornar arr
    }

    funcion parsear_string() -> Texto {
        este.posicion = este.posicion + 1  // saltar '"'
        variable resultado = ""
        mientras (este.posicion < longitud(este.texto)) {
            variable c = este.texto[este.posicion]
            si (c == '"') {
                este.posicion = este.posicion + 1
                retornar resultado
            }
            si (c == '\\') {
                este.posicion = este.posicion + 1
                si (este.posicion < longitud(este.texto)) {
                    variable esc = este.texto[este.posicion]
                    si (esc == 'n') { resultado = resultado + "\n" }
                    si (esc == 't') { resultado = resultado + "\t" }
                    si (esc == '\\') { resultado = resultado + "\\" }
                    si (esc == '"') { resultado = resultado + "\"" }
                }
            } sino {
                resultado = resultado + c
            }
            este.posicion = este.posicion + 1
        }
        retornar resultado
    }

    funcion parsear_numero() -> Texto {
        variable resultado = ""
        mientras (este.posicion < longitud(este.texto)) {
            variable c = este.texto[este.posicion]
            si ((c >= '0' && c <= '9') || c == '-' || c == '.' || c == 'e' || c == 'E') {
                resultado = resultado + c
                este.posicion = este.posicion + 1
            } sino {
                retornar resultado
            }
        }
        retornar resultado
    }

    funcion valor_a_texto(valor) -> Texto {
        retornar valor
    }
}

funcion serializar_a_json(datos, profundidad) -> Texto {
    variable resultado = ""
    variable tabs = ""
    variable i = 0
    mientras (i < profundidad) {
        tabs = tabs + "  "
        i = i + 1
    }

    si (tipo_de(datos) == "Array") {
        resultado = "[\n"
        variable j = 0
        mientras (j < longitud(datos)) {
            resultado = resultado + tabs + "  "
            resultado = resultado + serializar_a_json(datos[j], profundidad + 1)
            si (j < longitud(datos) - 1) {
                resultado = resultado + ","
            }
            resultado = resultado + "\n"
            j = j + 1
        }
        resultado = resultado + tabs + "]"
    } sino {
        resultado = resultado + datos
    }

    retornar resultado
}

funcion main() {
    escribir("=== PROCESAMIENTO JSON ===\n")

    variable json_str = '{"nombre": "Ana", "edad": 30, "activo": true, "hobbies": ["leer", "correr", "codificar"]}'

    escribir("JSON original:")
    escribir("  ${json_str}\n")

    variable parser = nuevo JSONParser()
    parser.init(json_str)
    variable resultado = parser.parsear()

    escribir("Resultado del parseo:")
    variable i = 0
    mientras (i < longitud(resultado)) {
        escribir("  [${i}]: ${resultado[i]}")
        i = i + 1
    }

    escribir("")
    escribir("--- Construcción manual de JSON-like ---")

    // Crear estructura de datos similar a JSON
    variable persona = []
    persona[0] = "nombre:Juan"
    persona[1] = "edad:25"
    persona[2] = "email:juan@email.com"

    variable habilidades = []
    habilidades[0] = "Python"
    habilidades[1] = "Forja"
    habilidades[2] = "Rust"

    persona[3] = "habilidades:" + habilidades

    escribir("  Estructura de persona:")
    variable j = 0
    mientras (j < longitud(persona)) {
        escribir("    ${persona[j]}")
        j = j + 1
    }

    escribir("")
    escribir("JSON es el formato de intercambio de datos más usado en la web.")
    escribir("Forja puede procesar JSON usando mapas y procesamiento de texto.")
}

main()
