// 🎓 Lección 19: Ámbito de variables
// Las variables existen solo dentro de su bloque {}

variable global = "Soy global"
escribir(global)

si (verdadero) {
    variable interna = "Soy interna"
    escribir(interna)   // visible aquí
    escribir(global)    // también visible aquí
}
// escribir(interna)  // ← ERROR: interna no existe fuera del bloque

// Bloques en bucles
para (variable i = 0; i < 3; i = i + 1) {
    variable mensaje = "Vuelta " + i
    escribir(mensaje)
}
// escribir(mensaje)  // ← ERROR: mensaje no existe aquí
// escribir(i)        // ← ERROR: i no existe aquí
