# ═══════════════════════════════════════════════════════════════════
#  CALLBACKS
# ═══════════════════════════════════════════════════════════════════

funcion accion_story(valor: Texto) -> Texto {
    retornar valor
}

funcion toggle_tema_cb(valor: Texto) -> Texto {
    retornar "Tema alternado"
}

funcion toggle_menu_cb(valor: Texto) -> Texto {
    retornar "Menú toggle"
}

funcion cambiar_pagina_cb(valor: Texto) -> Texto {
    retornar valor
}

funcion cambiar_tab_cb(valor: Texto) -> Texto {
    retornar valor
}

# ─── Diálogos ───

funcion mostrar_alerta_cb(valor: Texto) -> Texto {
    dialogo_alerta("Título", "Mensaje de alerta")
    retornar valor
}

funcion mostrar_confirmacion_cb(valor: Texto) -> Texto {
    dialogo_confirmacion("¿Confirmar?", "¿Estás seguro?", &accion_story, &accion_story)
    retornar valor
}

funcion mostrar_hoja_cb(valor: Texto) -> Texto {
    hoja_inferior(
        columna((
            texto_mediano("Bottom Sheet"),
            etiqueta("Contenido"),
            boton_relleno("Cerrar", &accion_story)
        )),
        "verdadero"
    )
    retornar valor
}

funcion mostrar_notificacion_cb(valor: Texto) -> Texto {
    notificación("Archivo guardado")
    retornar valor
}
