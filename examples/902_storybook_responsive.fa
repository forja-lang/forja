        ), 16, "inicio"),

        espacio(16),
        texto_mediano("Listas"),
        espacio(8),
        lista_con_dividores((
            elemento_lista_doble(icono_material("folder", 24, "secondary"), "Docs", "15 archivos", icono_material("arrow_forward", 24, "on_surface_variant")),
            elemento_lista_doble(icono_material("image", 24, "secondary"), "Fotos", "42 archivos", icono_material("arrow_forward", 24, "on_surface_variant")),
            elemento_lista_doble(icono_material("audiotrack", 24, "secondary"), "Música", "8 archivos", icono_material("arrow_forward", 24, "on_surface_variant")),
        )),
