# ═══════════════════════════════════════════════════════════════════
#  FORJA STORYBOOK — Responsive Edition
#  Visor de componentes con 3 layouts según WindowSizeClass:
#    - Compact (< 600px):  sidebar colapsada, navegación inferior
#    - Medium (600-840px): sidebar compacta (solo iconos)
#    - Expanded (> 840px): sidebar completa con labels
# ═══════════════════════════════════════════════════════════════════
#
#  Ejecutar:
#    forja-gui examples/902_storybook_responsive.fa
#
# ═══════════════════════════════════════════════════════════════════

importar "gui"

# ═══════════════════════════════════════════════════════════════════
#  FUNCIÓN PRINCIPAL
# ═══════════════════════════════════════════════════════════════════

funcion main() {
    # ─── Variables de estado ───
    variable pagina = 0
    variable tema_oscuro = "falso"
    variable menu_abierto = "falso"

    # ─── Variables para controles ───
    variable btn_disabled = "falso"
    variable btn_icon = "falso"
    variable switch_val = "verdadero"
    variable slider_val = "50"
    variable texto_val = ""
    variable rating_val = "3"

    # ─── Andamio principal ───
    andamio(
        # Barra superior con menú hamburguesa y acciones
        barra_superior(
            "📱 Forja Storybook",
            (
                boton_icono("🍔", &toggle_menu_cb),
                boton_icono("🌙", &toggle_tema_cb),
            )
        ),

        # Cuerpo: responsive según tamaño de ventana
        cuerpo_responsive(pagina,
            btn_disabled, btn_icon,
            texto_val, slider_val, switch_val,
            rating_val, menu_abierto),

        # Barra inferior (solo visible en Compact)
        barra_navegacion(
            (item_navegacion("🔘", "Botones"),
             item_navegacion("⌨️", "Inputs"),
             item_navegacion("🃏", "Tarjetas"),
             item_navegacion("💬", "Feedback"),
             item_navegacion("🧭", "Nav")),
            pagina, &cambiar_pagina_cb
        )
    )
}

# ═══════════════════════════════════════════════════════════════════
#  CUERPO RESPONSIVE (3 layouts según WindowSizeClass)
# ═══════════════════════════════════════════════════════════════════
#  Usa andamio() con adaptable() para cambiar entre:
#    Compact   → sin sidebar, solo navegación inferior
#    Medium    → sidebar compacta (iconos sin texto)
#    Expanded  → sidebar completa (iconos + labels)
# ═══════════════════════════════════════════════════════════════════

funcion cuerpo_responsive(p: Entero,
    btn_disabled: Texto, btn_icon: Texto,
    texto_val: Texto, slider_val: Texto, switch_val: Texto,
    rating_val: Texto, menu_abierto: Texto) {

    retornar adaptable(

        # ─── COMPACT (< 600px) ───
        # Sin sidebar. La navegación se hace por la barra inferior.
        # El menú hamburguesa abre un cajón lateral.
        columna(
            espacio(8),

            # Título de categoría
            texto_grande(titulo_categoria(p)),
            espacio(4),
            separador(),
            espacio(8),

            # Contenido desplazable
            desplazable(
                seccion_activa(p,
                    btn_disabled, btn_icon,
                    texto_val, slider_val, switch_val,
                    rating_val)
            ),

            # Cajón modal para navegación completa (hamburger menu)
            cajon_modal(
                (item_navegacion("🔘", "Botones"),
                 item_navegacion("⌨️", "Inputs"),
                 item_navegacion("🃏", "Tarjetas"),
                 item_navegacion("💬", "Feedback"),
                 item_navegacion("🧭", "Navegación"),
                 item_navegacion("📊", "Indicadores"),
                 item_navegacion("👤", "Avatares"),
                 item_navegacion("📈", "Gráficos"),
                 item_navegacion("🎭", "Expressive"),
                 item_navegacion("🏃", "Motion"),
                 item_navegacion("📐", "Layout")),
                p, &cambiar_pagina_cb,
                menu_abierto
            )
        ),

        # ─── MEDIUM (600-840px) ───
        # Sidebar compacta: solo iconos, sin labels
        # Contenido a la derecha
        fila((
            riel_navegacion(
                (item_navegacion("🔘", ""),
                 item_navegacion("⌨️", ""),
                 item_navegacion("🃏", ""),
                 item_navegacion("💬", ""),
                 item_navegacion("🧭", ""),
                 item_navegacion("📊", ""),
                 item_navegacion("👤", ""),
                 item_navegacion("📈", ""),
                 item_navegacion("🎭", ""),
                 item_navegacion("🏃", ""),
                 item_navegacion("📐", "")),
                p, &cambiar_pagina_cb,
                falso    # extendido = falso → solo iconos
            ),

            # Contenido principal
            desplazable(
                columna(
                    texto_grande(titulo_categoria(p)),
                    espacio(4),
                    separador(),
                    espacio(8),

                    seccion_activa(p,
                        btn_disabled, btn_icon,
                        texto_val, slider_val, switch_val,
                        rating_val)
                )
            )
        )),

        # ─── EXPANDED (> 840px) ───
        # Sidebar completa: iconos + labels
        # Layout tipo IDE
        fila((
            riel_navegacion(
                (item_navegacion("🔘", "Botones"),
                 item_navegacion("⌨️", "Inputs"),
                 item_navegacion("🃏", "Tarjetas"),
                 item_navegacion("💬", "Feedback"),
                 item_navegacion("🧭", "Navegación"),
                 item_navegacion("📊", "Indicadores"),
                 item_navegacion("👤", "Avatares"),
                 item_navegacion("📈", "Gráficos"),
                 item_navegacion("🎭", "Expressive"),
                 item_navegacion("🏃", "Motion"),
                 item_navegacion("📐", "Layout")),
                p, &cambiar_pagina_cb,
                verdadero   # extendido = verdadero → iconos + labels
            ),

            # Contenido principal con más espacio
            desplazable(
                columna(
                    texto_grande(titulo_categoria(p)),
                    espacio(8),
                    separador(),
                    espacio(12),

                    seccion_activa(p,
                        btn_disabled, btn_icon,
                        texto_val, slider_val, switch_val,
                        rating_val)
                )
            )
        ))
    )
}

# ═══════════════════════════════════════════════════════════════════
#  HELPER: Título de categoría
# ═══════════════════════════════════════════════════════════════════

funcion titulo_categoria(p: Entero) -> Texto {
    si (p == 0) { retornar "🔘 Botones" }
    sino {
        si (p == 1) { retornar "⌨️ Inputs" }
        sino {
            si (p == 2) { retornar "🃏 Tarjetas" }
            sino {
                si (p == 3) { retornar "💬 Feedback" }
                sino {
                    si (p == 4) { retornar "🧭 Navegación" }
                    sino {
                        si (p == 5) { retornar "📊 Indicadores" }
                        sino {
                            si (p == 6) { retornar "👤 Avatares" }
                            sino {
                                si (p == 7) { retornar "📈 Gráficos" }
                                sino {
                                    si (p == 8) { retornar "🎭 Expressive" }
                                    sino {
                                        si (p == 9) { retornar "🏃 Motion" }
                                        sino { retornar "📐 Layout" }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

# ═══════════════════════════════════════════════════════════════════
#  HELPER: Sección activa
# ═══════════════════════════════════════════════════════════════════

funcion seccion_activa(p: Entero,
    btn_disabled: Texto, btn_icon: Texto,
    texto_val: Texto, slider_val: Texto, switch_val: Texto,
    rating_val: Texto) {

    si (p == 0) { retornar seccion_botones(btn_disabled, btn_icon) }
    sino {
        si (p == 1) { retornar seccion_inputs(texto_val, slider_val, switch_val) }
        sino {
            si (p == 2) { retornar seccion_tarjetas() }
            sino {
                si (p == 3) { retornar seccion_feedback() }
                sino {
                    si (p == 4) { retornar seccion_navegacion() }
                    sino {
                        si (p == 5) { retornar seccion_indicadores(slider_val) }
                        sino {
                            si (p == 6) { retornar seccion_avatares() }
                            sino {
                                si (p == 7) { retornar seccion_graficos(rating_val) }
                                sino {
                                    si (p == 8) { retornar seccion_expressive() }
                                    sino {
                                        si (p == 9) { retornar seccion_motion() }
                                        sino { retornar seccion_layout() }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

# ═══════════════════════════════════════════════════════════════════
#  SECCIÓN 0: BOTONES
# ═══════════════════════════════════════════════════════════════════

funcion seccion_botones(disabled: Texto, con_icono: Texto) {
    retornar columna(
        texto_mediano("Variantes principales"),
        espacio(8),
        fila_con_gap((
            boton_relleno("Relleno", &accion_story),
            boton_tonal("Tonal", &accion_story),
            boton_perfilado("Perfilado", &accion_story),
            boton_texto("Texto", &accion_story),
            boton_elevado("Elevado", &accion_story),
        ), 8, "centro"),

        espacio(16),
        texto_mediano("FAB"),
        espacio(8),
        fila_con_gap((
            fab_pequeño("➕", &accion_story),
            fab("➕", &accion_story),
            fab_grande("➕", &accion_story),
        ), 8, "centro"),

        espacio(16),
        texto_mediano("Icon Buttons"),
        espacio(8),
        fila_con_gap((
            boton_icono("⭐", &accion_story),
            boton_icono_relleno("⭐", &accion_story),
            boton_icono_tonal("⭐", &accion_story),
        ), 8, "centro"),

        espacio(16),
        texto_mediano("Chips"),
        espacio(8),
        flujo((
            subconjunto_asistente("Ayuda", &accion_story),
            subconjunto_filtro("Filtro", verdadero, &accion_story),
            subconjunto_sugerencia("Sugerencia", &accion_story),
        ), 8),
    )
}

# ═══════════════════════════════════════════════════════════════════
#  SECCIÓN 1: INPUTS
# ═══════════════════════════════════════════════════════════════════

funcion seccion_inputs(texto: Texto, slider: Texto, sw: Texto) {
    retornar columna(
        texto_mediano("Campos de texto"),
        espacio(8),
        campo_texto(texto, "Texto"),
        espacio(8),
        campo_email(texto, "Email"),
        espacio(8),
        campo_contraseña(texto, "Contraseña"),
        espacio(8),
        campo_numero(texto, "Edad", 0, 150),

        espacio(16),
        texto_mediano("Controles"),
        espacio(8),
        interruptor("Interruptor", sw),
        espacio(8),
        deslizante(slider, 0, 100),

        espacio(16),
        texto_mediano("Fecha y Color"),
        espacio(8),
        fila_con_gap((
            selector_fecha("2025-01-15"),
            selector_color("#6750A4"),
        ), 16, "centro"),
    )
}

