/// Desempaquetar Opcion con match
/// Conceptos: coincidir, caso, patrones Some/None, extraer valores
/// Nivel: intermedio

importar "std/io"

// Para usar el valor dentro de un Opcion, debemos
// desempaquetarlo con coincidir (pattern matching)

funcion buscar_en_lista(lista, objetivo) -> Opcion<Entero> {
    variable i = 0
    mientras (i < longitud(lista)) {
        si (lista[i] == objetivo) {
            retornar Some(i)
        }
        i = i + 1
    }
    retornar None
}

funcion main() {
    variable numeros = [10, 20, 30, 40, 50]
    variable resultado = buscar_en_lista(numeros, 30)
    
    escribir("=== Desempaquetar Opcion ===")
    
    coincidir (resultado) {
        caso Some(valor) -> {
            escribir("Encontrado en índice: ${valor}")
        }
        caso None -> {
            escribir("Valor no encontrado")
        }
    }
    
    // Otro ejemplo:
    variable busqueda = buscar_en_lista(numeros, 99)
    
    coincidir (busqueda) {
        caso Some(valor) -> {
            escribir("Encontrado: ${valor}")
        }
        caso None -> {
            escribir("El 99 no está en la lista")
        }
    }
}

main()
