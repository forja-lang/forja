# Contratos que FALLAN (para probar)
# ═══════════════════════════════════════════

importar "std/io"

# Esta función FALLARÁ por precondición
funcion test_precondicion() {
    imprimir("Intentando dividir(10, 0)...")
    variable r = dividir(10, 0)  # ← FALLA: precondición b != 0
    imprimir("  Esto no debería ejecutarse")
}

funcion dividir(a: Entero, b: Entero) -> Entero
    requiere b != 0, "No dividir por cero"
{
    retornar a / b
}

funcion main() {
    test_precondicion()
}

main()
