// 🎓 Lección 24: Bucle repetir avanzado
// 'repetir' ejecuta un bloque N veces

escribir("Tabla del 5:")
repetir (10) {
    variable i = 0
    // No podemos usar el contador directamente, necesitamos variable externa
}
// Solución: usar 'para' cuando necesitamos índice
// 'repetir' es útil para acciones que no necesitan índice

escribir("Saludos:")
repetir (3) {
    escribir("  Hola!")
}

escribir("Línea punteada:")
repetir (20) {
    escribir("-")
}
