/// Match dentro de match (anidado)
/// Conceptos: coincidir anidado, patrones complejos, composición de coincidencia
/// Nivel: avanzado

importar "std/io"

tipo Color = RGB(Entero, Entero, Entero) | HSL(Decimal, Decimal, Decimal) | Hex(Texto)

tipo Figura = Circulo(Entero) | Rectangulo(Entero, Entero) | Triangulo(Entero, Entero)

tipo Dibujo = FiguraColoreada(Figura, Color) | Grupo(Texto)

funcion describir_color(c) -> Texto {
    coincidir (c) {
        caso RGB(r, g, b) -> {
            retornar "RGB(${r}, ${g}, ${b})"
        }
        caso HSL(h, s, l) -> {
            retornar "HSL(${h}, ${s}%, ${l}%)"
        }
        caso Hex(v) -> {
            retornar "#${v}"
        }
    }
}

funcion describir_figura(f) -> Texto {
    coincidir (f) {
        caso Circulo(r) -> {
            retornar "Círculo radio=${r}"
        }
        caso Rectangulo(b, h) -> {
            retornar "Rectángulo ${b}x${h}"
        }
        caso Triangulo(b, h) -> {
            retornar "Triángulo base=${b} altura=${h}"
        }
    }
}

funcion analizar_dibujo(d) -> Texto {
    // Match ANIDADO: coincidir dentro de un brazo de coincidir
    coincidir (d) {
        caso FiguraColoreada(fig, col) -> {
            variable desc_fig = describir_figura(fig)
            variable desc_col = describir_color(col)
            retornar "🎨 ${desc_fig} en color ${desc_col}"
        }
        caso Grupo(nombre) -> {
            retornar "📁 Grupo: ${nombre}"
        }
    }
}

funcion area_total(dibujos) -> Entero {
    variable total = 0
    variable i = 0
    mientras (i < longitud(dibujos)) {
        coincidir (dibujos[i]) {
            caso FiguraColoreada(fig, _) -> {
                // Match anidado para calcular área según la figura
                coincidir (fig) {
                    caso Circulo(r) -> {
                        total = total + (3 * r * r)
                    }
                    caso Rectangulo(b, h) -> {
                        total = total + (b * h)
                    }
                    caso Triangulo(b, h) -> {
                        total = total + ((b * h) / 2)
                    }
                }
            }
            caso Grupo(_) -> {
                // Los grupos no aportan área directa
            }
        }
        i = i + 1
    }
    retornar total
}

funcion main() {
    escribir("=== Match anidado ===\n")

    variable dibujos = [
        FiguraColoreada(Circulo(5), RGB(255, 0, 0)),
        FiguraColoreada(Rectangulo(10, 20), HSL(120, 50, 50)),
        FiguraColoreada(Triangulo(6, 8), Hex("FF8800")),
        Grupo("Fondo")
    ]

    variable i = 0
    mientras (i < longitud(dibujos)) {
        escribir("  ${analizar_dibujo(dibujos[i])}")
        i = i + 1
    }

    escribir("")
    escribir("Área total: ${area_total(dibujos)} unidades cuadradas")

    escribir("")
    escribir("El match anidado permite descomponer estructuras complejas.")
}

main()
