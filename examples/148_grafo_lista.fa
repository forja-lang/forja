/// Grafo con lista de adyacencia
/// Conceptos: grafo, lista de adyacencia, vértices, aristas, eficiencia
/// Nivel: avanzado

importar "std/io"

clase NodoAdy {
    vertice
    peso
    siguiente

    constructor(v, p) {
        este.vertice = v
        este.peso = p
        este.siguiente = nulo
    }
}

clase GrafoLista {
    vertices
    listas
    tamano

    constructor(n) {
        este.tamano = n
        este.vertices = []
        este.listas = []
        variable i = 0
        mientras (i < n) {
            este.listas[i] = nulo
            i = i + 1
        }
    }

    funcion agregar_vertice(nombre) {
        este.vertices[longitud(este.vertices)] = nombre
    }

    funcion agregar_arista(origen, destino, peso) {
        // Agregar al inicio de la lista (dirigido de origen a destino)
        variable nodo = nuevo NodoAdy(destino, peso)
        nodo.siguiente = este.listas[origen]
        este.listas[origen] = nodo
    }

    funcion mostrar_listas() {
        escribir("  Listas de adyacencia:\n")
        variable i = 0
        mientras (i < este.tamano) {
            variable linea = "  ${este.vertices[i]}: "
            variable actual = este.listas[i]
            mientras (actual != nulo) {
                linea = linea + "${este.vertices[actual.vertice]}(${actual.peso}) → "
                actual = actual.siguiente
            }
            linea = linea + "∅"
            escribir("${linea}")
            i = i + 1
        }
    }

    funcion tiene_ciclo_util(v, visitados, pila_rec) -> Booleano {
        visitados[v] = verdadero
        pila_rec[v] = verdadero

        variable actual = este.listas[v]
        mientras (actual != nulo) {
            si (!visitados[actual.vertice]) {
                si (este.tiene_ciclo_util(actual.vertice, visitados, pila_rec)) {
                    retornar verdadero
                }
            } sino {
                si (pila_rec[actual.vertice]) {
                    retornar verdadero
                }
            }
            actual = actual.siguiente
        }

        pila_rec[v] = falso
        retornar falso
    }

    funcion detectar_ciclo() -> Booleano {
        variable visitados = []
        variable pila_rec = []
        variable i = 0
        mientras (i < este.tamano) {
            visitados[i] = falso
            pila_rec[i] = falso
            i = i + 1
        }

        variable j = 0
        mientras (j < este.tamano) {
            si (!visitados[j]) {
                si (este.tiene_ciclo_util(j, visitados, pila_rec)) {
                    retornar verdadero
                }
            }
            j = j + 1
        }
        retornar falso
    }
}

funcion main() {
    escribir("=== Grafo con Lista de Adyacencia ===\n")

    // Grafo dirigido con 4 vértices
    variable grafo = nuevo GrafoLista(4)
    grafo.agregar_vertice("A")
    grafo.agregar_vertice("B")
    grafo.agregar_vertice("C")
    grafo.agregar_vertice("D")

    // Aristas dirigidas con peso
    grafo.agregar_arista(0, 1, 5)  // A → B (peso 5)
    grafo.agregar_arista(0, 2, 3)  // A → C (peso 3)
    grafo.agregar_arista(1, 3, 2)  // B → D (peso 2)
    grafo.agregar_arista(2, 3, 7)  // C → D (peso 7)

    grafo.mostrar_listas()

    escribir("")
    escribir("¿Tiene ciclos? ${grafo.detectar_ciclo()}")

    escribir("")
    escribir("La lista de adyacencia es O(V+E) en memoria, ideal para grafos dispersos.")
}

main()
