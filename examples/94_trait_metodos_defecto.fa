/// Métodos con implementación por defecto en traits
/// Conceptos: método default, herencia de implementación, override
/// Nivel: avanzado

importar "std/io"

// Los traits pueden tener métodos con implementación por defecto
// Las clases pueden usarlos directamente o sobreescribirlos

trait Saludador {
    // Método sin implementación (debe implementarlo la clase)
    funcion obtener_nombre() -> Texto
    
    // Método con implementación por defecto
    funcion saludar() {
        escribir("Hola, soy ${este.obtener_nombre()}!")
    }
    
    funcion despedirse() {
        escribir("${este.obtener_nombre()} dice: ¡Chau!")
    }
}

clase Persona {
    nombre
    
    funcion obtener_nombre() -> Texto {
        retornar este.nombre
    }
    funcion saludar() {
        escribir("Hola, soy ${este.obtener_nombre()}!")
    }
    funcion despedirse() {
        escribir("${este.obtener_nombre()} dice: ¡Chau!")
    }
}

clase Robot {
    codigo
    
    funcion obtener_nombre() -> Texto {
        retornar "Robot-${este.codigo}"
    }
    
    funcion saludar() {
        escribir("${este.obtener_nombre()}: SISTEMA INICIADO. Hola, humano.")
    }
    
    funcion despedirse() {
        escribir("${este.obtener_nombre()} dice: ¡Chau!")
    }
}

funcion main() {
    escribir("=== Métodos por Defecto ===\n")
    
    variable p = nuevo Persona()
    p.nombre = "Ana"
    p.saludar()
    p.despedirse()
    
    escribir("")
    
    variable r = nuevo Robot()
    r.codigo = "X7-42"
    r.saludar()
    r.despedirse()
}

main()
