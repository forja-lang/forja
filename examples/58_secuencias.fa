// 🎓 Lección 58: Generar secuencias numéricas

// Secuencia: 1, 4, 9, 16, 25 (cuadrados)
escribir("Cuadrados:")
para (variable i = 1; i <= 5; i = i + 1) {
    escribir("  " + i + "² = " + (i * i))
}

// Secuencia: 2, 4, 8, 16, 32 (potencias de 2)
escribir("Potencias de 2:")
variable pot = 2
para (variable i = 1; i <= 5; i = i + 1) {
    escribir("  2^" + i + " = " + pot)
    pot = pot * 2
}

// Secuencia: 1, 3, 6, 10, 15 (triangulares)
escribir("Números triangulares:")
variable tri = 0
para (variable i = 1; i <= 5; i = i + 1) {
    tri = tri + i
    escribir("  T" + i + " = " + tri)
}
