/// @test en funciones de prueba
/// Conceptos: @test, pruebas unitarias, asegurar, funciones de test
/// Nivel: intermedio

importar "std/io"

// @test marca funciones como pruebas unitarias
// Se ejecutan con: forja test examples/124_atributo_test.fa

funcion suma(a, b) {
    retornar a + b
}

funcion resta(a, b) {
    retornar a - b
}

funcion multiplicar(a, b) {
    retornar a * b
}

funcion dividir(a, b) {
    retornar a / b
}

@test
funcion prueba_suma() {
    asegurar(suma(2, 3) == 5)
    asegurar(suma(-1, 1) == 0)
    asegurar(suma(0, 0) == 0)
}

@test
funcion prueba_resta() {
    asegurar(resta(10, 5) == 5)
    asegurar(resta(0, 5) == -5)
}

@test
funcion prueba_multiplicar() {
    asegurar(multiplicar(3, 4) == 12)
    asegurar(multiplicar(-2, 5) == -10)
}

@test
funcion prueba_dividir() {
    asegurar(dividir(10, 2) == 5)
    asegurar(dividir(9, 3) == 3)
}

funcion main() {
    escribir("=== @test ===\n")
    escribir("Ejecutá 'forja test examples/124_atributo_test.fa'")
    escribir("para correr las pruebas automáticamente.\n")

    escribir("Pruebas definidas:")
    escribir("  prueba_suma()")
    escribir("  prueba_resta()")
    escribir("  prueba_multiplicar()")
    escribir("  prueba_dividir()")
}

main()
