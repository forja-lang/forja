// 🎓 Lección 6: Bucles (repeticiones)

// 'mientras' repite mientras la condición sea verdadera:
variable contador = 0
mientras (contador < 3) {
    escribir("Vuelta: " + contador)
    contador = contador + 1
}

// 'para' repite con un contador:
para (variable i = 0; i < 3; i = i + 1) {
    escribir("i = " + i)
}

// 'repetir' repite una cantidad fija de veces:
repetir (3) {
    escribir("Esto se repite 3 veces")
}
