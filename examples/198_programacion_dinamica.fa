/// Programación Dinámica: Fibonacci optimizado
/// Conceptos: programación dinámica, memoización, tabulación, optimización
/// Nivel: avanzado

importar "std/io"

// La programación dinámica resuelve problemas dividiéndolos en
// subproblemas más pequeños y almacenando sus resultados para
// evitar recálculos. Demostrado con la secuencia de Fibonacci.

// --- Versión ingenua (recursiva sin optimización) ---

funcion fib_ingenua(n) -> Entero {
    si (n <= 1) {
        retornar n
    }
    retornar fib_ingenua(n - 1) + fib_ingenua(n - 2)
}

// --- Versión con memoización (top-down) ---

clase FibonacciMemo {
    memo

    constructor() {
        este.memo = []
        variable i = 0
        mientras (i < 100) {
            este.memo[i] = -1
            i = i + 1
        }
        este.memo[0] = 0
        este.memo[1] = 1
    }

    funcion calcular(n) -> Entero {
        si (este.memo[n] != -1) {
            retornar este.memo[n]
        }
        este.memo[n] = este.calcular(n - 1) + este.calcular(n - 2)
        retornar este.memo[n]
    }
}

// --- Versión con tabulación (bottom-up) ---

funcion fib_tabulacion(n) -> Entero {
    si (n <= 1) {
        retornar n
    }

    variable tabla = []
    tabla[0] = 0
    tabla[1] = 1

    variable i = 2
    mientras (i <= n) {
        tabla[i] = tabla[i - 1] + tabla[i - 2]
        i = i + 1
    }
    retornar tabla[n]
}

// --- Versión optimizada (solo dos variables) ---

funcion fib_optimizado(n) -> Entero {
    si (n <= 1) {
        retornar n
    }

    variable a = 0
    variable b = 1
    variable c = 0

    variable i = 2
    mientras (i <= n) {
        c = a + b
        a = b
        b = c
        i = i + 1
    }
    retornar c
}

// --- Problema de la mochila (knapsack) con DP ---

funcion mochila_dp(capacidad, pesos, valores, n) -> Entero {
    variable dp = []
    variable i = 0
    mientras (i <= n) {
        variable fila = []
        variable w = 0
        mientras (w <= capacidad) {
            fila[w] = 0
            w = w + 1
        }
        dp[i] = fila
        i = i + 1
    }

    variable objeto = 0
    mientras (objeto <= n) {
        variable peso = 0
        mientras (peso <= capacidad) {
            si (objeto == 0 || peso == 0) {
                dp[objeto][peso] = 0
            } sino {
                si (pesos[objeto - 1] <= peso) {
                    variable incluir = valores[objeto - 1] + dp[objeto - 1][peso - pesos[objeto - 1]]
                    variable excluir = dp[objeto - 1][peso]
                    si (incluir > excluir) {
                        dp[objeto][peso] = incluir
                    } sino {
                        dp[objeto][peso] = excluir
                    }
                } sino {
                    dp[objeto][peso] = dp[objeto - 1][peso]
                }
            }
            peso = peso + 1
        }
        objeto = objeto + 1
    }

    retornar dp[n][capacidad]
}

funcion main() {
    escribir("=== PROGRAMACIÓN DINÁMICA ===\n")

    escribir("--- Fibonacci: Comparación de enfoques ---")
    variable n = 10

    // Tabulación
    variable resultado_tab = fib_tabulacion(n)
    escribir("  Fib(${n}) - Tabulación (bottom-up): ${resultado_tab}")

    // Optimizado
    variable resultado_opt = fib_optimizado(n)
    escribir("  Fib(${n}) - Optimizado (O(1) memoria): ${resultado_opt}")

    escribir("")
    escribir("  Comparación de complejidad:")
    escribir("    Tabulación:  O(n) tiempo, O(n) memoria")
    escribir("    Optimizado:  O(n) tiempo, O(1) memoria")

    escribir("")
    escribir("--- Problema de la Mochila (0/1 Knapsack) ---")
    variable pesos = [2, 3, 4, 5]
    variable valores = [3, 4, 5, 6]
    variable capacidad = 8
    variable n_items = 4

    escribir("  Items: (peso, valor)")
    variable i = 0
    mientras (i < n_items) {
        escribir("    ${i + 1}: (${pesos[i]}, ${valores[i]})")
        i = i + 1
    }
    escribir("  Capacidad: ${capacidad}")

    variable valor_maximo = mochila_dp(capacidad, pesos, valores, n_items)
    escribir("  Valor máximo: ${valor_maximo}")

    escribir("")
    escribir("La programación dinámica es útil para:")
    escribir("  • Problemas con subestructura óptima")
    escribir("  • Problemas con subproblemas superpuestos")
    escribir("  • Optimización combinatoria")
    escribir("  • La clave: almacenar resultados para reutilizarlos")
}

main()
