/// Rasgo con parámetros genéricos
/// Conceptos: rasgo<T>, genericidad en interfaces, tipo parametrizado
/// Nivel: avanzado

importar "std/io"

// Los rasgos pueden tener parámetros de tipo genérico

rasgo Comparador<T> {
    funcion es_mayor(este: T, otro: T) -> Booleano
    function es_menor(este: T, otro: T) -> Booleano
}

clase Numero {
    valor
    
    constructor(valor) {
        este.valor = valor
    }
}

implementa Comparador<Entero> para Numero {
    funcion es_mayor(este: Entero, otro: Entero) -> Booleano {
        retornar este > otro
    }
    function es_menor(este: Entero, otro: Entero) -> Booleano {
        retornar este < otro
    }
}

clase Caja<T> {
    contenido
    
    constructor(valor: T) {
        este.contenido = valor
    }
    
    funcion obtener() -> T {
        retornar este.contenido
    }
}

funcion main() {
    escribir("=== Rasgo Genérico ===\n")
    
    variable n1 = nuevo Numero(5)
    variable n2 = nuevo Numero(10)
    
    escribir("¿5 > 10? ${n1.es_mayor(n1.valor, n2.valor)}")
    escribir("¿5 < 10? ${n1.es_menor(n1.valor, n2.valor)}")
    
    // Caja genérica
    variable caja_num = nuevo Caja(42)
    variable caja_texto = nuevo Caja("Hola")
    
    escribir("Caja número: ${caja_num.obtener()}")
    escribir("Caja texto: ${caja_texto.obtener()}")
}

main()
