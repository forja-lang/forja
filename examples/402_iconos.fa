# ─────────────────────────────────────────────────────────────────────
# Iconos Material Design - Demostración
# Forja GUI + Xilem
# ─────────────────────────────────────────────────────────────────────
# Muestra el sistema de iconos vectoriales Material Design.
# Los iconos se renderizan como emoji con tamaño y color,
# preparados para migrar a SVG real cuando Xilem lo soporte.
# ─────────────────────────────────────────────────────────────────────

importar "gui"

funcion main() {
    columna(
        texto_grande("Iconos Material Design"),
        espacio(16),

        texto_mediano("Iconos de navegación:"),
        espacio(8),
        fila_con_gap((
            icono_material("home", 32, "primary"),
            icono_material("search", 32, "primary"),
            icono_material("settings", 32, "primary"),
            icono_material("menu", 32, "primary"),
            icono_material("arrow_back", 32, "primary"),
            icono_material("arrow_forward", 32, "primary"),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Iconos de acción:"),
        espacio(8),
        fila_con_gap((
            icono_material("add", 32, "secondary"),
            icono_material("delete", 32, "error"),
            icono_material("close", 32, "on_surface"),
            icono_material("check", 32, "primary"),
            icono_material("send", 32, "primary"),
            icono_material("file", 32, "secondary"),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Iconos de estado:"),
        espacio(8),
        fila_con_gap((
            icono_material("info", 32, "primary"),
            icono_material("warning", 32, "#FF9800"),
            icono_material("error", 32, "error"),
            icono_material("favorite", 32, "#FF0000"),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Iconos de usuario:"),
        espacio(8),
        fila_con_gap((
            icono_material("person", 32, "primary"),
            icono_material("email", 32, "secondary"),
            icono_material("phone", 32, "secondary"),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Diferentes tamaños:"),
        espacio(8),
        fila_con_gap((
            icono_material("favorite", 16, "primary"),
            icono_material("favorite", 24, "primary"),
            icono_material("favorite", 32, "primary"),
            icono_material("favorite", 48, "primary"),
            icono_material("favorite", 64, "primary"),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Diferentes estilos:"),
        espacio(8),
        fila_con_gap((
            icono_relleno("favorite", 32),
            icono_perfilado("favorite", 32),
            icono_redondo("favorite", 32),
            icono_agudo("favorite", 32),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Iconos en botones:"),
        espacio(8),
        fila_con_gap((
            boton_icono(icono_material("home", 24, "on_primary_container"), &accion),
            boton_icono_relleno(icono_material("search", 24, "on_primary"), &accion),
            boton_icono_tonal(icono_material("settings", 24, "on_secondary_container"), &accion),
            boton_icono_perfilado(icono_material("favorite", 24, "primary"), &accion),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Iconos de comunicación:"),
        espacio(8),
        fila_con_gap((
            icono_material("chat", 32, "primary"),
            icono_material("notifications", 32, "secondary"),
            icono_material("forum", 32, "primary"),
            icono_material("share", 32, "secondary"),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Iconos de archivo:"),
        espacio(8),
        fila_con_gap((
            icono_material("folder", 32, "#FFC107"),
            icono_material("folder_open", 32, "#FFC107"),
            icono_material("download", 32, "primary"),
            icono_material("upload", 32, "primary"),
            icono_material("image", 32, "secondary"),
            icono_material("description", 32, "secondary"),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Iconos de lugar y mapa:"),
        espacio(8),
        fila_con_gap((
            icono_material("place", 32, "error"),
            icono_material("map", 32, "primary"),
            icono_material("directions", 32, "primary"),
            icono_material("restaurant", 32, "secondary"),
            icono_material("hotel", 32, "secondary"),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Calificaciones (estrellas y corazón):"),
        espacio(8),
        fila_con_gap((
            icono_material("star", 32, "#FFC107"),
            icono_material("star_half", 32, "#FFC107"),
            icono_material("star_outline", 32, "#FFC107"),
            icono_material("favorite", 32, "#FF0000"),
            icono_material("favorite_outline", 32, "#FF0000"),
            icono_material("thumb_up", 32, "primary"),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Iconos de editor y código:"),
        espacio(8),
        fila_con_gap((
            icono_material("code", 32, "primary"),
            icono_material("edit", 32, "secondary"),
            icono_material("copy", 32, "primary"),
            icono_material("save", 32, "primary"),
            icono_material("lock", 32, "secondary"),
            icono_material("visibility", 32, "primary"),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Iconos de dispositivo:"),
        espacio(8),
        fila_con_gap((
            icono_material("wifi", 32, "primary"),
            icono_material("bluetooth", 32, "primary"),
            icono_material("location", 32, "error"),
            icono_material("computer", 32, "secondary"),
            icono_material("phone_android", 32, "secondary"),
            icono_material("tablet", 32, "secondary"),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Iconos de comercio:"),
        espacio(8),
        fila_con_gap((
            icono_material("shopping_cart", 32, "primary"),
            icono_material("payment", 32, "primary"),
            icono_material("account_balance", 32, "secondary"),
            icono_material("store", 32, "primary"),
            icono_material("trending_up", 32, "primary"),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Iconos de red social:"),
        espacio(8),
        fila_con_gap((
            icono_material("public", 32, "primary"),
            icono_material("school", 32, "secondary"),
            icono_material("work", 32, "primary"),
            icono_material("group", 32, "secondary"),
            icono_material("celebration", 32, "#FF9800"),
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Fallback a emoji (icono no encontrado):"),
        espacio(8),
        fila_con_gap((
            icono_material("racoon", 32, "primary"),
            icono_material("unicornio", 32, "secondary"),
            icono_material("galaxy", 32, "error"),
        ), 16, "centro"),

        espacio(24),
        texto_mediano("Ejemplo completo con grid de iconos:"),
        espacio(8),

        # Grid de iconos básicos con colores del tema
        columna_con_gap((
            fila_con_gap((
                icono_material("home", 24, "primary"),
                icono_material("search", 24, "primary"),
                icono_material("settings", 24, "primary"),
                icono_material("info", 24, "primary"),
                icono_material("help", 24, "primary"),
                icono_material("feedback", 24, "primary"),
            ), 12, "centro"),
            fila_con_gap((
                icono_material("add", 24, "secondary"),
                icono_material("delete", 24, "error"),
                icono_material("edit", 24, "secondary"),
                icono_material("save", 24, "secondary"),
                icono_material("cancel", 24, "error"),
                icono_material("done", 24, "primary"),
            ), 12, "centro"),
            fila_con_gap((
                icono_material("email", 24, "primary"),
                icono_material("phone", 24, "primary"),
                icono_material("person", 24, "primary"),
                icono_material("chat", 24, "secondary"),
                icono_material("notifications", 24, "secondary"),
                icono_material("forum", 24, "primary"),
            ), 12, "centro"),
        ), 8, "centro"),
    )
}

funcion accion(valor: Texto) -> Texto {
    retornar valor
}
