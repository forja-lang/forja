/// Heap (montículo) para cola de prioridad
/// Conceptos: heap, montículo, max-heap, cola de prioridad, árbol binario en array
/// Nivel: avanzado

importar "std/io"

clase MaxHeap {
    elementos
    tamano

    constructor() {
        este.elementos = []
        este.tamano = 0
    }

    funcion padre(i) -> Entero {
        retornar (i - 1) / 2
    }

    funcion hijo_izquierdo(i) -> Entero {
        retornar 2 * i + 1
    }

    funcion hijo_derecho(i) -> Entero {
        retornar 2 * i + 2
    }

    funcion intercambiar(i, j) {
        variable temp = este.elementos[i]
        este.elementos[i] = este.elementos[j]
        este.elementos[j] = temp
    }

    funcion encolar(valor) {
        este.elementos[este.tamano] = valor
        este.tamano = este.tamano + 1

        variable i = este.tamano - 1
        mientras (i > 0 && este.elementos[este.padre(i)] < este.elementos[i]) {
            este.intercambiar(i, este.padre(i))
            i = este.padre(i)
        }
    }

    funcion hundir(i) {
        variable mayor = i
        variable izq = este.hijo_izquierdo(i)
        variable der = este.hijo_derecho(i)

        si (izq < este.tamano && este.elementos[izq] > este.elementos[mayor]) {
            mayor = izq
        }
        si (der < este.tamano && este.elementos[der] > este.elementos[mayor]) {
            mayor = der
        }
        si (mayor != i) {
            este.intercambiar(i, mayor)
            este.hundir(mayor)
        }
    }

    funcion desencolar() -> Entero {
        si (este.tamano == 0) {
            retornar nulo
        }
        variable maximo = este.elementos[0]
        este.elementos[0] = este.elementos[este.tamano - 1]
        este.tamano = este.tamano - 1
        este.hundir(0)
        retornar maximo
    }

    funcion ver_max() -> Entero {
        si (este.tamano == 0) {
            retornar nulo
        }
        retornar este.elementos[0]
    }

    funcion esta_vacia() -> Booleano {
        retornar este.tamano == 0
    }

    funcion mostrar() {
        escribir("  Heap: ${este.elementos[0..este.tamano-1]}")
        escribir("  Máximo: ${este.ver_max()}")
    }
}

funcion heap_sort(arr) {
    variable heap = nuevo MaxHeap()
    variable i = 0
    mientras (i < longitud(arr)) {
        heap.encolar(arr[i])
        i = i + 1
    }

    variable resultado = []
    variable j = 0
    mientras (!heap.esta_vacia()) {
        resultado[j] = heap.desencolar()
        j = j + 1
    }
    retornar resultado
}

funcion main() {
    escribir("=== Heap (Montículo / Cola de Prioridad) ===\n")

    variable heap = nuevo MaxHeap()

    escribir("Encolando: 30, 10, 50, 20, 40, 60\n")
    heap.encolar(30)
    heap.encolar(10)
    heap.encolar(50)
    heap.encolar(20)
    heap.encolar(40)
    heap.encolar(60)

    heap.mostrar()

    escribir("")
    escribir("Desencolando (siempre el máximo):")
    mientras (!heap.esta_vacia()) {
        escribir("  ${heap.desencolar()}")
    }

    escribir("")
    escribir("Heap Sort descendente:")
    variable numeros = [15, 3, 8, 22, 1, 19, 7, 12]
    escribir("  Original: ${numeros}")
    variable ordenados = heap_sort(numeros)
    escribir("  Ordenado: ${ordenados}")

    escribir("")
    escribir("El heap garantiza que el máximo sea siempre accesible en O(1).")
}

main()
