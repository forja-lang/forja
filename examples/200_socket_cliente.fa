

funcion probar_conexion_http() {
imprimir("Conectando a httpbin.org:80...")
variable socket = socket_tcp_conectar("httpbin.org", 80)
imprimir("¡Conectado!")
variable solicitud = "GET /get HTTP/1.1
Host: httpbin.org
Connection: close

"
variable bytes = socket_enviar(socket, solicitud)
imprimir("Enviados " + a_texto(bytes) + " bytes")
variable datos = socket_recibir(socket, 4096)
imprimir("Respuesta (" + a_texto(longitud(datos)) + " bytes):")
imprimir(datos)
socket_cerrar(socket)
imprimir("Socket cerrado")
}

funcion probar_info_socket() {
imprimir("")
imprimir("--- Información del socket ---")
variable socket = socket_tcp_conectar("httpbin.org", 80)
variable local = socket_direccion_local(socket)
variable remota = socket_direccion_remota(socket)
imprimir("Local: " + local)
imprimir("Remoto: " + remota)
socket_cerrar(socket)
}

probar_conexion_http()

probar_info_socket()

imprimir("")

imprimir("Pruebas completadas.")

