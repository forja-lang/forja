// 🎓 Lección 8: Listas (arrays)
// Las listas guardan varios valores en una variable.

variable frutas = ["manzana", "banana", "naranja"]
escribir(frutas)
escribir(frutas[0])
escribir(frutas[1])
escribir(frutas[2])

// Lista de números:
variable numeros = [10, 20, 30]
escribir(numeros[0])
escribir(numeros[1])
escribir(numeros[2])

// Recorrer array con para (solo lectura):
para (variable i = 0; i < 3; i = i + 1) {
    escribir(frutas[i])
}
