// 🎓 Lección 48: Contar elementos en arrays

variable palabras = ["Hola", "mundo", "desde", "Forja"]
variable cantidad = 4
escribir("Array de palabras: " + palabras)
escribir("Cantidad de palabras: " + cantidad)

// Mostrar cada palabra
para (variable i = 0; i < cantidad; i = i + 1) {
    escribir("  Palabra " + (i + 1) + ": " + palabras[i])
}
