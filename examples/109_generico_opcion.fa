/// Option<T> genérico manual
/// Conceptos: implementación manual de Opcion, Some, None
/// Nivel: avanzado

importar "std/io"

// Implementación manual del tipo Opcion<T>
// (el lenguaje ya tiene Opcion<T> built-in, esto es educativo)

clase MiOpcion<T> {
    tiene_valor
    valor
    
    constructor() {
        este.tiene_valor = falso
        este.valor = nulo
    }
    
    funcion es_some() -> Booleano {
        retornar este.tiene_valor
    }
    
    funcion es_none() -> Booleano {
        retornar no este.tiene_valor
    }
    
    funcion obtener_valor() -> Opcion<T> {
        si (este.tiene_valor) {
            retornar Some(este.valor)
        }
        retornar None
    }
}

funcion alguno<T>(valor: T) -> MiOpcion<T> {
    variable opt = nuevo MiOpcion<T>()
    opt.tiene_valor = verdadero
    opt.valor = valor
    retornar opt
}

funcion ninguno<T>() -> MiOpcion<T> {
    retornar nuevo MiOpcion<T>()
}

funcion main() {
    escribir("=== MiOpcion<T> Manual ===\n")
    
    variable opt_entero = alguno(42)
    variable opt_texto = alguno("Hola")
    variable opt_vacio = ninguno<Entero>()
    
    escribir("MiOpcion con 42:")
    escribir("  ¿Es Some? ${opt_entero.es_some()}")
    escribir("  ¿Es None? ${opt_entero.es_none()}")
    
    coincidir (opt_entero.obtener_valor()) {
        caso Some(v) -> escribir("  Valor: ${v}")
        caso None -> escribir("  Sin valor")
    }
    
    escribir("")
    escribir("MiOpcion con \"Hola\":")
    coincidir (opt_texto.obtener_valor()) {
        caso Some(v) -> escribir("  Valor: ${v}")
        caso None -> escribir("  Sin valor")
    }
    
    escribir("")
    escribir("MiOpcion vacío:")
    escribir("  ¿Es Some? ${opt_vacio.es_some()}")
    escribir("  ¿Es None? ${opt_vacio.es_none()}")
}

main()
