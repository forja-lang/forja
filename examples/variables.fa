// Variables y constantes en Forja
// variable = mutable, constante = inmutable

variable nombre = "Gaucho"
variable edad = 30
constante altura = 1.85

escribir("Nombre: " + nombre)
escribir("Edad: " + edad)

edad = 31  // funciona porque 'variable' es mutable
escribir("Nueva edad: " + edad)

// altura = 2.0  // ERROR: 'constante' no se puede modificar
