/// CODIFICACIÓN — Ejemplo de uso del módulo std/codificacion
///
/// Demuestra:
///   - Codificación y decodificación Base64
///   - Codificación y decodificación Hexadecimal
///   - Codificación y decodificación URL (percent-encoding)
///   - Manejo de errores en decodificación
///   - Caracteres especiales y UTF-8
///
/// Ejecutar:
///   cargo run --bin forja -- ejecutar examples\214_codificacion.fa

importar "std/codificacion"
importar "std/resultado"

funcion probar_base64() {
    escribir_linea("═══ BASE64 ═══")

    # Texto simple
    variable texto1 = "Hola Mundo"
    variable cod1 = codificacion.base64_codificar(texto1)
    escribir_linea("Original: '" + texto1 + "'")
    escribir_linea("Codificado: " + cod1)

    variable dec1 = codificacion.base64_decodificar(cod1)
    si (tipo(dec1) == "resultado_ok") {
        escribir_linea("Decodificado: '" + dec1.valor + "'")
    }

    # Texto con caracteres especiales
    variable texto2 = "Forja™ — Lenguaje ★ educativo"
    variable cod2 = codificacion.base64_codificar(texto2)
    escribir_linea("")
    escribir_linea("Original: '" + texto2 + "'")
    escribir_linea("Codificado: " + cod2)

    variable dec2 = codificacion.base64_decodificar(cod2)
    si (tipo(dec2) == "resultado_ok") {
        escribir_linea("Decodificado: '" + dec2.valor + "'")
    }

    # Error: Base64 inválido
    variable dec_err = codificacion.base64_decodificar("¡esto-no-es-base64!")
    si (tipo(dec_err) == "resultado_error") {
        escribir_linea("")
        escribir_linea("Error esperado al decodificar inválido:")
        escribir_linea("  mensaje: " + dec_err.error.mensaje)
        escribir_linea("  codigo: " + dec_err.error.codigo)
    }
}

funcion probar_hex() {
    escribir_linea("")
    escribir_linea("═══ HEXADECIMAL ═══")

    # Texto simple
    variable texto1 = "Hola Mundo"
    variable cod1 = codificacion.hex_codificar(texto1)
    escribir_linea("Original: '" + texto1 + "'")
    escribir_linea("Hex: " + cod1)

    variable dec1 = codificacion.hex_decodificar(cod1)
    si (tipo(dec1) == "resultado_ok") {
        escribir_linea("Decodificado: '" + dec1.valor + "'")
    }

    # Texto con UTF-8
    variable texto2 = "Ñoño & Café"
    variable cod2 = codificacion.hex_codificar(texto2)
    escribir_linea("")
    escribir_linea("Original: '" + texto2 + "'")
    escribir_linea("Hex: " + cod2)

    variable dec2 = codificacion.hex_decodificar(cod2)
    si (tipo(dec2) == "resultado_ok") {
        escribir_linea("Decodificado: '" + dec2.valor + "'")
    }

    # Error: Hex inválido (caracter 'Z' no es hex)
    variable dec_err = codificacion.hex_decodificar("4Z7A")
    si (tipo(dec_err) == "resultado_error") {
        escribir_linea("")
        escribir_linea("Error esperado al decodificar hex inválido:")
        escribir_linea("  mensaje: " + dec_err.error.mensaje)
        escribir_linea("  codigo: " + dec_err.error.codigo)
    }
}

funcion probar_url() {
    escribir_linea("")
    escribir_linea("═══ URL ═══")

    # Texto simple
    variable texto1 = "hola mundo"
    variable cod1 = codificacion.url_codificar(texto1)
    escribir_linea("Original: '" + texto1 + "'")
    escribir_linea("URL: " + cod1)

    variable dec1 = codificacion.url_decodificar(cod1)
    si (tipo(dec1) == "resultado_ok") {
        escribir_linea("Decodificado: '" + dec1.valor + "'")
    }

    # URL con caracteres especiales y query string
    variable texto2 = "a=b&c=d+e+f%20g"
    variable cod2 = codificacion.url_codificar(texto2)
    escribir_linea("")
    escribir_linea("Original: '" + texto2 + "'")
    escribir_linea("URL: " + cod2)

    variable dec2 = codificacion.url_decodificar(cod2)
    si (tipo(dec2) == "resultado_ok") {
        escribir_linea("Decodificado: '" + dec2.valor + "'")
    }

    # URL con caracteres acentuados y símbolos
    variable texto3 = "¿qué es Forja? ¡un lenguaje de programación! $100 + IVA"
    variable cod3 = codificacion.url_codificar(texto3)
    escribir_linea("")
    escribir_linea("Original: '" + texto3 + "'")
    escribir_linea("URL: " + cod3)

    variable dec3 = codificacion.url_decodificar(cod3)
    si (tipo(dec3) == "resultado_ok") {
        escribir_linea("Decodificado: '" + dec3.valor + "'")
    }

    # Decodificar con %XX y +
    variable url_codificada = "Hola+%2B+Adi%C3%B3s"
    variable dec4 = codificacion.url_decodificar(url_codificada)
    si (tipo(dec4) == "resultado_ok") {
        escribir_linea("")
        escribir_linea("URL codificada: '" + url_codificada + "'")
        escribir_linea("Decodificado: '" + dec4.valor + "'")
    }

    # Error: URL inválida (% sin 2 dígitos)
    variable dec_err = codificacion.url_decodificar("Hola%2GMundo")
    si (tipo(dec_err) == "resultado_error") {
        escribir_linea("")
        escribir_linea("Error esperado al decodificar URL inválida:")
        escribir_linea("  mensaje: " + dec_err.error.mensaje)
        escribir_linea("  codigo: " + dec_err.error.codigo)
    }

    # Decodificar + como espacio
    variable url_con_plus = "string+con+espacios"
    variable dec5 = codificacion.url_decodificar(url_con_plus)
    si (tipo(dec5) == "resultado_ok") {
        escribir_linea("")
        escribir_linea("URL con '+': '" + url_con_plus + "'")
        escribir_linea("Decodificado: '" + dec5.valor + "'")
    }

    # Caracteres seguros no se codifican: letras, dígitos, _, -, ., ~
    variable texto4 = "hello_123-45.test~end"
    variable cod4 = codificacion.url_codificar(texto4)
    escribir_linea("")
    escribir_linea("Caracteres seguros: '" + texto4 + "'")
    escribir_linea("URL (sin cambios): " + cod4)
}

funcion probar_hex_case() {
    escribir_linea("")
    escribir_linea("═══ HEX — MAYÚSCULAS/MINÚSCULAS ═══")

    # Verificar que hex_codificar produzca mayúsculas
    variable cod = codificacion.hex_codificar("abc")
    escribir_linea("hex_codificar('abc') = " + cod)

    # Verificar que hex_decodificar acepte minúsculas
    variable dec_min = codificacion.hex_decodificar("616263")
    si (tipo(dec_min) == "resultado_ok") {
        escribir_linea("hex_decodificar('616263') = '" + dec_min.valor + "'")
    }

    # Verificar que hex_decodificar acepte mayúsculas
    variable dec_may = codificacion.hex_decodificar("414243")
    si (tipo(dec_may) == "resultado_ok") {
        escribir_linea("hex_decodificar('414243') = '" + dec_may.valor + "'")
    }

    # Verificar que hex_decodificar acepte mixto
    variable dec_mix = codificacion.hex_decodificar("aBcDeF")
    si (tipo(dec_mix) == "resultado_ok") {
        escribir_linea("hex_decodificar('aBcDeF') = '" + dec_mix.valor + "'")
    }
}

funcion main() {
    escribir_linea("=== MÓDULO DE CODIFICACIÓN ===")
    escribir_linea("")

    probar_base64()
    probar_hex()
    probar_hex_case()
    probar_url()

    escribir_linea("")
    escribir_linea("=== ¡Todas las pruebas completadas! ===")
}
