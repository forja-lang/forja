// 🎓 Lección 9: Operaciones con texto (strings)
// Podemos trabajar con texto usando concatenación

variable mensaje = "Hola, Forja!"
variable largo = 12  // forzamos el largo conocido
escribir(mensaje)

// Concatenar (unir) textos:
variable saludo = "Hola"
variable nombre = "Ana"
variable completo = saludo + " " + nombre + "!"
escribir(completo)

// Texto con números:
variable edad = 25
variable presentacion = "Me llamo " + nombre + " y tengo " + edad + " años"
escribir(presentacion)

// Repetir texto con bucle:
escribir("Letra a letra:")
para (variable i = 0; i < 5; i = i + 1) {
    escribir("  Carácter en posición " + i)
}

// Comparar textos:
variable texto1 = "Hola"
variable texto2 = "hola"
variable sonIguales = texto1 == texto2
escribir("¿Son iguales? " + sonIguales)
