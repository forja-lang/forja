// Tipos explícitos y mutabilidad en Forja
// variable = mutable (let mut en Rust)
// constante = inmutable (let en Rust)

// Con tipo explícito y valor
variable nombre: Texto = "Gaucho"
variable edad: Entero = 30
variable altura: Decimal = 1.85
constante activo: Booleano = verdadero

// Con tipo explícito sin valor inicial
variable mensaje: Texto = ""
variable contador: Entero = 0

// Sin tipo (inferido)
variable ciudad = "Buenos Aires"
constante pais = "Argentina"

// Modificando variables (mutable por defecto)
mensaje = "Hola " + nombre
contador = contador + 1

escribir(mensaje)
escribir("Edad: " + edad)
escribir("Altura: " + altura)
escribir("Ciudad: " + ciudad)
