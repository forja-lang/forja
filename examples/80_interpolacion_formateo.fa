/// Interpolación combinada con métodos de string
/// Conceptos: métodos length, to_upper, to_lower en interpolación
/// Nivel: intermedio

importar "std/io"

// Combinación de interpolación con métodos de string

variable texto = "forja lenguaje"
variable numero = 42

// Uso de métodos de string dentro de interpolación:
// Nota: los métodos se llaman con la sintaxis objeto.metodo()
escribir("Texto original: ${texto}")
escribir("En mayúsculas: ${texto.to_upper()}")
escribir("En minúsculas: ${texto.to_lower()}")
escribir("Longitud: ${texto.length()}")

// Reemplazo de texto:
variable saludo = "Hola Mundo"
escribir("Reemplazo: ${saludo.replace('Mundo', 'Forja')}")

// Combinaciones:
variable nombre = "ana"
variable ciudad = "buenos aires"
escribir("Nombre formateado: ${nombre.to_upper()}")
escribir("${nombre.to_upper()} vive en ${ciudad.to_upper()}")

// Números y texto combinados:
variable cantidad = 7
variable item = "manzanas"
escribir("Tengo ${cantidad} ${item}")
escribir("Tengo ${cantidad} ${item.to_upper()}")
