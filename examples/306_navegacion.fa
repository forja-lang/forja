# Ejemplo: Navegación Material You
# Muestra: barra superior, búsqueda, pestañas y barra de navegación inferior

importar "gui"

funcion main() {
    variable pagina = 0
    variable busqueda = ""

    columna(
        barra_superior("Mi App", (boton_icono("🔔", &notificar), boton_icono("⚙️", &ajustes))),

        espacio(8),
        barra_busqueda("Buscar...", busqueda),
        espacio(8),

        pestañas(("Inicio", "Explorar", "Perfil"), pagina, &cambiar_pagina),
        espacio(16),

        # Contenido según página
        si pagina == 0 {
            tarjeta(columna((
                texto_mediano("Página de Inicio"),
                etiqueta("Bienvenido a la app Material You"),
            )))
        } sino si pagina == 1 {
            tarjeta(columna((
                texto_mediano("Explorar"),
                etiqueta("Contenido para explorar"),
            )))
        } sino {
            tarjeta(columna((
                texto_mediano("Perfil"),
                etiqueta("Tu perfil de usuario"),
            )))
        },

        espacio(16),
        separador(),

        barra_navegacion(
            (item_navegacion("🏠", "Inicio"),
             item_navegacion("🔍", "Explorar"),
             item_navegacion("👤", "Perfil")),
            pagina, &cambiar_pagina
        )
    )
}

funcion cambiar_pagina(valor: Texto) -> Texto {
    retornar valor
}

funcion notificar(valor: Texto) -> Texto {
    retornar valor
}

funcion ajustes(valor: Texto) -> Texto {
    retornar valor
}
