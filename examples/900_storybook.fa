# ═══════════════════════════════════════════════════════════════════
#  FORJA STORYBOOK — Visor Interactivo de Componentes
#  Muestra los ~200 componentes organizados en 11 categorías
#  con preview en vivo, controles editables y toggle de tema.
# ═══════════════════════════════════════════════════════════════════
#
#  Ejecutar (nativo):
#    forja-gui examples/900_storybook.fa
#    forja-gui --dark examples/900_storybook.fa
#    forja-gui --tema #FF5722 examples/900_storybook.fa
#
#  Compilar y ejecutar:
#    cargo build --features gui
#    cargo run --bin forja --features gui -- ejemplo examples/900_storybook.fa
#
# ═══════════════════════════════════════════════════════════════════

importar "gui"

# ═══════════════════════════════════════════════════════════════════
#  FUNCIÓN PRINCIPAL
# ═══════════════════════════════════════════════════════════════════

funcion main() {
    variable pagina = 0
    variable tema_oscuro = "falso"
    variable color_seed = "#6750A4"

    # Variables para controles en secciones
    variable btn_disabled = "falso"
    variable btn_icon = "falso"
    variable switch_val = "verdadero"
    variable slider_val = "50"
    variable texto_val = ""
    variable rating_val = "3"

    andamio(
        barra_superior(
            "🎨 Forja Storybook",
            (
                boton_icono("☀️", &toggle_tema_cb),
                boton_icono("⚙️", &ajustes_cb)
            )
        ),

        fila((
            riel_navegacion(
                (item_navegacion("🔘", "Botones"),
                 item_navegacion("⌨️", "Inputs"),
                 item_navegacion("🃏", "Tarjetas"),
                 item_navegacion("💬", "Feedback"),
                 item_navegacion("🧭", "Navegación"),
                 item_navegacion("📊", "Indicadores"),
                 item_navegacion("👤", "Avatares"),
                 item_navegacion("📈", "Gráficos"),
                 item_navegacion("🎭", "Expressive"),
                 item_navegacion("🏃", "Motion"),
                 item_navegacion("📐", "Layout")),
                pagina,
                &cambiar_pagina_cb
            ),

            desplazable(
                columna(
                    texto_grande(titulo_categoria(pagina)),
                    espacio(4),
                    separador(),
                    espacio(8),

                    # Renderizar según categoría activa
                    si (pagina == 0) {
                        seccion_botones(btn_disabled, btn_icon)
                    } sino {
                        si (pagina == 1) {
                            seccion_inputs(texto_val, slider_val, switch_val)
                        } sino {
                            si (pagina == 2) {
                                seccion_tarjetas()
                            } sino {
                                si (pagina == 3) {
                                    seccion_feedback()
                                } sino {
                                    si (pagina == 4) {
                                        seccion_navegacion()
                                    } sino {
                                        si (pagina == 5) {
                                            seccion_indicadores(slider_val)
                                        } sino {
                                            si (pagina == 6) {
                                                seccion_avatares()
                                            } sino {
                                                si (pagina == 7) {
                                                    seccion_graficos(rating_val)
                                                } sino {
                                                    si (pagina == 8) {
                                                        seccion_expressive()
                                                    } sino {
                                                        si (pagina == 9) {
                                                            seccion_motion()
                                                        } sino {
                                                            seccion_layout()
                                                        }
                                                    }
                                                }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                    }
                )
            )
        ))
    )
}

# ═══════════════════════════════════════════════════════════════════
#  TÍTULO DE CATEGORÍA
# ═══════════════════════════════════════════════════════════════════

funcion titulo_categoria(p: Entero) -> Texto {
    si (p == 0) { retornar "🔘 Botones" }
    sino {
        si (p == 1) { retornar "⌨️ Inputs y Formularios" }
        sino {
            si (p == 2) { retornar "🃏 Tarjetas y Listas" }
            sino {
                si (p == 3) { retornar "💬 Feedback" }
                sino {
                    si (p == 4) { retornar "🧭 Navegación" }
                    sino {
                        si (p == 5) { retornar "📊 Indicadores" }
                        sino {
                            si (p == 6) { retornar "👤 Avatares" }
                            sino {
                                si (p == 7) { retornar "📈 Gráficos" }
                                sino {
                                    si (p == 8) { retornar "🎭 Expressive" }
                                    sino {
                                        si (p == 9) { retornar "🏃 Motion" }
                                        sino { retornar "📐 Layout" }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

# ═══════════════════════════════════════════════════════════════════
#  SECCIÓN 0: BOTONES
# ═══════════════════════════════════════════════════════════════════

funcion seccion_botones(disabled: Texto, con_icono: Texto) {
    retornar columna(
        texto_mediano("Variantes principales"),
        espacio(8),
        fila_con_gap((
            boton_relleno("Relleno", &accion_story),
            boton_tonal("Tonal", &accion_story),
            boton_perfilado("Perfilado", &accion_story),
            boton_texto("Texto", &accion_story),
            boton_elevado("Elevado", &accion_story)
        ), 8, "centro"),

        espacio(16),
        texto_mediano("FAB"),
        espacio(8),
        fila_con_gap((
            fab_pequeño("➕", &accion_story),
            fab("➕", &accion_story),
            fab_grande("➕", &accion_story),
            fab_extendido("Crear", "➕", &accion_story)
        ), 8, "centro"),

        espacio(16),
        texto_mediano("Icon Buttons"),
        espacio(8),
        fila_con_gap((
            boton_icono("⭐", &accion_story),
            boton_icono_relleno("⭐", &accion_story),
            boton_icono_tonal("⭐", &accion_story),
            boton_icono_perfilado("⭐", &accion_story)
        ), 8, "centro"),

        espacio(16),
        texto_mediano("Segmented Buttons"),
        espacio(8),
        segmentado(("Día", "Semana", "Mes"), 0, &accion_story),
        espacio(4),
        segmentado_multiple(("A", "B", "C"), (verdadero, falso, falso), &accion_story),

        espacio(16),
        texto_mediano("Chips"),
        espacio(8),
        flujo((
            subconjunto_asistente("Ayuda", &accion_story),
            subconjunto_filtro("Filtro", verdadero, &accion_story),
            subconjunto_entrada("Cerrar ✕", &accion_story),
            subconjunto_sugerencia("Sugerencia", &accion_story)
        ), 8),

        espacio(16),
        separador(),
        texto_mediano("🎛️ Controles"),
        espacio(8),
        interruptor("Deshabilitado", disabled),
        espacio(4),
        interruptor("Mostrar icono", con_icono)
    )
}

# ═══════════════════════════════════════════════════════════════════
#  SECCIÓN 1: INPUTS
# ═══════════════════════════════════════════════════════════════════

funcion seccion_inputs(texto: Texto, slider: Texto, sw: Texto) {
    retornar columna(
        texto_mediano("Campos de texto"),
        espacio(8),
        campo_texto(texto, "Texto (relleno)"),
        espacio(8),
        campo_perfilado(texto, "Texto (perfilado)"),
        espacio(8),
        campo_email(texto, "Correo electrónico"),
        espacio(8),
        campo_contraseña(texto, "Contraseña"),
        espacio(8),
        campo_numero(texto, "Edad", 0, 150),
        espacio(8),
        campo_busqueda(texto),

        espacio(16),
        texto_mediano("Selección"),
        espacio(8),
        menu_seleccion(("Opción 1", "Opción 2", "Opción 3"), 0, "Elegir..."),

        espacio(16),
        texto_mediano("Controles"),
        espacio(8),
        interruptor("Interruptor", sw),
        espacio(8),
        deslizante(slider, 0, 100),
        espacio(8),
        deslizante_discreto(slider, 0, 100, 10),

        espacio(16),
        texto_mediano("Fecha y Hora"),
        espacio(8),
        fila_con_gap((
            selector_fecha("2025-01-15"),
            selector_hora("14:30")
        ), 16, "centro"),

        espacio(16),
        texto_mediano("Color"),
        espacio(8),
        selector_color("#6750A4")
    )
}

