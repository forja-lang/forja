// 🎓 Lección 3: Tipos de datos
// Cada valor tiene un tipo: Entero, Decimal, Texto, Booleano.

variable edad: Entero = 30        // Números sin decimales
variable altura: Decimal = 1.75   // Números con decimales
variable nombre: Texto = "Luis"   // Palabras o texto
variable activo: Booleano = verdadero  // verdadero o falso

escribir("Edad: " + edad)
escribir("Altura: " + altura)
escribir("Nombre: " + nombre)
escribir("Activo: " + activo)

// Si no especificás el tipo, Forja lo infiere:
variable ciudad = "Buenos Aires"  // Forja sabe que es Texto
escribir("Ciudad: " + ciudad)
