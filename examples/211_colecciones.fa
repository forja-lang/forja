/// 🧪 Ejemplo 211: Operaciones funcionales sobre colecciones
/// Demostración del módulo std/colecciones con map, filter, reduce, etc.
/// Ejecutar con: forja run examples/211_colecciones.fa

importar "std/io"
importar "std/colecciones"

# ─── Funciones callback auxiliares ──────────────────────

funcion duplicar(x) {
    retornar x * 2
}

funcion exclamar(s) {
    retornar s + "!"
}

funcion es_par(x) -> Booleano {
    retornar x % 2 == 0
}

funcion es_mayor_que_3(x) -> Booleano {
    retornar x > 3
}

funcion es_negativo(x) -> Booleano {
    retornar x < 0
}

funcion es_positivo(x) -> Booleano {
    retornar x > 0
}

funcion sumar(acc, x) {
    retornar acc + x
}

funcion multiplicar(acc, x) {
    retornar acc * x
}

funcion cuadrar(x) {
    retornar x * x
}

# ─── Main ──────────────────────────────────────────────

funcion main() {
    escribir("╔══════════════════════════════════════════════╗")
    escribir("║    Operaciones Funcionales sobre Colecciones ║")
    escribir("╚══════════════════════════════════════════════╝")
    escribir("")

    # ─── mapa() ──────────────────────────────────────────────
    escribir("─── mapa() ───")

    variable numeros = [1, 2, 3, 4, 5]
    variable dobles = colecciones.mapa(numeros, duplicar)
    escribir("  mapa([1,2,3,4,5], duplicar):")
    escribir("    " + dobles)
    # → [2, 4, 6, 8, 10]

    variable palabras = ["hola", "mundo", "forja"]
    variable gritos = colecciones.mapa(palabras, exclamar)
    escribir("  mapa([\"hola\",\"mundo\",\"forja\"], exclamar):")
    escribir("    " + gritos)
    # → ["hola!", "mundo!", "forja!"]

    # ─── filtrar() ───────────────────────────────────────────
    escribir("─── filtrar() ───")

    variable pares = colecciones.filtrar(numeros, es_par)
    escribir("  filtrar([1,2,3,4,5], es_par):")
    escribir("    " + pares)
    # → [2, 4]

    variable mayores_a_3 = colecciones.filtrar(numeros, es_mayor_que_3)
    escribir("  filtrar([1,2,3,4,5], >3):")
    escribir("    " + mayores_a_3)
    # → [4, 5]

    # ─── reducir() ──────────────────────────────────────────
    escribir("─── reducir() ───")

    variable suma = colecciones.reducir(numeros, sumar, 0)
    escribir("  suma con reducir([1,2,3,4,5]): " + suma)
    # → 15

    variable producto = colecciones.reducir(numeros, multiplicar, 1)
    escribir("  producto con reducir([1,2,3,4,5]): " + producto)
    # → 120

    # ─── encontrar() ─────────────────────────────────────────
    escribir("─── encontrar() ───")

    variable primer_mayor_3 = colecciones.encontrar(numeros, es_mayor_que_3)
    escribir("  encontrar([1,2,3,4,5], >3): " + primer_mayor_3)
    # → 4

    variable no_encontrado = colecciones.encontrar(numeros, es_negativo)
    escribir("  encontrar([1,2,3,4,5], negativo): " + no_encontrado)
    # → nulo

    # ─── alguno() ────────────────────────────────────────────
    escribir("─── alguno() ───")

    variable hay_pares = colecciones.alguno(numeros, es_par)
    escribir("  ¿algún par en [1,2,3,4,5]?: " + hay_pares)
    # → verdadero

    variable hay_negativos = colecciones.alguno(numeros, es_negativo)
    escribir("  ¿algún negativo?: " + hay_negativos)
    # → falso

    # ─── todos() ─────────────────────────────────────────────
    escribir("─── todos() ───")

    variable todos_positivos = colecciones.todos(numeros, es_positivo)
    escribir("  ¿todos positivos en [1,2,3,4,5]?: " + todos_positivos)
    # → verdadero

    variable todos_pares = colecciones.todos(numeros, es_par)
    escribir("  ¿todos pares en [1,2,3,4,5]?: " + todos_pares)
    # → falso

    # ─── ordenar() ───────────────────────────────────────────
    escribir("─── ordenar() ───")

    variable desordenado = [3, 1, 4, 1, 5, 9, 2, 6]
    variable ordenado = colecciones.ordenar(desordenado)
    escribir("  ordenar([3,1,4,1,5,9,2,6]):")
    escribir("    " + ordenado)
    # → [1, 1, 2, 3, 4, 5, 6, 9]

    # Verificar que el original no se modificó
    escribir("  original intacto:")
    escribir("    " + desordenado)
    # → [3, 1, 4, 1, 5, 9, 2, 6]

    # ─── aplanar() ──────────────────────────────────────────
    escribir("─── aplanar() ───")

    variable anidado = [[1, 2], [3, [4]], 5]
    variable plano = colecciones.aplanar(anidado)
    escribir("  aplanar([[1,2],[3,[4]],5]):")
    escribir("    " + plano)
    # → [1, 2, 3, [4], 5]

    # ─── unico() ─────────────────────────────────────────────
    escribir("─── unico() ───")

    variable con_duplicados = [1, 2, 2, 3, 1, 4, 3, 5]
    variable sin_duplicados = colecciones.unico(con_duplicados)
    escribir("  unico([1,2,2,3,1,4,3,5]):")
    escribir("    " + sin_duplicados)
    # → [1, 2, 3, 4, 5]

    # ─── invertir() ─────────────────────────────────────────
    escribir("─── invertir() ───")

    variable invertido = colecciones.invertir(numeros)
    escribir("  invertir([1,2,3,4,5]):")
    escribir("    " + invertido)
    # → [5, 4, 3, 2, 1]

    # ─── segmento() ─────────────────────────────────────────
    escribir("─── segmento() ───")

    variable letras = ["a", "b", "c", "d", "e"]
    variable segmentado = colecciones.segmento(letras, 1, 4)
    escribir("  segmento([a,b,c,d,e], 1, 4):")
    escribir("    " + segmentado)
    # → ["b", "c", "d"]

    # ─── Combinación de operaciones ─────────────────────────
    escribir("─── Combinación de operaciones ───")

    # Ejemplo: números pares, al cuadrado, ordenados
    variable resultado_final = colecciones.ordenar(
        colecciones.mapa(
            colecciones.filtrar([8, 3, 1, 6, 4, 7, 2, 5], es_par),
            cuadrar
        )
    )
    escribir("  pares al cuadrado y ordenados:")
    escribir("    " + resultado_final)
    # → [4, 16, 36, 64]

    # ─── Mapas (API definida, pendiente de iteración nativa) ─
    escribir("─── Mapas (API definida) ───")
    escribir("  Las funciones claves(), valores(), pares(),")
    escribir("  fusionar() y filtrar_claves() están definidas")
    escribir("  y requieren soporte futuro de iteración nativa")
    escribir("  sobre mapas en el runtime de Forja.")
}

main()
