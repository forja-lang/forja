# Ejemplo: Feedback y Superposiciones Material You
# Muestra: Diálogos, Bottom Sheets, Snackbar, Tooltips y Menús
importar "gui"

funcion main() {
    variable mostrar_snackbar = falso
    variable mostrar_hoja = falso
    variable seleccion_menu = 0
    
    columna(
        texto_grande("Feedback y Superposiciones"),
        espacio(16),
        
        texto_mediano("Diálogos:"),
        espacio(8),
        boton_relleno("Mostrar Alerta", &mostrar_alerta),
        espacio(8),
        boton_tonal("Diálogo Confirmación", &mostrar_confirmacion),
        
        espacio(16),
        texto_mediano("Bottom Sheets:"),
        espacio(8),
        boton_tonal("Abrir Hoja Inferior", &abrir_hoja),
        
        espacio(16),
        texto_mediano("Snackbar:"),
        espacio(8),
        boton_relleno("Mostrar Notificación", &mostrar_notificacion),
        
        espacio(16),
        if mostrar_snackbar == verdadero {
            notificación_accion("Archivo guardado correctamente", "Deshacer", &deshacer)
        },
        
        espacio(16),
        texto_mediano("Tooltip:"),
        espacio(8),
        información(boton_icono("❓", &ayuda), "Haz clic para obtener ayuda"),
        
        espacio(16),
        texto_mediano("Menú:"),
        espacio(8),
        menú_desplegable(("Opción 1", "Opción 2", "Opción 3"), seleccion_menu, &seleccionar)
    )
}

funcion mostrar_alerta(valor: Texto) -> Texto {
    dialogo_alerta("Bienvenido", "Este es un diálogo de alerta Material You")
    retornar valor
}

funcion mostrar_confirmacion(valor: Texto) -> Texto {
    dialogo_confirmacion("¿Eliminar?", "Esta acción no se puede deshacer", &confirmar_eliminar, &cancelar_eliminar)
    retornar valor
}

funcion confirmar_eliminar(valor: Texto) -> Texto {
    notificación("Elemento eliminado")
    retornar valor
}

funcion cancelar_eliminar(valor: Texto) -> Texto {
    notificación("Operación cancelada")
    retornar valor
}

funcion abrir_hoja(valor: Texto) -> Texto {
    hoja_inferior(columna((
        texto_mediano("Opciones"),
        espacio(8),
        boton_relleno("Cerrar", &cerrar_hoja)
    )), "true")
    retornar valor
}

funcion cerrar_hoja(valor: Texto) -> Texto {
    retornar valor
}

funcion mostrar_notificacion(valor: Texto) -> Texto {
    mostrar_snackbar = verdadero
    retornar valor
}

funcion deshacer(valor: Texto) -> Texto {
    retornar "Acción deshecha"
}

funcion ayuda(valor: Texto) -> Texto {
    retornar "Ayuda mostrada"
}

funcion seleccionar(valor: Texto) -> Texto {
    retornar valor
}
