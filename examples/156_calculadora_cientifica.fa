/// Calculadora Científica
/// Conceptos: funciones matemáticas, operaciones, menú interactivo, precisión
/// Nivel: intermedio

importar "std/io"
importar "std/matematica"

// Calculadora científica interactiva que soporta operaciones básicas,
// trigonometría, logaritmos, potencias y raíces.

funcion menu_principal() -> Entero {
    escribir("")
    escribir("=== CALCULADORA CIENTÍFICA ===")
    escribir("1. Sumar")
    escribir("2. Restar")
    escribir("3. Multiplicar")
    escribir("4. Dividir")
    escribir("5. Potencia (x^y)")
    escribir("6. Raíz cuadrada")
    escribir("7. Seno (grados)")
    escribir("8. Coseno (grados)")
    escribir("9. Logaritmo (base 10)")
    escribir("10. Logaritmo natural")
    escribir("11. Factorial")
    escribir("12. Valor absoluto")
    escribir("0. Salir")
    variable op = pedir_numero("\nElige una opción: ")
    retornar op
}

funcion aproximar_pi() -> Decimal {
    // Aproximación simple de π
    retornar 3.1415926535
}

funcion seno_aprox(grados) -> Decimal {
    // Aproximación de seno usando serie de Taylor
    variable rad = grados * aproximar_pi() / 180
    variable termino = rad
    variable suma = rad
    variable i = 1
    mientras (i < 8) {
        termino = -termino * rad * rad / ((2 * i) * (2 * i + 1))
        suma = suma + termino
        i = i + 1
    }
    retornar suma
}

funcion coseno_aprox(grados) -> Decimal {
    variable rad = grados * aproximar_pi() / 180
    variable termino = 1
    variable suma = 1
    variable i = 1
    mientras (i < 8) {
        termino = -termino * rad * rad / ((2 * i - 1) * (2 * i))
        suma = suma + termino
        i = i + 1
    }
    retornar suma
}

funcion ln_aprox(x) -> Decimal {
    si (x <= 0) {
        retornar -999999
    }
    // Aproximación usando expansión
    variable y = (x - 1) / (x + 1)
    variable suma = 0
    variable i = 0
    mientras (i < 20) {
        suma = suma + (1.0 / (2 * i + 1)) * potencia(y, 2 * i + 1)
        i = i + 1
    }
    retornar 2 * suma
}

funcion main() {
    variable opcion = -1
    mientras (opcion != 0) {
        opcion = menu_principal()
        variable a = 0
        variable b = 0

        si (opcion == 0) {
            escribir("¡Hasta luego!")
        } sino {
            si (opcion >= 1 && opcion <= 4) {
                a = pedir_numero("Primer número: ")
                b = pedir_numero("Segundo número: ")
            } sino {
                si (opcion == 5) {
                    a = pedir_numero("Base: ")
                    b = pedir_numero("Exponente: ")
                } sino {
                    si (opcion == 6 || opcion == 9 || opcion == 10 || opcion == 11 || opcion == 12) {
                        a = pedir_numero("Número: ")
                    } sino {
                        si (opcion == 7 || opcion == 8) {
                            a = pedir_numero("Ángulo en grados: ")
                        }
                    }
                }
            }

            variable resultado = 0
            si (opcion == 1) { resultado = a + b }
            si (opcion == 2) { resultado = a - b }
            si (opcion == 3) { resultado = a * b }
            si (opcion == 4) {
                si (b == 0) {
                    escribir("  Error: División por cero.")
                    continuar
                }
                resultado = a / b
            }
            si (opcion == 5) { resultado = potencia(a, b) }
            si (opcion == 6) {
                si (a < 0) {
                    escribir("  Error: Raíz negativa.")
                    continuar
                }
                resultado = potencia(a, 0.5)
            }
            si (opcion == 7) { resultado = seno_aprox(a) }
            si (opcion == 8) { resultado = coseno_aprox(a) }
            si (opcion == 9) { resultado = ln_aprox(a) / ln_aprox(10) }
            si (opcion == 10) { resultado = ln_aprox(a) }
            si (opcion == 11) {
                si (a < 0) {
                    escribir("  Error: Factorial de número negativo.")
                    continuar
                }
                resultado = factorial(a)
            }
            si (opcion == 12) { resultado = abs(a) }

            escribir("  Resultado: ${resultado}")
        }
    }
}

main()
