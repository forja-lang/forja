# ═══════════════════════════════════════════════════════════════════
#  CALLBACKS
# ═══════════════════════════════════════════════════════════════════

funcion accion_story(valor: Texto) -> Texto {
    retornar valor
}

funcion toggle_tema_cb(valor: Texto) -> Texto {
    retornar "Tema alternado"
}

funcion abrir_panel_tema_cb(valor: Texto) -> Texto {
    notificación("Panel de tema abierto")
    retornar valor
}

funcion cambiar_pagina_cb(valor: Texto) -> Texto {
    retornar valor
}

funcion cambiar_tab_cb(valor: Texto) -> Texto {
    retornar valor
}

