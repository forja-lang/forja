    retornar valor
}

# ─── Diálogos ───

funcion mostrar_alerta_cb(valor: Texto) -> Texto {
    dialogo_alerta("Título", "Mensaje de alerta Material You")
    retornar valor
}

funcion mostrar_confirmacion_cb(valor: Texto) -> Texto {
    dialogo_confirmacion("¿Confirmar?", "¿Estás seguro?", &accion_story, &accion_story)
    retornar valor
}

funcion mostrar_personalizado_cb(valor: Texto) -> Texto {
    dialogo_personalizado("Personalizado",
        columna((
            etiqueta("Contenido personalizado"),
            campo_texto("", "Campo en diálogo"),
            boton_relleno("OK", &accion_story)
        ))
    )
    retornar valor
}

funcion mostrar_hoja_cb(valor: Texto) -> Texto {
    hoja_inferior(
        columna((
            texto_mediano("Bottom Sheet"),
            etiqueta("Contenido de la hoja inferior"),
            boton_relleno("Cerrar", &accion_story)
        )),
        "verdadero"
    )
    retornar valor
}

funcion mostrar_hoja_modal_cb(valor: Texto) -> Texto {
    hoja_inferior_modal(
        columna((
            texto_mediano("Modal Sheet"),
            etiqueta("Overlay semitransparente"),
            boton_relleno("Cerrar", &accion_story)
        )),
        "verdadero"
    )
    retornar valor
}

funcion mostrar_notificacion_cb(valor: Texto) -> Texto {
    notificación("Archivo guardado correctamente")
    retornar valor
}

funcion mostrar_notificacion_accion_cb(valor: Texto) -> Texto {
    notificación_accion("Cambios detectados", "Guardar", &accion_story)
    retornar valor
}
