# ═══════════════════════════════════════════════════════════════════
#  FORJA STORYBOOK — Theme Edition
#  Storybook completo + panel de control de tema en vivo:
#    - Selector de color semilla (Material You / Monet)
#    - Toggle claro/oscuro
#    - Preview de paleta de colores generada
# ═══════════════════════════════════════════════════════════════════
#
#  Ejecutar:
#    forja-gui examples/901_storybook_theme.fa
#    forja-gui --dark --tema #004D40 examples/901_storybook_theme.fa
#
# ═══════════════════════════════════════════════════════════════════

importar "gui"

# ═══════════════════════════════════════════════════════════════════
#  FUNCIÓN PRINCIPAL
# ═══════════════════════════════════════════════════════════════════

funcion main() {
    # ─── Variables de estado ───
    variable pagina = 0
    variable tema_oscuro = "falso"
    variable color_semilla = "#6750A4"

    # ─── Variables para controles ───
    variable btn_disabled = "falso"
    variable btn_icon = "falso"
    variable switch_val = "verdadero"
    variable slider_val = "50"
    variable texto_val = ""
    variable rating_val = "3"

    # ─── Colores predefinidos ───
    variable color_idx = 0

    # ─── Andamio principal ───
    andamio(
        barra_superior(
            "🎨 Forja Storybook — Theme",
            (
                boton_icono("🌙", &toggle_tema_cb),
                boton_icono("🎨", &abrir_panel_tema_cb)
            )
        ),

        fila((

            # ──────────────────────────────────────────────
            # SIDEBAR: Navegación por categorías
            # ──────────────────────────────────────────────
            riel_navegacion(
                (item_navegacion("🔘", "Botones"),
                 item_navegacion("⌨️", "Inputs"),
                 item_navegacion("🃏", "Tarjetas"),
                 item_navegacion("💬", "Feedback"),
                 item_navegacion("🧭", "Navegación"),
                 item_navegacion("📊", "Indicadores"),
                 item_navegacion("👤", "Avatares"),
                 item_navegacion("📈", "Gráficos"),
                 item_navegacion("🎭", "Expressive"),
                 item_navegacion("🏃", "Motion"),
                 item_navegacion("📐", "Layout")),
                pagina,
                &cambiar_pagina_cb
            ),

            # ──────────────────────────────────────────────
            # CONTENIDO PRINCIPAL
            # ──────────────────────────────────────────────
            desplazable(
                columna(

                    # ── Panel de control de tema ──
                    panel_tema(color_semilla, tema_oscuro, color_idx),

                    espacio(8),
                    separador(),
                    espacio(8),

                    # ── Contenido de la categoría activa ──
                    texto_grande(titulo_categoria(pagina)),
                    espacio(4),
                    separador(),
                    espacio(8),

                    seccion_activa(pagina,
                        btn_disabled, btn_icon,
                        texto_val, slider_val, switch_val,
                        rating_val)
                )
            )
        ))
    )
}

# ═══════════════════════════════════════════════════════════════════
#  PANEL DE CONTROL DE TEMA
# ═══════════════════════════════════════════════════════════════════

funcion panel_tema(color: Texto, oscuro: Texto, idx: Entero) {
    retornar columna(
        texto_grande("🎛️ Panel de Tema"),
        espacio(4),
        separador(),
        espacio(8),

        # ── Selector de color semilla ──
        texto_mediano("Color semilla (Material You)"),
        espacio(4),
        fila_con_gap((
            selector_color(color),
            etiqueta("  #6750A4 (púrpura)"),
        ), 8, "centro"),
        espacio(4),

        # ── Colores predefinidos ──
        texto_mediano("Colores predefinidos"),
        espacio(4),
        fila_con_gap((
            boton_icono("🟣", &color_morado_cb),
            boton_icono("🔵", &color_azul_cb),
            boton_icono("🟢", &color_verde_cb),
            boton_icono("🟠", &color_naranja_cb),
            boton_icono("🔴", &color_rojo_cb),
            boton_icono("⚫", &color_gris_cb),
        ), 4, "centro"),

        espacio(12),

        # ── Toggle claro/oscuro ──
        texto_mediano("Modo de tema"),
        espacio(4),
        interruptor("Modo oscuro", oscuro),

        espacio(12),

        # ── Preview de paleta ──
        texto_mediano("Preview de paleta"),
        espacio(4),
        fila_con_gap((
            preview_color("#6750A4"),
            preview_color("#D0BCFF"),
            preview_color("#FFB4AB"),
            preview_color("#4F378B"),
            preview_color("#E8DEF8"),
            preview_color("#FFFBFE"),
        ), 4, "centro"),

        espacio(4),
        fila_con_gap((
            preview_color("#9C27B0"),
            preview_color("#CE93D8"),
            preview_color("#F48FB1"),
            preview_color("#81D4FA"),
            preview_color("#A5D6A7"),
            preview_color("#FFE082"),
        ), 4, "centro"),
    )
}

# ═══════════════════════════════════════════════════════════════════
#  HELPER: Preview de color (cajita de color)
# ═══════════════════════════════════════════════════════════════════

funcion preview_color(hex: Texto) {
    retornar caja_fija(
        tarjeta_perfilada(etiqueta("  ")),
        32.0, 32.0
    )
}

# ═══════════════════════════════════════════════════════════════════
#  HELPER: Título de categoría
# ═══════════════════════════════════════════════════════════════════

funcion titulo_categoria(p: Entero) -> Texto {
    si (p == 0) { retornar "🔘 Botones" }
    sino {
        si (p == 1) { retornar "⌨️ Inputs y Formularios" }
        sino {
            si (p == 2) { retornar "🃏 Tarjetas y Listas" }
            sino {
                si (p == 3) { retornar "💬 Feedback" }
                sino {
                    si (p == 4) { retornar "🧭 Navegación" }
                    sino {
                        si (p == 5) { retornar "📊 Indicadores" }
                        sino {
                            si (p == 6) { retornar "👤 Avatares" }
                            sino {
                                si (p == 7) { retornar "📈 Gráficos" }
                                sino {
                                    si (p == 8) { retornar "🎭 Expressive" }
                                    sino {
                                        si (p == 9) { retornar "🏃 Motion" }
                                        sino { retornar "📐 Layout" }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

# ═══════════════════════════════════════════════════════════════════
#  HELPER: Selecciona la sección activa
# ═══════════════════════════════════════════════════════════════════

funcion seccion_activa(p: Entero, btn_disabled: Texto, btn_icon: Texto,
                        texto_val: Texto, slider_val: Texto, switch_val: Texto,
                        rating_val: Texto) {
    si (p == 0) { retornar seccion_botones(btn_disabled, btn_icon) }
    sino {
        si (p == 1) { retornar seccion_inputs(texto_val, slider_val, switch_val) }
        sino {
            si (p == 2) { retornar seccion_tarjetas() }
            sino {
                si (p == 3) { retornar seccion_feedback() }
                sino {
                    si (p == 4) { retornar seccion_navegacion() }
                    sino {
                        si (p == 5) { retornar seccion_indicadores(slider_val) }
                        sino {
                            si (p == 6) { retornar seccion_avatares() }
                            sino {
                                si (p == 7) { retornar seccion_graficos(rating_val) }
                                sino {
                                    si (p == 8) { retornar seccion_expressive() }
                                    sino {
                                        si (p == 9) { retornar seccion_motion() }
                                        sino { retornar seccion_layout() }
                                    }
                                }
                            }
                        }
                    }
                }
            }
        }
    }
}

# ═══════════════════════════════════════════════════════════════════
#  SECCIÓN 0: BOTONES
# ═══════════════════════════════════════════════════════════════════

funcion seccion_botones(disabled: Texto, con_icono: Texto) {
    retornar columna(
        texto_mediano("Variantes principales"),
        espacio(8),
        fila_con_gap((
            boton_relleno("Relleno", &accion_story),
            boton_tonal("Tonal", &accion_story),
            boton_perfilado("Perfilado", &accion_story),
            boton_texto("Texto", &accion_story),
            boton_elevado("Elevado", &accion_story),
        ), 8, "centro"),

        espacio(16),
        texto_mediano("FAB"),
        espacio(8),
        fila_con_gap((
            fab_pequeño("➕", &accion_story),
            fab("➕", &accion_story),
            fab_grande("➕", &accion_story),
            fab_extendido("Crear", "➕", &accion_story),
        ), 8, "centro"),

        espacio(16),
        texto_mediano("Icon Buttons"),
        espacio(8),
        fila_con_gap((
            boton_icono("⭐", &accion_story),
            boton_icono_relleno("⭐", &accion_story),
            boton_icono_tonal("⭐", &accion_story),
            boton_icono_perfilado("⭐", &accion_story),
        ), 8, "centro"),

        espacio(16),
        texto_mediano("Segmented Buttons"),
        espacio(8),
        segmentado(("Día", "Semana", "Mes"), 0, &accion_story),
        espacio(4),
        segmentado_multiple(("A", "B", "C"), (verdadero, falso, falso), &accion_story),

        espacio(16),
        texto_mediano("Chips"),
        espacio(8),
        flujo((
            subconjunto_asistente("Ayuda", &accion_story),
            subconjunto_filtro("Filtro", verdadero, &accion_story),
            subconjunto_entrada("Cerrar ✕", &accion_story),
            subconjunto_sugerencia("Sugerencia", &accion_story),
        ), 8),
    )
}

# ═══════════════════════════════════════════════════════════════════
#  SECCIÓN 1: INPUTS
# ═══════════════════════════════════════════════════════════════════

funcion seccion_inputs(texto: Texto, slider: Texto, sw: Texto) {
    retornar columna(
        texto_mediano("Campos de texto"),
        espacio(8),
        campo_texto(texto, "Texto (relleno)"),
        espacio(8),
        campo_perfilado(texto, "Texto (perfilado)"),
        espacio(8),
        campo_email(texto, "Correo electrónico"),
        espacio(8),
        campo_contraseña(texto, "Contraseña"),
        espacio(8),
        campo_numero(texto, "Edad", 0, 150),

        espacio(16),
        texto_mediano("Controles"),
        espacio(8),
        interruptor("Interruptor", sw),
        espacio(8),
        deslizante(slider, 0, 100),

        espacio(16),
        texto_mediano("Fecha, Hora y Color"),
        espacio(8),
        fila_con_gap((
            selector_fecha("2025-01-15"),
            selector_hora("14:30"),
            selector_color("#6750A4"),
        ), 16, "centro"),
    )
}

