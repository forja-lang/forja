/// Torres de Hanoi (clásico)
/// Conceptos: torres de Hanoi, recursividad clásica, problema matemático
/// Nivel: intermedio

importar "std/io"

funcion hanoi(n, origen, destino, auxiliar) {
    si (n == 1) {
        escribir("  Mover disco 1 de ${origen} a ${destino}")
        retornar
    }
    hanoi(n - 1, origen, auxiliar, destino)
    escribir("  Mover disco ${n} de ${origen} a ${destino}")
    hanoi(n - 1, auxiliar, destino, origen)
}

funcion contar_movimientos(n) -> Entero {
    // Cantidad de movimientos = 2^n - 1
    variable resultado = 1
    variable i = 1
    mientras (i <= n) {
        resultado = resultado * 2
        i = i + 1
    }
    retornar resultado - 1
}

funcion main() {
    escribir("=== Torres de Hanoi ===\n")

    variable discos = 3

    escribir("Resolviendo Torres de Hanoi con ${discos} discos:\n")
    escribir("Movimientos:")
    hanoi(discos, "A", "C", "B")

    variable total = contar_movimientos(discos)
    escribir("\nTotal de movimientos para ${discos} discos: ${total}")

    escribir("")
    escribir("Con 4 discos serían ${contar_movimientos(4)} movimientos.")
    escribir("Con 5 discos serían ${contar_movimientos(5)} movimientos.")

    escribir("")
    escribir("Las Torres de Hanoi es un problema clásico de recursividad.")
}

main()
