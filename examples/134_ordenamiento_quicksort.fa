/// Quicksort
/// Conceptos: ordenamiento rápido, dividir y conquistar, recursividad, pivote
/// Nivel: avanzado

importar "std/io"

funcion particion(arr, bajo, alto) -> Entero {
    variable pivote = arr[alto]
    variable i = bajo - 1
    variable j = bajo
    mientras (j < alto) {
        si (arr[j] <= pivote) {
            i = i + 1
            variable temp = arr[i]
            arr[i] = arr[j]
            arr[j] = temp
        }
        j = j + 1
    }
    variable temp = arr[i + 1]
    arr[i + 1] = arr[alto]
    arr[alto] = temp
    retornar i + 1
}

funcion quick_sort(arr, bajo, alto) {
    si (bajo < alto) {
        variable pi = particion(arr, bajo, alto)
        quick_sort(arr, bajo, pi - 1)
        quick_sort(arr, pi + 1, alto)
    }
}

funcion ordenar(arr) {
    quick_sort(arr, 0, longitud(arr) - 1)
    retornar arr
}

funcion main() {
    escribir("=== Quicksort ===\n")

    variable numeros = [38, 27, 43, 3, 9, 82, 10, 55, 1]
    escribir("Original: ${numeros}")

    numeros = ordenar(numeros)
    escribir("Ordenado: ${numeros}")

    escribir("")
    escribir("Quicksort usa dividir y conquistar con un pivote O(n log n) promedio.")
}

main()
