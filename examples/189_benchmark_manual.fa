/// Cómo Medir Rendimiento Manualmente
/// Conceptos: benchmarking, profiling, medición de tiempo, optimización
/// Nivel: avanzado

importar "std/io"

// El benchmarking manual permite medir el tiempo de ejecución de
// fragmentos de código para identificar cuellos de botella y
// verificar el impacto de las optimizaciones.

funcion medir_tiempo(funcion_a_medir, nombre, iteraciones) {
    escribir("  ⏱️ Midiendo: ${nombre} (${iteraciones} iteraciones)...")

    variable inicio = tiempo_actual()
    variable i = 0
    mientras (i < iteraciones) {
        funcion_a_medir()
        i = i + 1
    }
    variable fin = tiempo_actual()

    variable tiempo_total = fin - inicio
    variable tiempo_promedio = tiempo_total / iteraciones

    escribir("    Total: ${tiempo_total} ms")
    escribir("    Promedio: ${tiempo_promedio} ms/op")
    retornar tiempo_total
}

// Funciones para benchmarkear
funcion suma_for() {
    variable suma = 0
    variable i = 0
    mientras (i < 10000) {
        suma = suma + i
        i = i + 1
    }
}

funcion suma_formula() {
    variable suma = (9999 * 10000) / 2
}

funcion multiplicacion_lenta() {
    variable resultado = 1
    variable i = 1
    mientras (i <= 50) {
        resultado = resultado * i
        i = i + 1
    }
}

funcion crear_array_grande() {
    variable arr = []
    variable i = 0
    mientras (i < 1000) {
        arr[i] = i * 2
        i = i + 1
    }
}

clase BenchmarkSuite {
    resultados
    contador

    constructor() {
        este.resultados = []
        este.contador = 0
    }

    funcion agregar_prueba(nombre, iteraciones, funcion) {
        escribir("")
        escribir("Prueba #${este.contador + 1}: ${nombre}")
        variable inicio = tiempo_actual()
        variable i = 0
        mientras (i < iteraciones) {
            funcion()
            i = i + 1
        }
        variable fin = tiempo_actual()

        variable tiempo = fin - inicio
        este.resultados[este.contador] = tiempo
        este.contador = este.contador + 1

        escribir("  Total: ${tiempo} ms para ${iteraciones} iteraciones")
        retornar tiempo
    }

    funcion mostrar_resumen() {
        escribir("")
        escribir("=== RESUMEN DE BENCHMARK ===")
        variable i = 0
        mientras (i < este.contador) {
            escribir("  Prueba #${i + 1}: ${este.resultados[i]} ms")
            i = i + 1
        }

        // Encontrar el más rápido
        variable mas_rapido = este.resultados[0]
        variable idx_rapido = 0
        variable j = 1
        mientras (j < este.contador) {
            si (este.resultados[j] < mas_rapido) {
                mas_rapido = este.resultados[j]
                idx_rapido = j
            }
            j = j + 1
        }
        escribir("")
        escribir("  🏆 Prueba más rápida: #${idx_rapido + 1} (${mas_rapido} ms)")
    }
}

funcion main() {
    escribir("=== BENCHMARKING MANUAL ===\n")
    escribir("Cómo medir el rendimiento del código Forja.\n")

    escribir("--- Comparación de algoritmos ---")
    medir_tiempo(suma_for, "Suma con bucle for", 1000)
    medir_tiempo(suma_formula, "Suma con fórmula", 1000)

    escribir("")
    escribir("--- Suite de benchmarks ---")
    variable suite = nuevo BenchmarkSuite()

    suite.agregar_prueba("Multiplicación 1..50", 1000, multiplicacion_lenta)
    suite.agregar_prueba("Crear array 1000 elementos", 500, crear_array_grande)
    suite.agregar_prueba("Suma con bucle for", 500, suma_for)
    suite.agregar_prueba("Suma con fórmula", 500, suma_formula)

    suite.mostrar_resumen()

    escribir("")
    escribir("Consejos para benchmarks precisos:")
    escribir("  1. Ejecuta múltiples iteraciones y promedia")
    escribir("  2. Asegura que el sistema no esté bajo carga")
    escribir("  3. Mide solo el código que quieres evaluar")
    escribir("  4. Compara alternativas equivalentes")
    escribir("  5. Los resultados pueden variar entre ejecuciones")
}

main()
