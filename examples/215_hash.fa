/// HASH SHA-256 — Ejemplo de uso del módulo std/hash
///
/// Demuestra:
///   - Cálculo de SHA-256 de un texto
///   - Cálculo de SHA-256 de múltiples entradas
///   - El hash cambia drásticamente con diferentes inputs
///   - Manejo de errores con cadena vacía
///   - Verificación de integridad (mismo input → mismo hash)
///
/// Ejecutar:
///   cargo run --bin forja -- ejecutar examples\215_hash.fa

importar "std/hash"
importar "std/resultado"

funcion probar_sha256_basico() {
    escribir_linea("═══ SHA-256 BÁSICO ═══")

    # Texto simple
    variable texto1 = "Hola Mundo"
    variable hash1 = hash.sha256(texto1)
    si (tipo(hash1) == "resultado_ok") {
        escribir_linea("Texto: '" + texto1 + "'")
        escribir_linea("SHA-256: " + hash1.valor)
        escribir_linea("Longitud: " + longitud(hash1.valor) + " caracteres")
    }

    escribir_linea("")

    # Texto con caracteres especiales
    variable texto2 = "Forja™ — Lenguaje ★ educativo"
    variable hash2 = hash.sha256(texto2)
    si (tipo(hash2) == "resultado_ok") {
        escribir_linea("Texto: '" + texto2 + "'")
        escribir_linea("SHA-256: " + hash2.valor)
    }
}

funcion probar_consistencia() {
    escribir_linea("")
    escribir_linea("═══ CONSISTENCIA ═══")

    # Mismo input debe producir mismo hash
    variable texto = "Forja es genial"
    variable hash_a = hash.sha256(texto)
    variable hash_b = hash.sha256(texto)

    si (tipo(hash_a) == "resultado_ok" && tipo(hash_b) == "resultado_ok") {
        escribir_linea("Texto: '" + texto + "'")
        escribir_linea("Hash A: " + hash_a.valor)
        escribir_linea("Hash B: " + hash_b.valor)
        variable son_iguales = (hash_a.valor == hash_b.valor)
        escribir_linea("¿Mismo hash? " + son_iguales + " (debe ser Verdadero)")
    }
}

funcion probar_diferentes_inputs() {
    escribir_linea("")
    escribir_linea("═══ DIFERENTES INPUTS → DIFERENTES HASHES ═══")

    # Inputs similares producen hashes completamente diferentes (efecto avalancha)
    variable inputs = [
        "hola",
        "Hola",       # mayúscula inicial
        "hola!",       # signo de exclamación
        "hola!",       # duplicado para probar consistencia
        "hola mundo",
        "hola  mundo"  # doble espacio
    ]

    variable i = 0
    mientras (i < longitud(inputs)) {
        variable resultado = hash.sha256(inputs[i])
        si (tipo(resultado) == "resultado_ok") {
            escribir_linea("SHA-256('" + inputs[i] + "') = " + resultado.valor)
        }
        i = i + 1
    }
}

funcion probar_error_vacio() {
    escribir_linea("")
    escribir_linea("═══ MANEJO DE ERRORES ═══")

    # Cadena vacía debe retornar error
    variable resultado = hash.sha256("")
    si (tipo(resultado) == "resultado_error") {
        escribir_linea("Error esperado al hashear cadena vacía:")
        escribir_linea("  mensaje: " + resultado.error.mensaje)
        escribir_linea("  código: " + resultado.error.codigo)
    }
}

funcion probar_hex_como_se_espera() {
    escribir_linea("")
    escribir_linea("═══ VERIFICACIÓN DE HASH CONOCIDO ═══")

    # SHA-256 de "abc" (conocido): 
    # ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad
    variable resultado = hash.sha256("abc")
    si (tipo(resultado) == "resultado_ok") {
        escribir_linea("SHA-256('abc') = " + resultado.valor)
        # Verificar que sea el valor esperado
        variable esperado = "ba7816bf8f01cfea414140de5dae2223b00361a396177a9cb410ff61f20015ad"
        escribir_linea("Esperado:       " + esperado)
        variable coincide = (resultado.valor == esperado)
        escribir_linea("¿Coincide? " + coincide + " (debe ser Verdadero)")
    }
}

funcion main() {
    escribir_linea("=== MÓDULO HASH SHA-256 ===")
    escribir_linea("")

    probar_sha256_basico()
    probar_consistencia()
    probar_diferentes_inputs()
    probar_error_vacio()
    probar_hex_como_se_espera()

    escribir_linea("")
    escribir_linea("=== ¡Todas las pruebas completadas! ===")
}
