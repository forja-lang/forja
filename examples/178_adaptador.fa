/// Patrón Adapter con Rasgos
/// Conceptos: adapter, rasgos, compatibilidad, interfaces, wrappers
/// Nivel: avanzado

importar "std/io"

// El patrón Adapter permite que clases con interfaces incompatibles
// trabajen juntas, actuando como un wrapper entre ellas.

// Sistema antiguo (API legacy)
clase SistemaTemperaturaFahrenheit {
    constructor() {}

    funcion obtener_temperatura_f() -> Entero {
        retornar 98  // 98°F ≈ 36.7°C
    }

    funcion configurar_temp_f(temp_f) {
        escribir("  🌡️ Sistema legacy: temperatura ajustada a ${temp_f}°F")
    }
}

// Interfaz moderna que queremos usar
rasgo SistemaTemperatura {
    funcion obtener_temperatura_c() -> Entero
    funcion configurar_temp_c(temp_c)
    funcion obtener_unidad() -> Texto
}

// Adaptador: convierte Fahrenheit a Celsius
clase AdaptadorFahrenheitCelsius {
    sistema_legacy

    constructor() {
        este.sistema_legacy = nulo
    }

    funcion init(sistema) {
        este.sistema_legacy = sistema
    }
}

implementa SistemaTemperatura para AdaptadorFahrenheitCelsius {
    funcion obtener_temperatura_c() -> Entero {
        variable temp_f = este.sistema_legacy.obtener_temperatura_f()
        // Fórmula: (°F - 32) × 5/9 = °C
        variable temp_c = (temp_f - 32) * 5 / 9
        retornar temp_c
    }

    funcion configurar_temp_c(temp_c) {
        // Fórmula: °C × 9/5 + 32 = °F
        variable temp_f = (temp_c * 9 / 5) + 32
        este.sistema_legacy.configurar_temp_f(temp_f)
    }

    funcion obtener_unidad() -> Texto {
        retornar "°C"
    }
}

// Otro sistema legacy: pulgadas vs centímetros
clase SistemaLongitudPulgadas {
    constructor() {}

    funcion obtener_longitud_pulgadas() -> Entero {
        retornar 12  // 12 pulgadas = 30.48 cm
    }
}

rasgo SistemaLongitud {
    funcion obtener_longitud_cm() -> Entero
    funcion obtener_unidad_long() -> Texto
}

clase AdaptadorPulgadasCm {
    sistema_legacy

    constructor() {
        este.sistema_legacy = nulo
    }

    funcion init(sistema) {
        este.sistema_legacy = sistema
    }
}

implementa SistemaLongitud para AdaptadorPulgadasCm {
    funcion obtener_longitud_cm() -> Entero {
        variable pulgadas = este.sistema_legacy.obtener_longitud_pulgadas()
        // 1 pulgada = 2.54 cm
        variable cm = pulgadas * 254 / 100
        retornar cm
    }

    funcion obtener_unidad_long() -> Texto {
        retornar "cm"
    }
}

funcion main() {
    escribir("=== PATRÓN ADAPTER ===\n")
    escribir("Convierte interfaces incompatibles mediante un adaptador.\n")

    escribir("--- Adaptador de Temperatura ---")
    variable sistema_old = nuevo SistemaTemperaturaFahrenheit()
    variable adaptador_temp = nuevo AdaptadorFahrenheitCelsius()
    adaptador_temp.init(sistema_old)

    variable temp_actual = adaptador_temp.obtener_temperatura_c()
    escribir("  Temperatura actual: ${temp_actual}${adaptador_temp.obtener_unidad()}")

    escribir("  Configurando a 25°C...")
    adaptador_temp.configurar_temp_c(25)

    escribir("")
    escribir("--- Adaptador de Longitud ---")
    variable sistema_pulgadas = nuevo SistemaLongitudPulgadas()
    variable adaptador_long = nuevo AdaptadorPulgadasCm()
    adaptador_long.init(sistema_pulgadas)

    variable largo_cm = adaptador_long.obtener_longitud_cm()
    escribir("  Longitud: ${largo_cm} ${adaptador_long.obtener_unidad_long()}")

    escribir("")
    escribir("El patrón Adapter es útil para:")
    escribir("  • Integrar APIs de terceros con interfaces diferentes")
    escribir("  • Hacer compatible código legacy con sistemas modernos")
    escribir("  • Unificar múltiples implementaciones bajo una interfaz común")
    escribir("  • Migrar sistemas gradualmente sin romper el código existente")
}

main()
