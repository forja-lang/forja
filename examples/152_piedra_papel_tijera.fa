/// Juego: Piedra, Papel o Tijera
/// Conceptos: entrada/salida, enumeraciones (match), condicionales, aleatoriedad
/// Nivel: básico

importar "std/io"

// Implementación del clásico juego Piedra, Papel o Tijera.
// El jugador se enfrenta a la computadora en duels de 3 rondas.

tipo Mano = Piedra | Papel | Tijera

funcion manos_a_texto(m) -> Texto {
    coincidir (m) {
        caso Piedra -> { retornar "🪨 Piedra" }
        caso Papel -> { retornar "📄 Papel" }
        caso Tijera -> { retornar "✂️ Tijera" }
    }
}

funcion generar_jugada_computadora() -> Mano {
    variable t = tiempo_actual()
    variable r = t % 3
    si (r == 0) { retornar Piedra }
    si (r == 1) { retornar Papel }
    retornar Tijera
}

funcion leer_jugada_usuario() -> Mano {
    escribir("Elige: (1) Piedra, (2) Papel, (3) Tijera")
    variable op = pedir_numero("Opción: ")
    mientras (op < 1 || op > 3) {
        escribir("Opción inválida. Intenta de nuevo.")
        op = pedir_numero("Opción: ")
    }
    si (op == 1) { retornar Piedra }
    si (op == 2) { retornar Papel }
    retornar Tijera
}

funcion determinar_ganador(jugador, computadora) -> Texto {
    si (jugador == computadora) {
        retornar "Empate"
    }
    coincidir (jugador) {
        caso Piedra -> {
            si (computadora == Tijera) { retornar "Ganaste" }
        }
        caso Papel -> {
            si (computadora == Piedra) { retornar "Ganaste" }
        }
        caso Tijera -> {
            si (computadora == Papel) { retornar "Ganaste" }
        }
    }
    retornar "Perdiste"
}

funcion main() {
    escribir("=== PIEDRA, PAPEL O TIJERA ===\n")
    escribir("El primero en ganar 2 rondas gana el juego!\n")

    variable puntos_jugador = 0
    variable puntos_pc = 0
    constante META = 2

    mientras (puntos_jugador < META && puntos_pc < META) {
        escribir("\n--- Ronda ---")
        escribir("Marcador: Tú ${puntos_jugador} - ${puntos_pc} PC\n")

        variable jugador = leer_jugada_usuario()
        variable computadora = generar_jugada_computadora()

        escribir("")
        escribir("Tú sacaste: ${manos_a_texto(jugador)}")
        escribir("PC sacó:    ${manos_a_texto(computadora)}")

        variable resultado = determinar_ganador(jugador, computadora)
        escribir("  → ${resultado}")

        si (resultado == "Ganaste") {
            puntos_jugador = puntos_jugador + 1
        }
        si (resultado == "Perdiste") {
            puntos_pc = puntos_pc + 1
        }
    }

    escribir("")
    si (puntos_jugador > puntos_pc) {
        escribir("🎉 ¡FELICIDADES! Ganaste el juego ${puntos_jugador} a ${puntos_pc}!")
    } sino {
        escribir("😔 La computadora ganó ${puntos_pc} a ${puntos_jugador}. Mejor suerte la próxima!")
    }
}

main()
