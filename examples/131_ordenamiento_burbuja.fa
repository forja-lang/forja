/// Bubble sort
/// Conceptos: ordenamiento burbuja, algoritmo clásico, arrays, intercambio
/// Nivel: básico

importar "std/io"

funcion burbuja(arr) {
    variable n = longitud(arr)
    variable i = 0
    mientras (i < n - 1) {
        variable j = 0
        mientras (j < n - i - 1) {
            si (arr[j] > arr[j + 1]) {
                variable temp = arr[j]
                arr[j] = arr[j + 1]
                arr[j + 1] = temp
            }
            j = j + 1
        }
        i = i + 1
    }
    retornar arr
}

funcion main() {
    escribir("=== Bubble Sort ===\n")

    variable numeros = [64, 34, 25, 12, 22, 11, 90]
    escribir("Original: ${numeros}")

    numeros = burbuja(numeros)
    escribir("Ordenado: ${numeros}")

    escribir("")
    escribir("Bubble sort compara pares adyacentes y los intercambia si están desordenados.")
}

main()
