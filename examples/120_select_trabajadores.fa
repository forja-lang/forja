/// Patrón worker pool con select
/// Conceptos: seleccionar, worker pool, tareas concurrentes, balanceo de carga
/// Nivel: avanzado

importar "std/io"

// Patrón worker pool: múltiples trabajadores compiten por tareas

funcion trabajador(id, rx_tareas, tx_resultados) {
    variable activo = true
    mientras (activo) {
        seleccionar {
            caso rx_tareas -> tarea -> {
                variable resultado = tarea * 2
                escribir("  Trabajador ${id}: procesó ${tarea} → ${resultado}")
                tx_resultados.enviar(resultado)
            }
            otro -> {
                // Si no hay tareas, el trabajador descansa
                activo = false
            }
        }
    }
    escribir("  Trabajador ${id}: terminó")
    retornar 0
}

funcion main() {
    escribir("=== Patrón Worker Pool con Select ===\n")

    variable tx_tareas, rx_tareas = canal()
    variable tx_res, rx_res = canal()

    // Lanzar 3 trabajadores
    variable w1 = hilo { trabajador(1, rx_tareas, tx_res) }
    variable w2 = hilo { trabajador(2, rx_tareas, tx_res) }
    variable w3 = hilo { trabajador(3, rx_tareas, tx_res) }

    // Enviar 6 tareas
    escribir("Enviando tareas...\n")
    variable tareas = [10, 20, 30, 40, 50, 60]
    variable i = 0
    mientras (i < longitud(tareas)) {
        tx_tareas.enviar(tareas[i])
        i = i + 1
    }

    // Dar tiempo para que terminen
    esperar(0.5)

    // Recoger resultados
    escribir("\nResultados:\n")
    variable j = 0
    mientras (j < 6) {
        seleccionar {
            caso rx_res -> resultado -> {
                escribir("  Resultado: ${resultado}")
            }
            otro -> {
                escribir("  No hay más resultados por ahora")
            }
        }
        j = j + 1
    }

    w1.unir()
    w2.unir()
    w3.unir()

    escribir("\nEl worker pool distribuye tareas entre múltiples trabajadores.")
}

main()
