/// Aproximación de Pi (Leibniz / Monte Carlo)
/// Conceptos: series infinitas, simulación Monte Carlo, convergencia, precisión
/// Nivel: intermedio

importar "std/io"

// Dos métodos para aproximar π:
// 1. Serie de Leibniz: π/4 = 1 - 1/3 + 1/5 - 1/7 + ...
// 2. Monte Carlo: puntos aleatorios dentro de un cuadrado

funcion aprox_pi_leibniz(terminos) -> Decimal {
    variable suma = 0.0
    variable i = 0
    mientras (i < terminos) {
        variable numerador = 1.0
        si (i % 2 == 1) {
            numerador = -1.0
        }
        variable denominador = 2.0 * i + 1.0
        suma = suma + numerador / denominador
        i = i + 1
    }
    retornar suma * 4.0
}

funcion aprox_pi_montecarlo(puntos) -> Decimal {
    variable dentro = 0
    variable i = 0
    mientras (i < puntos) {
        variable t = tiempo_actual() * (i + 1)
        variable x = ((t % 10000) + 10000) / 20000.0
        variable y = (((t * 7 + 13) % 10000) + 10000) / 20000.0
        variable distancia = x * x + y * y
        si (distancia <= 1.0) {
            dentro = dentro + 1
        }
        i = i + 1
    }
    si (puntos > 0) {
        retornar (4.0 * dentro) / puntos
    }
    retornar 0.0
}

funcion main() {
    escribir("=== APROXIMACIÓN DE PI ===\n")
    escribir("Valor real de PI ≈ 3.1415926535...\n")

    escribir("--- Método 1: Serie de Leibniz ---")
    variable terminos = [10, 100, 1000]
    variable i = 0
    mientras (i < longitud(terminos)) {
        variable n = terminos[i]
        variable aprox = aprox_pi_leibniz(n)
        variable error = aprox - 3.1415926535
        si (error < 0) { error = -error }
        escribir("  ${n} términos: π ≈ ${aprox}  (error: ${error})")
        i = i + 1
    }

    escribir("")
    escribir("--- Método 2: Monte Carlo ---")
    variable puntos = [100, 1000]
    variable j = 0
    mientras (j < longitud(puntos)) {
        variable n = puntos[j]
        variable aprox = aprox_pi_montecarlo(n)
        variable error = aprox - 3.1415926535
        si (error < 0) { error = -error }
        escribir("  ${n} puntos: π ≈ ${aprox}  (error: ${error})")
        j = j + 1
    }

    escribir("")
    escribir("La serie de Leibniz converge lentamente.")
    escribir("Monte Carlo da resultados aproximados que mejoran con más puntos.")
}

main()
