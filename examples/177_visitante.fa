/// Patrón Visitor con Match
/// Conceptos: visitor, match, separación de algoritmos y datos, type-safe
/// Nivel: avanzado

importar "std/io"

// El patrón Visitor permite definir nuevas operaciones sobre una
// estructura de objetos sin modificar las clases de esos objetos.
// Usamos `coincidir` (match) para lograr un comportamiento similar.

tipo Figura = Circulo(Entero) | Rectangulo(Entero, Entero) | Triangulo(Entero, Entero)

funcion calcular_area(figura) -> Entero {
    coincidir (figura) {
        caso Circulo(r) -> {
            retornar 3 * r * r  // π ≈ 3
        }
        caso Rectangulo(b, h) -> {
            retornar b * h
        }
        caso Triangulo(b, h) -> {
            retornar (b * h) / 2
        }
    }
}

funcion calcular_perimetro(figura) -> Entero {
    coincidir (figura) {
        caso Circulo(r) -> {
            retornar 2 * 3 * r  // 2πr ≈ 6r
        }
        caso Rectangulo(b, h) -> {
            retornar 2 * (b + h)
        }
        caso Triangulo(b, h) -> {
            // Triángulo rectángulo aproximado
            retornar b + h + raiz(b * b + h * h)
        }
    }
}

funcion describir(figura) -> Texto {
    coincidir (figura) {
        caso Circulo(r) -> {
            retornar "⭕ Círculo (radio=${r})"
        }
        caso Rectangulo(b, h) -> {
            retornar "📐 Rectángulo (${b}×${h})"
        }
        caso Triangulo(b, h) -> {
            retornar "🔺 Triángulo (base=${b}, altura=${h})"
        }
    }
}

funcion escalar(figura, factor) {
    coincidir (figura) {
        caso Circulo(r) -> {
            retornar Circulo(r * factor)
        }
        caso Rectangulo(b, h) -> {
            retornar Rectangulo(b * factor, h * factor)
        }
        caso Triangulo(b, h) -> {
            retornar Triangulo(b * factor, h * factor)
        }
    }
}

funcion a_json(figura) -> Texto {
    coincidir (figura) {
        caso Circulo(r) -> {
            retornar '{"tipo": "circulo", "radio": ${r}}'
        }
        caso Rectangulo(b, h) -> {
            retornar '{"tipo": "rectangulo", "base": ${b}, "altura": ${h}}'
        }
        caso Triangulo(b, h) -> {
            retornar '{"tipo": "triangulo", "base": ${b}, "altura": ${h}}'
        }
    }
}

funcion raiz(S) -> Decimal {
    si (S <= 0) { retornar 0 }
    variable x = S
    variable i = 0
    mientras (i < 20) {
        x = (x + S / x) / 2.0
        i = i + 1
    }
    retornar x
}

funcion main() {
    escribir("=== PATRÓN VISITOR ===")
    escribir("Operaciones separadas de la estructura de datos.\n")

    variable figuras = [
        Circulo(5),
        Rectangulo(4, 6),
        Triangulo(3, 8),
        Circulo(10),
        Rectangulo(7, 3)
    ]

    escribir("--- Visitante 1: Descripción ---")
    variable i = 0
    mientras (i < longitud(figuras)) {
        escribir("  ${describir(figuras[i])}")
        i = i + 1
    }

    escribir("")
    escribir("--- Visitante 2: Área ---")
    variable area_total = 0
    variable j = 0
    mientras (j < longitud(figuras)) {
        variable area = calcular_area(figuras[j])
        area_total = area_total + area
        escribir("  Área ${j + 1}: ${area}")
        j = j + 1
    }
    escribir("  Área total: ${area_total}")

    escribir("")
    escribir("--- Visitante 3: Perímetro ---")
    variable per_total = 0
    variable k = 0
    mientras (k < longitud(figuras)) {
        variable per = calcular_perimetro(figuras[k])
        per_total = per_total + per
        escribir("  Perímetro ${k + 1}: ${per}")
        k = k + 1
    }
    escribir("  Perímetro total: ${per_total}")

    escribir("")
    escribir("--- Visitante 4: Escalar (×2) ---")
    variable l = 0
    mientras (l < longitud(figuras)) {
        variable fig_escalada = escalar(figuras[l], 2)
        escribir("  ${describir(figuras[l])} → ${describir(fig_escalada)}")
        l = l + 1
    }

    escribir("")
    escribir("--- Visitante 5: JSON ---")
    variable m = 0
    mientras (m < longitud(figuras)) {
        escribir("  ${a_json(figuras[m])}")
        m = m + 1
    }

    escribir("")
    escribir("Con `match` podemos añadir nuevas operaciones (visitantes)")
    escribir("sin modificar las variantes originales del tipo.")
}

main()
