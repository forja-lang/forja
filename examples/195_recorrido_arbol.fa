/// DFS, BFS en Árbol Binario
/// Conceptos: árbol binario, DFS, BFS, recorridos, estructuras de datos
/// Nivel: avanzado

importar "std/io"

// Implementación de un árbol binario con recorridos:
// - DFS (Depth-First Search): preorden, inorden, postorden
// - BFS (Breadth-First Search): por niveles

clase NodoArbol {
    valor
    izquierdo
    derecho

    constructor() {
        este.valor = 0
        este.izquierdo = nulo
        este.derecho = nulo
    }

    funcion init(val) {
        este.valor = val
        este.izquierdo = nulo
        este.derecho = nulo
    }

    funcion es_hoja() -> Booleano {
        retornar este.izquierdo == nulo && este.derecho == nulo
    }
}

clase ArbolBinario {
    raiz

    constructor() {
        este.raiz = nulo
    }

    funcion insertar(valor) {
        variable nuevo = nuevo NodoArbol()
        nuevo.init(valor)

        si (este.raiz == nulo) {
            este.raiz = nuevo
            retornar
        }

        variable cola = []
        cola[0] = este.raiz
        variable idx = 0
        variable len = 1

        mientras (idx < len) {
            variable actual = cola[idx]
            idx = idx + 1

            si (actual.izquierdo == nulo) {
                actual.izquierdo = nuevo
                retornar
            } sino {
                cola[len] = actual.izquierdo
                len = len + 1
            }

            si (actual.derecho == nulo) {
                actual.derecho = nuevo
                retornar
            } sino {
                cola[len] = actual.derecho
                len = len + 1
            }
        }
    }

    // DFS - Preorden (raíz → izquierdo → derecho)
    funcion dfs_preorden(nodo) {
        si (nodo == nulo) { retornar }
        escribir("  ${nodo.valor} ", falso)
        este.dfs_preorden(nodo.izquierdo)
        este.dfs_preorden(nodo.derecho)
    }

    // DFS - Inorden (izquierdo → raíz → derecho)
    funcion dfs_inorden(nodo) {
        si (nodo == nulo) { retornar }
        este.dfs_inorden(nodo.izquierdo)
        escribir("  ${nodo.valor} ", falso)
        este.dfs_inorden(nodo.derecho)
    }

    // DFS - Postorden (izquierdo → derecho → raíz)
    funcion dfs_postorden(nodo) {
        si (nodo == nulo) { retornar }
        este.dfs_postorden(nodo.izquierdo)
        este.dfs_postorden(nodo.derecho)
        escribir("  ${nodo.valor} ", falso)
    }

    // BFS - por niveles
    funcion bfs() {
        si (este.raiz == nulo) { retornar }

        variable cola = []
        cola[0] = este.raiz
        variable idx = 0
        variable len = 1

        mientras (idx < len) {
            variable actual = cola[idx]
            idx = idx + 1
            escribir("  ${actual.valor} ", falso)

            si (actual.izquierdo != nulo) {
                cola[len] = actual.izquierdo
                len = len + 1
            }
            si (actual.derecho != nulo) {
                cola[len] = actual.derecho
                len = len + 1
            }
        }
    }

    funcion altura(nodo) -> Entero {
        si (nodo == nulo) { retornar 0 }
        variable alt_izq = este.altura(nodo.izquierdo)
        variable alt_der = este.altura(nodo.derecho)
        si (alt_izq > alt_der) {
            retornar alt_izq + 1
        }
        retornar alt_der + 1
    }

    funcion contar_nodos(nodo) -> Entero {
        si (nodo == nulo) { retornar 0 }
        retornar 1 + este.contar_nodos(nodo.izquierdo) + este.contar_nodos(nodo.derecho)
    }
}

funcion main() {
    escribir("=== RECORRIDO DE ÁRBOL BINARIO ===\n")
    escribir("DFS (profundidad) y BFS (amplitud).\n")

    variable arbol = nuevo ArbolBinario()

    // Construir árbol
    variable valores = [10, 5, 15, 3, 7, 12, 18, 1, 4, 6, 8]
    escribir("Insertando: ${valores}\n")

    variable i = 0
    mientras (i < longitud(valores)) {
        arbol.insertar(valores[i])
        i = i + 1
    }

    escribir("Árbol creado con ${arbol.contar_nodos(arbol.raiz)} nodos.")
    escribir("Altura del árbol: ${arbol.altura(arbol.raiz)}\n")

    escribir("DFS - Recorridos en profundidad:")
    escribir("  Preorden  (raíz → izq → der): ")
    arbol.dfs_preorden(arbol.raiz)
    escribir("")

    escribir("  Inorden   (izq → raíz → der): ")
    arbol.dfs_inorden(arbol.raiz)
    escribir("")
    escribir("  (Inorden en un BST da valores ordenados)")

    escribir("  Postorden (izq → der → raíz): ")
    arbol.dfs_postorden(arbol.raiz)
    escribir("")

    escribir("")
    escribir("BFS - Recorrido por niveles:")
    escribir("  BFS (amplitud): ")
    arbol.bfs()
    escribir("")

    escribir("")
    escribir("Comparación DFS vs BFS:")
    escribir("  • DFS usa pila (recursión) - profundiza primero")
    escribir("  • BFS usa cola - explora por niveles")
    escribir("  • DFS: mejor para árboles profundos")
    escribir("  • BFS: encuentra el camino más corto")
}

main()
