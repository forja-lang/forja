/// Cifrado César
/// Conceptos: criptografía, desplazamiento de caracteres, cifrado simétrico
/// Nivel: básico

importar "std/io"

// Implementación del cifrado César: desplaza cada letra del alfabeto
// un número fijo de posiciones. Uno de los métodos de cifrado más antiguos.

funcion cifrar_cesar(texto, desplazamiento) -> Texto {
    variable resultado = ""
    variable i = 0
    mientras (i < longitud(texto)) {
        variable c = texto[i]
        variable codigo = 0

        // Mayúsculas (A-Z: 65-90)
        si (c >= 'A' && c <= 'Z') {
            codigo = (c - 65 + desplazamiento) % 26
            si (codigo < 0) { codigo = codigo + 26 }
            resultado = resultado + caracter(65 + codigo)
        } sino {
            // Minúsculas (a-z: 97-122)
            si (c >= 'a' && c <= 'z') {
                codigo = (c - 97 + desplazamiento) % 26
                si (codigo < 0) { codigo = codigo + 26 }
                resultado = resultado + caracter(97 + codigo)
            } sino {
                // Otros caracteres se dejan igual
                resultado = resultado + c
            }
        }
        i = i + 1
    }
    retornar resultado
}

funcion descifrar_cesar(texto, desplazamiento) -> Texto {
    retornar cifrar_cesar(texto, -desplazamiento)
}

funcion cifrar_cesar_mejorado(texto, desplazamiento) -> Texto {
    // Versión que también cifra números
    variable resultado = ""
    variable i = 0
    mientras (i < longitud(texto)) {
        variable c = texto[i]

        si (c >= 'A' && c <= 'Z') {
            variable codigo = (c - 65 + desplazamiento) % 26
            si (codigo < 0) { codigo = codigo + 26 }
            resultado = resultado + caracter(65 + codigo)
        } sino {
            si (c >= 'a' && c <= 'z') {
                variable codigo = (c - 97 + desplazamiento) % 26
                si (codigo < 0) { codigo = codigo + 26 }
                resultado = resultado + caracter(97 + codigo)
            } sino {
                si (c >= '0' && c <= '9') {
                    variable codigo = (c - 48 + desplazamiento) % 10
                    si (codigo < 0) { codigo = codigo + 10 }
                    resultado = resultado + caracter(48 + codigo)
                } sino {
                    resultado = resultado + c
                }
            }
        }
        i = i + 1
    }
    retornar resultado
}

funcion fuerza_bruta_cesar(texto_cifrado) {
    escribir("  --- Ataque de fuerza bruta ---")
    variable i = 1
    mientras (i < 26) {
        variable intento = descifrar_cesar(texto_cifrado, i)
        escribir("  Desplazamiento ${i}: ${intento}")
        i = i + 1
    }
}

funcion main() {
    escribir("=== CIFRADO CÉSAR ===\n")

    escribir("--- Prueba básica ---")
    variable mensaje = "Hola Mundo Forja 2024"
    variable desplaz = 3
    escribir("  Original: ${mensaje}")
    escribir("  Desplazamiento: ${desplaz}")

    variable cifrado = cifrar_cesar(mensaje, desplaz)
    escribir("  Cifrado:  ${cifrado}")

    variable descifrado = descifrar_cesar(cifrado, desplaz)
    escribir("  Descifrado: ${descifrado}")

    escribir("")
    escribir("--- Cifrado mejorado (con números) ---")
    variable mensaje2 = "Secreto 123"
    variable cifrado2 = cifrar_cesar_mejorado(mensaje2, 5)
    variable descifrado2 = descifrar_cesar(cifrado2, 5)
    escribir("  Original:   ${mensaje2}")
    escribir("  Cifrado:    ${cifrado2}")
    escribir("  Descifrado: ${descifrado2}")

    escribir("")
    escribir("--- Probando diferentes desplazamientos ---")
    variable texto = "ABC"
    variable d = 1
    mientras (d <= 5) {
        variable c = cifrar_cesar(texto, d)
        escribir("  Cifrar '${texto}' con n=${d}: ${c}")
        d = d + 1
    }

    escribir("")
    variable cifrado_fuerza = cifrar_cesar("Mensaje secreto", 9)
    fuerza_bruta_cesar(cifrado_fuerza)

    escribir("")
    escribir("El cifrado César es un cifrado de sustitución simple.")
    escribir("Es fácil de romper con fuerza bruta (solo 25 desplazamientos).")
    escribir("¡No lo uses para información realmente sensible!")
}

main()
