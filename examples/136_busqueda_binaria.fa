/// Búsqueda binaria en array ordenado
/// Conceptos: búsqueda binaria, dividir y conquistar, arrays ordenados, eficiencia
/// Nivel: intermedio

importar "std/io"

funcion busqueda_binaria(arr, objetivo) -> Entero {
    variable izquierda = 0
    variable derecha = longitud(arr) - 1

    mientras (izquierda <= derecha) {
        variable medio = (izquierda + derecha) / 2

        si (arr[medio] == objetivo) {
            retornar medio
        }
        si (arr[medio] < objetivo) {
            izquierda = medio + 1
        } sino {
            derecha = medio - 1
        }
    }
    retornar -1  // no encontrado
}

funcion main() {
    escribir("=== Búsqueda Binaria ===\n")

    variable numeros = [2, 5, 8, 12, 16, 23, 38, 45, 56, 72]
    escribir("Array: ${numeros}")

    variable busquedas = [23, 2, 72, 99]
    variable i = 0
    mientras (i < longitud(busquedas)) {
        variable target = busquedas[i]
        variable pos = busqueda_binaria(numeros, target)
        si (pos >= 0) {
            escribir("  ${target} → encontrado en índice ${pos}")
        } sino {
            escribir("  ${target} → no encontrado")
        }
        i = i + 1
    }

    escribir("")
    escribir("Búsqueda binaria: O(log n), requiere array ordenado.")
}

main()
