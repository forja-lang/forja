// 🎓 Lección 16: Operadores lógicos
// and (&&), or (||), not (!)

variable x = 5
variable y = 10

// Y lógico (&&) - ambas deben ser verdadero
si (x > 0 && y > 0) {
    escribir("Ambos son positivos")
}

// O lógico (||) - al menos una debe ser verdadero
si (x > 0 || y < 0) {
    escribir("Al menos uno es positivo")
}

// NO lógico (!) - invierte el valor
variable activo = falso
si (!activo) {
    escribir("Está inactivo")
}

// Combinación
variable edad = 20
variable tienePermiso = verdadero
si (edad >= 18 && tienePermiso) {
    escribir("Puede ingresar")
}
