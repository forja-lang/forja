// Login App — GUI real con Forja + Xilem
// Formulario de login completo con validacion
//
// Este ejemplo integra:
//   - columna() para layout vertical
//   - entrada_texto() para captura de datos
//   - boton() con callback a funcion de validacion
//   - escribir() para labels y feedback
//   - AppState con variables del codigo Forja
//
// Ejecutar (con cargo): forja ejecutar examples/204_login_final.fa
// Ejecutar (nativa):    forja ejecutar --native examples/204_login_final.fa
//                        (requiere --features gui)

importar "gui"

// Funcion de validacion
funcion validar(u: Texto, p: Texto) -> Texto {
    si (u == "") { retornar "El usuario es obligatorio" }
    si (p == "") { retornar "La contrasena es obligatoria" }
    retornar "Bienvenido " + u
}

// Main con GUI
funcion main() {
    variable usuario = ""
    variable contrasena = ""
    variable resultado = ""
    
    columna(
        escribir("=================================="),
        escribir("      INICIAR SESION"),
        escribir("=================================="),
        escribir(""),
        escribir("Usuario:"),
        entrada_texto("Ingrese su usuario"),
        escribir(""),
        escribir("Contrasena:"),
        entrada_texto("Ingrese su contrasena"),
        escribir(""),
        boton("Ingresar", &validar),
        escribir(""),
        escribir(resultado),
        escribir(""),
        escribir("==================================")
    )
}
