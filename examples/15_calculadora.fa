// 🎓 Lección 15: Proyecto final — Calculadora
// Una calculadora que suma, resta, multiplica y divide.

funcion calcular(a, b, operacion) {
    si (operacion == "+") {
        retornar a + b
    }
    si (operacion == "-") {
        retornar a - b
    }
    si (operacion == "*") {
        retornar a * b
    }
    si (operacion == "/") {
        retornar a / b
    }
    retornar 0
}

escribir("Calculadora simple")
escribir(calcular(10, 5, "+"))  // 15
escribir(calcular(10, 5, "-"))  // 5
escribir(calcular(10, 5, "*"))  // 50
escribir(calcular(10, 5, "/"))  // 2
escribir("Fin!")
