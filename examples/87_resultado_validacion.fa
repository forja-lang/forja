/// Validación de datos con Resultado
/// Conceptos: validación, datos de entrada, errores descriptivos
/// Nivel: intermedio

importar "std/io"

// Usar Resultado para validar datos de entrada

funcion validar_edad(edad) -> Resultado<Entero, Texto> {
    si (edad < 0) {
        retornar Error("La edad no puede ser negativa")
    }
    si (edad > 150) {
        retornar Error("La edad parece irreal (> 150)")
    }
    si (edad < 18) {
        retornar Error("Debe ser mayor de edad (18+)")
    }
    retornar Ok(edad)
}

funcion validar_email(email) -> Resultado<Texto, Texto> {
    variable tiene_arroba = falso
    variable i = 0
    mientras (i < email.length()) {
        si (email[i] == '@') {
            tiene_arroba = verdadero
        }
        i = i + 1
    }
    si (no tiene_arroba) {
        retornar Error("El email debe contener @")
    }
    si (email.length() < 5) {
        retornar Error("El email es demasiado corto")
    }
    retornar Ok(email)
}

funcion validar_usuario(nombre, edad, email) {
    escribir("Validando usuario: ${nombre}")
    
    variable r_edad = validar_edad(edad)
    coincidir (r_edad) {
        caso Ok(e) -> {
            escribir("  ✅ Edad válida: ${e}")
        }
        caso Error(m) -> {
            escribir("  ❌ Edad: ${m}")
        }
    }
    
    variable r_email = validar_email(email)
    coincidir (r_email) {
        caso Ok(mail) -> {
            escribir("  ✅ Email válido: ${mail}")
        }
        caso Error(m) -> {
            escribir("  ❌ Email: ${m}")
        }
    }
}

funcion main() {
    escribir("=== Validación de Datos ===\n")
    
    validar_usuario("Ana", 25, "ana@email.com")
    escribir("")
    validar_usuario("Juan", -5, "invalido")
    escribir("")
    validar_usuario("Pedro", 200, "pedro@")
}

main()
