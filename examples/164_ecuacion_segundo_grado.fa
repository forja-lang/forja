/// Ecuación de Segundo Grado
/// Conceptos: álgebra, discriminante, raíces, números complejos, fórmula cuadrática
/// Nivel: básico

importar "std/io"

// Resuelve ecuaciones de la forma: ax² + bx + c = 0
// Usando la fórmula cuadrática: x = (-b ± √(b² - 4ac)) / 2a

funcion calcular_discriminante(a, b, c) -> Decimal {
    retornar b * b - 4 * a * c
}

funcion resolver_ecuacion(a, b, c) {
    si (a == 0) {
        si (b == 0) {
            si (c == 0) {
                escribir("  ∞ Solución: Todos los números son solución.")
            } sino {
                escribir("  ✗ Ecuación sin solución (${c} = 0 es falso).")
            }
        } sino {
            variable x = -c / b
            escribir("  Ecuación lineal: x = ${x}")
        }
        retornar
    }

    escribir("  Ecuación: ${a}x² + ${b}x + ${c} = 0")
    variable discriminante = calcular_discriminante(a, b, c)
    escribir("  Discriminante (Δ) = ${discriminante}")

    si (discriminante > 0) {
        // Dos raíces reales distintas
        variable sqrt_d = raiz_cuadrada(discriminante)
        variable x1 = (-b + sqrt_d) / (2 * a)
        variable x2 = (-b - sqrt_d) / (2 * a)
        escribir("  ✅ Dos raíces reales:")
        escribir("    x₁ = ${x1}")
        escribir("    x₂ = ${x2}")
    } sino {
        si (discriminante == 0) {
            // Una raíz real doble
            variable x = -b / (2 * a)
            escribir("  ✅ Una raíz real (doble):")
            escribir("    x = ${x}")
        } sino {
            // Dos raíces complejas
            variable sqrt_d = raiz_cuadrada(-discriminante)
            variable real = -b / (2 * a)
            variable imag = sqrt_d / (2 * a)
            escribir("  ✅ Dos raíces complejas:")
            escribir("    x₁ = ${real} + ${imag}i")
            escribir("    x₂ = ${real} - ${imag}i")
        }
    }
}

funcion raiz_cuadrada(S) -> Decimal {
    si (S < 0) {
        retornar -1  // Indicador de complejo
    }
    variable x = S
    si (S < 1) { x = 1.0 }
    variable i = 0
    mientras (i < 20) {
        x = (x + S / x) / 2.0
        i = i + 1
    }
    retornar x
}

funcion main() {
    escribir("=== ECUACIÓN DE SEGUNDO GRADO ===\n")
    escribir("Resuelve ax² + bx + c = 0\n")

    // Casos de prueba
    variable casos = [
        [1, -5, 6],    // x² - 5x + 6 = 0  → x=2, x=3
        [1, 2, 1],     // x² + 2x + 1 = 0  → x=-1 (doble)
        [1, 0, -4],    // x² - 4 = 0       → x=2, x=-2
        [2, 4, 2],     // 2x² + 4x + 2 = 0 → x=-1 (doble)
        [1, 1, 1],     // x² + x + 1 = 0   → raíces complejas
        [0, 2, 4],     // 2x + 4 = 0       → x=-2
        [0, 0, 5],     // 5 = 0            → sin solución
        [0, 0, 0]      // 0 = 0            → todos los números
    ]

    variable i = 0
    mientras (i < longitud(casos)) {
        variable caso = casos[i]
        variable a = caso[0]
        variable b = caso[1]
        variable c = caso[2]
        resolver_ecuacion(a, b, c)
        escribir("")
        i = i + 1
    }
}

main()
