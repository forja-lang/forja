// GUI Nativa — Demostración de Widgets
// Muestra: label, boton, text_input, progress_bar, slider, checkbox
// Ejecutar: forja ejecutar --native examples/207_gui_widgets.fa

importar "gui"

funcion main() {
    variable nombre = ""
    variable progreso = 50
    variable volumen = 50
    variable activo = verdadero
    variable saludo = ""
    
    columna(
        escribir("==========================="),
        escribir("    DEMO DE WIDGETS"),
        escribir("==========================="),
        escribir(""),
        escribir("Ingresa tu nombre:"),
        entrada_texto("nombre"),
        escribir(""),
        boton("Saludar", &saludar),
        escribir(saludo),
        escribir(""),
        escribir("Barra de progreso:"),
        barra_progreso(0.5),
        escribir(""),
        escribir("Casilla de verificacion:"),
        casilla("Acepto los terminos"),
        escribir(""),
        escribir("===========================")
    )
}

funcion saludar(n: Texto) -> Texto {
    retornar "Hola, " + n + "!"
}
