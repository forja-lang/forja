# Ejemplo: Tipo Exacto (BigDecimal)
# Demostración de precisión arbitraria

importar "std/matematica"

# Declaración básica
variable precio: Exacto = 19.99
escribir("Precio:")
escribir(precio)

# Operaciones aritméticas
variable cantidad = 3
variable total: Exacto = precio * cantidad
escribir("Total (3 unidades):")
escribir(total)

variable iva: Exacto = total * 0.21
escribir("IVA (21%):")
escribir(iva)

# Precisión con muchos decimales
variable pi_exacto: Exacto = 3.14159265358979323846
escribir("Pi exacto:")
escribir(pi_exacto)

# Resta de exactos
variable x: Exacto = 1.0
variable y: Exacto = 0.9
variable resta: Exacto = x - y
escribir("1.0 - 0.9 =")
escribir(resta)

# División
variable dividendo: Exacto = 10.0
variable divisor: Exacto = 3.0
variable cociente: Exacto = dividendo / divisor
escribir("10 / 3 =")
escribir(cociente)

# Uso de stdlib (abs)
variable num: Exacto = -42.5
variable abs_num: Exacto = abs(num)
escribir("Absoluto de -42.5:")
escribir(abs_num)

# Comparación de exactos
variable a: Exacto = 0.1
variable b: Exacto = 0.2
variable suma: Exacto = a + b
escribir("Exacto: 0.1 + 0.2 =")
escribir(suma)

# Mostrar que Exacto mantiene precisión
variable diff: Exacto = 1.0 - 0.9999999999
escribir("1.0 - 0.9999999999 =")
escribir(diff)

# --- Pruebas de las nuevas funciones de std/matematica ---

# exacto_desde_texto
variable desde_texto: Exacto = exacto_desde_texto("123.456")
escribir("exacto_desde_texto('123.456'):")
escribir(desde_texto)

variable desde_entero: Exacto = exacto_desde_texto("42")
escribir("exacto_desde_texto('42'):")
escribir(desde_entero)

variable desde_negativo: Exacto = exacto_desde_texto("-3.14")
escribir("exacto_desde_texto('-3.14'):")
escribir(desde_negativo)

# redondear_exacto
variable valor_redondear: Exacto = 123.4567
variable redondeado: Exacto = redondear_exacto(valor_redondear, 2)
escribir("redondear_exacto(123.4567, 2):")
escribir(redondeado)

variable redondeado_cero: Exacto = redondear_exacto(valor_redondear, 0)
escribir("redondear_exacto(123.4567, 0):")
escribir(redondeado_cero)

# exacto_pow
variable base_pow: Exacto = 2.0
variable exp_pow: Exacto = 3.0
variable pow_result: Exacto = exacto_pow(base_pow, exp_pow)
escribir("exacto_pow(2.0, 3.0):")
escribir(pow_result)

variable pow_result2: Exacto = exacto_pow(5.0, 0.0)
escribir("exacto_pow(5.0, 0.0):")
escribir(pow_result2)

variable pow_result3: Exacto = exacto_pow(3.0, 10.0)
escribir("exacto_pow(3.0, 10.0) = 59049:")
escribir(pow_result3)
