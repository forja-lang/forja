// 🎓 Lección 42: Trabajar con textos
// Concatenación y comparación de textos

variable nombre = "Forja"
variable saludo = "Hola, " + nombre + "!"
escribir(saludo)

// Comparación de textos
variable usuario = "admin"
variable clave = "admin"
si (usuario == clave) {
    escribir("Acceso concedido")
} sino {
    escribir("Acceso denegado")
}

// Longitud aproximada (contando caracteres)
variable texto = "Hola Mundo"
escribir("Texto: " + texto)
variable largoTexto = 10
escribir("El texto tiene aproximadamente " + largoTexto + " caracteres")
