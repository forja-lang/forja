# Ejemplo: Cliente HTTP Simple
# Uso: forja ejecutar examples/218_cliente_http.fa

importar "std/cliente_http"

funcion main() {
    imprimir("Probando cliente HTTP...")
    variable respuesta = get("http://httpbin.org/get")
    si (respuesta.exito) {
        imprimir("Exito! Codigo: " + a_texto(respuesta.codigo))
        imprimir("Cuerpo: " + respuesta.cuerpo[..100])
    } sino {
        imprimir("Error: " + respuesta.error)
    }
}

main()
