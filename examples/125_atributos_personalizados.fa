/// Atributos para configurar comportamiento
/// Conceptos: @atributos, anotaciones, configuración, metadatos
/// Nivel: intermedio

importar "std/io"

// Los atributos permiten adjuntar metadatos a funciones y tipos

/// @descripcion("Calcula el área de un rectángulo")
/// @param("base", "La base del rectángulo")
/// @param("altura", "La altura del rectángulo")
/// @retorna("El área calculada")
funcion area_rectangulo(base, altura) {
    retornar base * altura
}

/// @descripcion("Calcula el perímetro de un rectángulo")
/// @param("base", "La base del rectángulo")
/// @param("altura", "La altura del rectángulo")
/// @retorna("El perímetro calculado")
funcion perimetro_rectangulo(base, altura) {
    retornar 2 * (base + altura)
}

/// @autor("Equipo Forja")
/// @version("1.0.0")
/// @test
funcion prueba_area() {
    asegurar(area_rectangulo(5, 3) == 15)
    asegurar(area_rectangulo(0, 10) == 0)
}

/// @autor("Equipo Forja")
/// @version("1.0.0")
/// @test
funcion prueba_perimetro() {
    asegurar(perimetro_rectangulo(5, 3) == 16)
    asegurar(perimetro_rectangulo(10, 10) == 40)
}

funcion main() {
    escribir("=== Atributos personalizados ===\n")

    escribir("Usando funciones documentadas con @atributos:\n")

    variable base = 5
    variable altura = 3

    escribir("Rectángulo: ${base} x ${altura}")
    escribir("  Área: ${area_rectangulo(base, altura)}")
    escribir("  Perímetro: ${perimetro_rectangulo(base, altura)}")

    escribir("")
    escribir("Ejecutá 'forja test' para correr las pruebas.")

    escribir("")
    escribir("Los atributos permiten agregar metadatos y configurar comportamiento.")
}

main()
