/// Insertion sort
/// Conceptos: ordenamiento inserción, algoritmo clásico, arrays
/// Nivel: básico

importar "std/io"

funcion insercion(arr) {
    variable n = longitud(arr)
    variable i = 1
    mientras (i < n) {
        variable clave = arr[i]
        variable j = i - 1
        mientras (j >= 0 && arr[j] > clave) {
            arr[j + 1] = arr[j]
            j = j - 1
        }
        arr[j + 1] = clave
        i = i + 1
    }
    retornar arr
}

funcion main() {
    escribir("=== Insertion Sort ===\n")

    variable numeros = [29, 10, 14, 37, 13, 33, 48, 22]
    escribir("Original: ${numeros}")

    numeros = insercion(numeros)
    escribir("Ordenado: ${numeros}")

    escribir("")
    escribir("Insertion sort construye el array ordenado de a un elemento por vez.")
}

main()
