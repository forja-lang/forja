/// Tests con Resultado
/// Conceptos: @test, asegurar(), Resultado en pruebas unitarias
/// Nivel: avanzado

importar "std/io"

funcion dividir(a, b) -> Resultado<Entero, Texto> {
    si (b == 0) {
        retornar Error("No se puede dividir por cero")
    }
    retornar Ok(a / b)
}

funcion validar_edad(edad) -> Resultado<Entero, Texto> {
    si (edad < 0) {
        retornar Error("Edad negativa")
    }
    si (edad > 150) {
        retornar Error("Edad muy grande")
    }
    retornar Ok(edad)
}

funcion extraer_valor(r) -> Entero {
    coincidir (r) {
        caso Ok(v) -> {
            retornar v
        }
        caso Error(m) -> {
            retornar -1
        }
    }
}

@test
funcion test_dividir_ok() {
    variable r = dividir(10, 2)
    coincidir (r) {
        caso Ok(v) -> {
            asegurar(v == 5)
        }
        caso Error(m) -> {
            asegurar(falso)
        }
    }
}

@test
funcion test_dividir_error() {
    variable r = dividir(10, 0)
    coincidir (r) {
        caso Ok(v) -> {
            asegurar(falso)
        }
        caso Error(m) -> {
            asegurar(m == "No se puede dividir por cero")
        }
    }
}

@test
funcion test_validar_edad_ok() {
    variable r = validar_edad(25)
    asegurar(extraer_valor(r) == 25)
}

@test
funcion test_validar_edad_negativa() {
    variable r = validar_edad(-1)
    coincidir (r) {
        caso Ok(v) -> asegurar(falso)
        caso Error(m) -> asegurar(m == "Edad negativa")
    }
}

@test
funcion test_extraer_valor() {
    asegurar(extraer_valor(Ok(42)) == 42)
    asegurar(extraer_valor(Error("fallo")) == -1)
}

escribir("Ejecutá 'forja test examples/90_resultado_test.fa' para correr los tests")
