/// Match básico sobre enum
/// Conceptos: coincidir, enum, variantes, coincidencia de patrones
/// Nivel: básico

importar "std/io"

// Definimos un enum (tipo algebraico) con variantes simples
tipo Direccion = Norte | Sur | Este | Oeste

funcion describir_dir(d) -> Texto {
    coincidir (d) {
        caso Norte -> { retornar "Hacia el norte 🧭" }
        caso Sur -> { retornar "Hacia el sur 🧭" }
        caso Este -> { retornar "Hacia el este 🧭" }
        caso Oeste -> { retornar "Hacia el oeste 🧭" }
    }
}

funcion main() {
    escribir("=== Match básico sobre enum ===\n")

    variable d = Norte
    escribir("Dirección: ${describir_dir(d)}")

    d = Sur
    escribir("Dirección: ${describir_dir(d)}")

    d = Este
    escribir("Dirección: ${describir_dir(d)}")

    d = Oeste
    escribir("Dirección: ${describir_dir(d)}")

    escribir("")
    escribir("Match permite ejecutar código diferente según la variante.")
}

main()
