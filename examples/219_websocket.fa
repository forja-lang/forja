importar "std/websocket"

funcion main() {
    imprimir("WebSocket: este ejemplo requiere un servidor WebSocket")
    imprimir("Usar: conectar('ws://echo.example.com/echo')")
    imprimir("Por ahora, solo probamos que el modulo se importa correctamente.")
}

main()
