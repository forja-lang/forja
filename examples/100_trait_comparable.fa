/// Trait para ordenar objetos
/// Conceptos: Comparable, ordenamiento, comparación de objetos
/// Nivel: avanzado

importar "std/io"

// Trait para comparar y ordenar objetos

trait Comparable {
    funcion comparar_con(otro) -> Entero
    // retorna: -1 si menor, 0 si igual, 1 si mayor
}

clase Persona {
    nombre
    edad
    
    constructor() {
        este.nombre = ""
        este.edad = 0
    }
}

implementa Comparable para Persona {
    funcion comparar_con(otro) -> Entero {
        si (este.edad < otro.edad) {
            retornar -1
        }
        si (este.edad > otro.edad) {
            retornar 1
        }
        retornar 0
    }
}

clase Producto {
    nombre
    precio
    
    constructor() {
        este.nombre = ""
        este.precio = 0
    }
}

implementa Comparable para Producto {
    funcion comparar_con(otro) -> Entero {
        si (este.precio < otro.precio) {
            retornar -1
        }
        si (este.precio > otro.precio) {
            retornar 1
        }
        retornar 0
    }
}

funcion ordenar_lista(lista) {
    variable n = longitud(lista)
    variable i = 0
    mientras (i < n) {
        variable j = 0
        mientras (j < n - i - 1) {
            si (lista[j].comparar_con(lista[j + 1]) > 0) {
                variable temp = lista[j]
                lista[j] = lista[j + 1]
                lista[j + 1] = temp
            }
            j = j + 1
        }
        i = i + 1
    }
    retornar lista
}

funcion main() {
    escribir("=== Trait Comparable ===\n")
    
    // Ordenar personas por edad
    variable p1 = nuevo Persona()
    p1.nombre = "Ana"
    p1.edad = 30
    
    variable p2 = nuevo Persona()
    p2.nombre = "Juan"
    p2.edad = 25
    
    variable p3 = nuevo Persona()
    p3.nombre = "Pedro"
    p3.edad = 35
    
    variable personas = [p1, p2, p3]
    personas = ordenar_lista(personas)
    
    escribir("Personas ordenadas por edad:")
    variable i = 0
    mientras (i < longitud(personas)) {
        escribir("  ${personas[i].nombre} (${personas[i].edad})")
        i = i + 1
    }
    
    escribir("")
    
    // Ordenar productos por precio
    variable prod1 = nuevo Producto()
    prod1.nombre = "Laptop"
    prod1.precio = 1200
    
    variable prod2 = nuevo Producto()
    prod2.nombre = "Mouse"
    prod2.precio = 25
    
    variable prod3 = nuevo Producto()
    prod3.nombre = "Monitor"
    prod3.precio = 300
    
    variable productos = [prod1, prod2, prod3]
    productos = ordenar_lista(productos)
    
    escribir("Productos ordenados por precio:")
    variable j = 0
    mientras (j < longitud(productos)) {
        escribir("  ${productos[j].nombre} ($${productos[j].precio})")
        j = j + 1
    }
}

main()
