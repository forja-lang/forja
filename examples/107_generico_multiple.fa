/// Múltiples parámetros de tipo genérico
/// Conceptos: <T, U, V>, combinación de tipos, flexibilidad
/// Nivel: avanzado

importar "std/io"

// Funciones y clases con múltiples parámetros de tipo

funcion crear_tripla<T, U, V>(a: T, b: U, c: V) -> Tripla<T, U, V> {
    retornar nuevo Tripla(a, b, c)
}

clase Tripla<T, U, V> {
    primero
    segundo
    tercero
    
    constructor(a: T, b: U, c: V) {
        este.primero = a
        este.segundo = b
        este.tercero = c
    }
    
    funcion mostrar() {
        escribir("(${este.primero}, ${este.segundo}, ${este.tercero})")
    }
}

// Combinar pares
funcion combinar_pares<T, U, V>(par1: Par<T, U>, par2: Par<U, V>) -> Tripla<T, U, V> {
    retornar nuevo Tripla(par1.primero, par1.segundo, par2.segundo)
}

clase Par<T, U> {
    primero
    segundo
    
    constructor(a: T, b: U) {
        este.primero = a
        este.segundo = b
    }
}

funcion main() {
    escribir("=== Múltiples Parámetros Genéricos ===\n")
    
    // Tripla con Entero, Texto, Booleano
    variable t1 = crear_tripla(1, "medio", verdadero)
    t1.mostrar()
    
    // Tripla con Texto, Decimal, Entero
    variable t2 = crear_tripla("nombre", 3.14, 42)
    t2.mostrar()
    
    escribir("")
    
    // Combinar pares de diferentes tipos
    variable p1 = nuevo Par(1, "uno")
    variable p2 = nuevo Par("uno", 1.0)
    variable combinada = combinar_pares(p1, p2)
    escribir("Combinación:")
    combinada.mostrar()
    
    escribir("")
    escribir("Los tipos T, U, V son independientes entre sí")
}

main()
