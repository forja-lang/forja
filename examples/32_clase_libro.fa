// 🎓 Lección 32: Clase Libro con constructor simple

clase Libro {
    titulo
    autor
    disponible

    constructor() {
        este.titulo = "Sin título"
        este.autor = "Sin autor"
        este.disponible = verdadero
    }
}

variable libro = nuevo Libro()
escribir(libro.titulo)
escribir(libro.autor)
escribir(libro.disponible)
