/// Interpolación anidada
/// Conceptos: ${"${x}"}, expresiones complejas, strings dentro de strings
/// Nivel: avanzado

importar "std/io"

// La interpolación permite strings anidados y combinaciones avanzadas

variable nombre = "Ana"
variable idioma = "español"

// String dentro de interpolación:
escribir("${nombre} dice: \"${"Hola mundo"}\"")

// Selección dinámica con operador ternario simulado:
variable edad = 17
escribir("${nombre} es ${edad >= 18 ? "mayor" : "menor"} de edad")

// Combinación de múltiples expresiones:
variable a = 5
variable b = 3
escribir("Operaciones: suma=${a + b}, resta=${a - b}, mul=${a * b}")

// Formato condicional:
variable puntaje = 85
variable nota = ""

// Construcción condicional directamente en el string:
escribir("Puntaje: ${puntaje} - ${puntaje >= 60 ? "Aprobado" : "Desaprobado"}")

// Sin anidación real de ${}, pero con lógica inline:
funcion maximo(x, y) {
    si (x > y) { retornar x }
    retornar y
}

escribir("El mayor entre ${a} y ${b} es ${maximo(a, b)}")
