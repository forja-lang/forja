/// Lista doblemente enlazada
/// Conceptos: lista doble, nodos con anterior/siguiente, recorrido bidireccional
/// Nivel: avanzado

importar "std/io"

clase NodoDoble {
    valor
    siguiente
    anterior

    constructor() {
        este.valor = 0
        este.siguiente = nulo
        este.anterior = nulo
    }
}

clase ListaDoble {
    cabeza
    cola
    tamano

    constructor() {
        este.cabeza = nulo
        este.cola = nulo
        este.tamano = 0
    }

    funcion insertar_frente(valor) {
        variable nuevo = nuevo NodoDoble()
        nuevo.valor = valor
        nuevo.siguiente = este.cabeza
        nuevo.anterior = nulo

        si (este.cabeza != nulo) {
            este.cabeza.anterior = nuevo
        }
        este.cabeza = nuevo
        si (este.cola == nulo) {
            este.cola = nuevo
        }
        este.tamano = este.tamano + 1
    }

    funcion insertar_final(valor) {
        variable nuevo = nuevo NodoDoble()
        nuevo.valor = valor
        nuevo.siguiente = nulo
        nuevo.anterior = este.cola

        si (este.cola != nulo) {
            este.cola.siguiente = nuevo
        }
        este.cola = nuevo
        si (este.cabeza == nulo) {
            este.cabeza = nuevo
        }
        este.tamano = este.tamano + 1
    }

    funcion mostrar_adelante() {
        variable elementos = []
        variable actual = este.cabeza
        mientras (actual != nulo) {
            elementos[longitud(elementos)] = actual.valor
            actual = actual.siguiente
        }
        escribir("  Adelante: ${elementos}")
    }

    funcion mostrar_atras() {
        variable elementos = []
        variable actual = este.cola
        mientras (actual != nulo) {
            elementos[longitud(elementos)] = actual.valor
            actual = actual.anterior
        }
        escribir("  Atrás:    ${elementos}")
    }
}

funcion main() {
    escribir("=== Lista Doblemente Enlazada ===\n")

    variable lista = nuevo ListaDoble()
    lista.insertar_final(10)
    lista.insertar_final(20)
    lista.insertar_final(30)
    lista.insertar_frente(5)
    lista.insertar_frente(1)

    escribir("Contenido:")
    lista.mostrar_adelante()
    lista.mostrar_atras()

    escribir("")
    escribir("Tamaño: ${lista.tamano}")
    escribir("La lista doble permite recorrer en ambas direcciones.")
}

main()
