/// Juego del Ahorcado
/// Conceptos: strings, arrays, bucles, entrada/salida, lógica de juego
/// Nivel: intermedio

importar "std/io"

// El clásico juego del ahorcado. El jugador debe adivinar una palabra
// letra por letra antes de quedarse sin intentos.

funcion elegir_palabra() -> Texto {
    variable palabras = ["FORJA", "PROGRAMACION", "ALGORITMO", "COMPUTADORA",
                         "DESARROLLO", "CODIGO", "VARIABLE", "FUNCION"]
    variable t = tiempo_actual()
    variable idx = t % longitud(palabras)
    retornar palabras[idx]
}

funcion mostrar_estado(palabra, adivinadas, incorrectas, intentos_restantes) {
    escribir("")
    escribir("Palabra: ", false)
    variable i = 0
    mientras (i < longitud(palabra)) {
        variable letra_actual = palabra[i]
        variable encontrada = falso
        variable j = 0
        mientras (j < longitud(adivinadas)) {
            si (adivinadas[j] == letra_actual) {
                encontrada = verdadero
            }
            j = j + 1
        }
        si (encontrada) {
            escribir(letra_actual, false)
        } sino {
            escribir("_ ", false)
        }
        i = i + 1
    }
    escribir("")
    escribir("Incorrectas: ${incorrectas}")
    escribir("Intentos restantes: ${intentos_restantes}")
}

funcion juego_terminado(palabra, adivinadas) -> Booleano {
    variable i = 0
    mientras (i < longitud(palabra)) {
        variable encontrada = falso
        variable j = 0
        mientras (j < longitud(adivinadas)) {
            si (adivinadas[j] == palabra[i]) {
                encontrada = verdadero
            }
            j = j + 1
        }
        si (!encontrada) {
            retornar falso
        }
        i = i + 1
    }
    retornar verdadero
}

funcion ya_adivinada(letra, adivinadas) -> Booleano {
    variable i = 0
    mientras (i < longitud(adivinadas)) {
        si (adivinadas[i] == letra) {
            retornar verdadero
        }
        i = i + 1
    }
    retornar falso
}

funcion main() {
    escribir("=== EL AHORCADO ===\n")
    escribir("Adivina la palabra secreta letra por letra.\n")

    variable palabra = elegir_palabra()
    variable adivinadas = []
    variable incorrectas = ""
    variable intentos_restantes = 6
    variable letra

    mientras (intentos_restantes > 0 && !juego_terminado(palabra, adivinadas)) {
        mostrar_estado(palabra, adivinadas, incorrectas, intentos_restantes)
        escribir("")
        variable entrada = pedir_texto("Ingresa una letra: ")
        letra = mayuscula(entrada[0])

        si (ya_adivinada(letra, adivinadas)) {
            escribir("  Ya adivinaste esa letra!")
            continuar
        }

        adivinadas[longitud(adivinadas)] = letra

        variable acierto = falso
        variable k = 0
        mientras (k < longitud(palabra)) {
            si (palabra[k] == letra) {
                acierto = verdadero
            }
            k = k + 1
        }

        si (acierto) {
            escribir("  ✅ ¡Bien! La letra '${letra}' está en la palabra.")
        } sino {
            incorrectas = incorrectas + letra + " "
            intentos_restantes = intentos_restantes - 1
            escribir("  ❌ La letra '${letra}' no está.")
        }
    }

    escribir("")
    si (juego_terminado(palabra, adivinadas)) {
        escribir("🎉 ¡GANASTE! La palabra era: ${palabra}")
    } sino {
        escribir("💀 ¡AHORCADO! La palabra era: ${palabra}")
    }
}

main()
