/// Implementar múltiples traits
/// Conceptos: múltiples implementa, varios traits por clase
/// Nivel: intermedio

importar "std/io"

trait Volador {
    funcion volar()
    funcion aterrizar() -> Texto
}

trait Navegante {
    funcion obtener_posicion() -> Texto
    function calcular_distancia(destino: Texto) -> Entero
}

trait Mantenible {
    funcion necesita_mantenimiento() -> Booleano
}

clase Avion {
    modelo
    horas_vuelo
    
    constructor() {
        este.modelo = "Desconocido"
        este.horas_vuelo = 0
    }
}

implementa Volador para Avion {
    funcion volar() {
        escribir("${este.modelo}: Volando...")
    }
    funcion aterrizar() -> Texto {
        retornar "${este.modelo}: Aterrizando..."
    }
}

implementa Navegante para Avion {
    funcion obtener_posicion() -> Texto {
        retornar "Lat: -34.60, Lon: -58.38"
    }
    function calcular_distancia(destino: Texto) -> Entero {
        retornar 1200
    }
}

implementa Mantenible para Avion {
    funcion necesita_mantenimiento() -> Booleano {
        retornar este.horas_vuelo > 1000
    }
}

funcion main() {
    escribir("=== Múltiples Traits ===\n")
    
    variable a = nuevo Avion()
    a.modelo = "Airbus A380"
    a.horas_vuelo = 1500
    
    a.volar()
    escribir("Posición: ${a.obtener_posicion()}")
    escribir("Distancia a Madrid: ${a.calcular_distancia("Madrid")} km")
    escribir("¿Necesita mantenimiento? ${a.necesita_mantenimiento()}")
    escribir(a.aterrizar())
}

main()
