/// Conversor de Unidades
/// Conceptos: menú interactivo, conversiones, precisión decimal
/// Nivel: básico

importar "std/io"

// Conversor de unidades interactivo que soporta múltiples categorías:
// longitud, masa, temperatura, volumen y velocidad.

funcion mostrar_menu_categoria() -> Entero {
    escribir("")
    escribir("=== CONVERSOR DE UNIDADES ===")
    escribir("1. Longitud (m ↔ km ↔ millas ↔ pies)")
    escribir("2. Masa (kg ↔ g ↔ lb ↔ oz)")
    escribir("3. Temperatura (°C ↔ °F ↔ K)")
    escribir("4. Volumen (L ↔ mL ↔ galón)")
    escribir("5. Velocidad (km/h ↔ m/s ↔ mph)")
    escribir("0. Salir")
    variable op = pedir_numero("\nElige categoría: ")
    retornar op
}

funcion convertir_longitud(valor, origen, destino) -> Decimal {
    // Convertir todo a metros como base
    variable en_metros = 0
    si (origen == 1) { en_metros = valor }           // m
    si (origen == 2) { en_metros = valor * 1000 }     // km → m
    si (origen == 3) { en_metros = valor * 1609.34 }  // millas → m
    si (origen == 4) { en_metros = valor * 0.3048 }   // pies → m

    si (destino == 1) { retornar en_metros }
    si (destino == 2) { retornar en_metros / 1000 }
    si (destino == 3) { retornar en_metros / 1609.34 }
    si (destino == 4) { retornar en_metros / 0.3048 }
    retornar 0
}

funcion convertir_masa(valor, origen, destino) -> Decimal {
    variable en_kg = 0
    si (origen == 1) { en_kg = valor }           // kg
    si (origen == 2) { en_kg = valor / 1000 }     // g → kg
    si (origen == 3) { en_kg = valor * 0.453592 } // lb → kg
    si (origen == 4) { en_kg = valor * 0.0283495 }// oz → kg

    si (destino == 1) { retornar en_kg }
    si (destino == 2) { retornar en_kg * 1000 }
    si (destino == 3) { retornar en_kg / 0.453592 }
    si (destino == 4) { retornar en_kg / 0.0283495 }
    retornar 0
}

funcion convertir_temperatura(valor, origen, destino) -> Decimal {
    // Convertir a Celsius como base
    variable en_c = 0
    si (origen == 1) { en_c = valor }              // °C
    si (origen == 2) { en_c = (valor - 32) * 5 / 9 } // °F → °C
    si (origen == 3) { en_c = valor - 273.15 }      // K → °C

    si (destino == 1) { retornar en_c }
    si (destino == 2) { retornar (en_c * 9 / 5) + 32 }
    si (destino == 3) { retornar en_c + 273.15 }
    retornar 0
}

funcion convertir_volumen(valor, origen, destino) -> Decimal {
    variable en_litros = 0
    si (origen == 1) { en_litros = valor }           // L
    si (origen == 2) { en_litros = valor / 1000 }     // mL → L
    si (origen == 3) { en_litros = valor * 3.78541 }  // galón → L

    si (destino == 1) { retornar en_litros }
    si (destino == 2) { retornar en_litros * 1000 }
    si (destino == 3) { retornar en_litros / 3.78541 }
    retornar 0
}

funcion convertir_velocidad(valor, origen, destino) -> Decimal {
    variable en_kmh = 0
    si (origen == 1) { en_kmh = valor }           // km/h
    si (origen == 2) { en_kmh = valor * 3.6 }     // m/s → km/h
    si (origen == 3) { en_kmh = valor * 1.60934 } // mph → km/h

    si (destino == 1) { retornar en_kmh }
    si (destino == 2) { retornar en_kmh / 3.6 }
    si (destino == 3) { retornar en_kmh / 1.60934 }
    retornar 0
}

funcion main() {
    variable opcion = -1
    mientras (opcion != 0) {
        opcion = mostrar_menu_categoria()

        si (opcion >= 1 && opcion <= 5) {
            variable nombre_unidad = ""
            variable submenu = ""
            si (opcion == 1) {
                submenu = "1: m, 2: km, 3: millas, 4: pies"
                nombre_unidad = "Longitud"
            }
            si (opcion == 2) {
                submenu = "1: kg, 2: g, 3: lb, 4: oz"
                nombre_unidad = "Masa"
            }
            si (opcion == 3) {
                submenu = "1: °C, 2: °F, 3: K"
                nombre_unidad = "Temperatura"
            }
            si (opcion == 4) {
                submenu = "1: L, 2: mL, 3: galón"
                nombre_unidad = "Volumen"
            }
            si (opcion == 5) {
                submenu = "1: km/h, 2: m/s, 3: mph"
                nombre_unidad = "Velocidad"
            }

            escribir("\n${nombre_unidad}")
            escribir("Opciones: ${submenu}")
            variable origen = pedir_numero("Unidad de origen: ")
            variable destino = pedir_numero("Unidad de destino: ")
            variable valor = pedir_numero("Valor a convertir: ")

            variable resultado = 0
            si (opcion == 1) { resultado = convertir_longitud(valor, origen, destino) }
            si (opcion == 2) { resultado = convertir_masa(valor, origen, destino) }
            si (opcion == 3) { resultado = convertir_temperatura(valor, origen, destino) }
            si (opcion == 4) { resultado = convertir_volumen(valor, origen, destino) }
            si (opcion == 5) { resultado = convertir_velocidad(valor, origen, destino) }

            escribir("  Resultado: ${resultado}")
        } sino {
            si (opcion != 0) {
                escribir("Opción inválida.")
            }
        }
    }
    escribir("¡Hasta luego!")
}

main()
