// 🎓 Lección 43: Suma de dígitos
// Sumamos los dígitos individuales de un número

funcion sumarDigitos(n: Entero) {
    variable num = n
    variable suma = 0
    
    mientras (num > 0) {
        variable digito = num - ((num / 10) * 10)
        suma = suma + digito
        num = num / 10
    }
    
    escribir("Suma de dígitos de " + n + " = " + suma)
}

sumarDigitos(123)   // 1 + 2 + 3 = 6
sumarDigitos(4567)  // 4 + 5 + 6 + 7 = 22
sumarDigitos(999)   // 9 + 9 + 9 = 27
