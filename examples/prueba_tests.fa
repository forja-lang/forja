// Tests de ejemplo para forja test
// Ejecutar con: forja test examples/prueba_tests.fa

funcion suma(a, b) {
    retornar a + b
}

funcion resta(a, b) {
    retornar a - b
}

@test
funcion test_suma() {
    asegurar(suma(2, 2) == 4)
    asegurar(suma(-1, 1) == 0)
    asegurar(suma(0, 0) == 0)
}

@test
funcion test_resta() {
    asegurar(resta(5, 3) == 2)
    asegurar(resta(10, 7) == 3)
}

@test
funcion test_multiplicacion() {
    asegurar(3 * 4 == 12)
    asegurar(0 * 5 == 0)
}
