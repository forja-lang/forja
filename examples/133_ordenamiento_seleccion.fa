/// Selection sort
/// Conceptos: ordenamiento selección, algoritmo clásico, arrays, mínimo
/// Nivel: básico

importar "std/io"

funcion seleccion(arr) {
    variable n = longitud(arr)
    variable i = 0
    mientras (i < n - 1) {
        variable min_idx = i
        variable j = i + 1
        mientras (j < n) {
            si (arr[j] < arr[min_idx]) {
                min_idx = j
            }
            j = j + 1
        }
        variable temp = arr[min_idx]
        arr[min_idx] = arr[i]
        arr[i] = temp
        i = i + 1
    }
    retornar arr
}

funcion main() {
    escribir("=== Selection Sort ===\n")

    variable numeros = [64, 25, 12, 22, 11, 90, 33]
    escribir("Original: ${numeros}")

    numeros = seleccion(numeros)
    escribir("Ordenado: ${numeros}")

    escribir("")
    escribir("Selection sort encuentra el mínimo y lo coloca en su posición.")
}

main()
