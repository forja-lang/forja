/// Ejemplo 216: Concurrencia de alto nivel
/// Conceptos: pool_workers, paralelo_for, mapa_paralelo, con_timeout, reintentar
/// Nivel: avanzado
///
/// Demostración de la API de patrones de concurrencia.
///
/// NOTA: La VM actual de Forja tiene limitaciones con:
///   - hilo/canal/seleccionar: no implementados (retornan nulo)
///   - empujar/asignación por índice: bugs que causan "Límite"
///
/// Este ejemplo demuestra la API correcta. Cuando la VM madure,
/// los patrones funcionarán en paralelo sin cambiar el código.
///
/// Para probar: target\release\forja.exe run examples/216_concurrencia.fa

importar "std/io"
importar "std/concurrencia"


funcion duplicar(valor) {
    retornar valor * 2
}

funcion cuadrado(valor) {
    retornar valor * valor
}

funcion identidad(valor) {
    retornar valor
}

funcion tarea_rapida() {
    retornar 999
}


funcion main() {
    escribir("═══════════════════════════════════════════")
    escribir("  Concurrencia de Alto Nivel")
    escribir("═══════════════════════════════════════════")

    # --------------------------------------------------
    # 1. Pool de Workers
    # --------------------------------------------------
    escribir("\n── 1. Pool de Workers (API) ──\n")

    variable pool = pool_workers(3, duplicar)
    variable tx_tareas = pool[0]
    variable rx_resultados = pool[1]
    escribir("Pool creado con 3 workers")
    escribir("  tx_tareas tipo: ${tipo(tx_tareas)}")
    escribir("  rx_resultados tipo: ${tipo(rx_resultados)}")
    escribir("")

    # --------------------------------------------------
    # 2. Uso directo (sin canales)
    # --------------------------------------------------
    escribir("── 2. Procesamiento directo ──\n")

    variable tareas = [10, 20, 30, 40, 50]
    escribir("Tareas: ")
    variable i = 0
    mientras (i < longitud(tareas)) {
        escribir("  [${i}] ${tareas[i]} → ${duplicar(tareas[i])}")
        i = i + 1
    }
    escribir("")

    # --------------------------------------------------
    # 3. Timeout
    # --------------------------------------------------
    escribir("── 3. Timeout ──\n")

    variable r1 = con_timeout(3000, tarea_rapida)
    escribir("Resultado tarea rápida (timeout 3s): ${r1}")
    si (r1.es_ok()) {
        escribir("  → Tarea completada a tiempo ✓")
    }
    escribir("")

    # --------------------------------------------------
    # FIN
    # --------------------------------------------------
    escribir("\n═══════════════════════════════════════════")
    escribir("  Fin del ejemplo 216")
    escribir("═══════════════════════════════════════════")
}

main()
