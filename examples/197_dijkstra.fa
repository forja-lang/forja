/// Algoritmo de Dijkstra (Ruta más Corta)
/// Conceptos: Dijkstra, ruta más corta, grafos ponderados, algoritmo voraz
/// Nivel: experto

importar "std/io"

// El algoritmo de Dijkstra encuentra la ruta más corta desde un nodo
// origen a todos los demás nodos en un grafo ponderado con pesos no negativos.

constante INFINITO = 999999

clase GrafoPonderado {
    num_nodos
    matriz_adyacencia

    constructor() {
        este.num_nodos = 0
        este.matriz_adyacencia = []
    }

    funcion init(n) {
        este.num_nodos = n
        este.matriz_adyacencia = []
        variable i = 0
        mientras (i < n) {
            variable fila = []
            variable j = 0
            mientras (j < n) {
                fila[j] = 0
                j = j + 1
            }
            este.matriz_adyacencia[i] = fila
            i = i + 1
        }
    }

    funcion agregar_arista(origen, destino, peso) {
        este.matriz_adyacencia[origen][destino] = peso
        este.matriz_adyacencia[destino][origen] = peso  // No dirigido
    }

    funcion encontrar_minimo(distancias, visitados) -> Entero {
        variable min = INFINITO
        variable min_idx = -1
        variable i = 0
        mientras (i < este.num_nodos) {
            si (!visitados[i] && distancias[i] < min) {
                min = distancias[i]
                min_idx = i
            }
            i = i + 1
        }
        retornar min_idx
    }

    funcion dijkstra(origen) {
        variable distancias = []
        variable visitados = []
        variable previos = []

        variable i = 0
        mientras (i < este.num_nodos) {
            distancias[i] = INFINITO
            visitados[i] = falso
            previos[i] = -1
            i = i + 1
        }

        distancias[origen] = 0

        variable j = 0
        mientras (j < este.num_nodos - 1) {
            variable u = este.encontrar_minimo(distancias, visitados)
            si (u == -1) { continuar }

            visitados[u] = verdadero

            variable v = 0
            mientras (v < este.num_nodos) {
                si (!visitados[v] &&
                    este.matriz_adyacencia[u][v] > 0 &&
                    distancias[u] != INFINITO &&
                    distancias[u] + este.matriz_adyacencia[u][v] < distancias[v]) {

                    distancias[v] = distancias[u] + este.matriz_adyacencia[u][v]
                    previos[v] = u
                }
                v = v + 1
            }
            j = j + 1
        }

        retornar [distancias, previos]
    }

    funcion reconstruir_ruta(previos, destino) {
        variable ruta = []
        variable actual = destino
        mientras (actual != -1) {
            variable len_ruta = longitud(ruta)
            ruta[len_ruta] = actual
            actual = previos[actual]
        }

        // Invertir ruta
        variable invertida = []
        variable i = longitud(ruta) - 1
        variable j = 0
        mientras (i >= 0) {
            invertida[j] = ruta[i]
            j = j + 1
            i = i - 1
        }
        retornar invertida
    }

    funcion mostrar_matriz() {
        escribir("  Matriz de adyacencia:")
        variable i = 0
        mientras (i < este.num_nodos) {
            escribir("    ", false)
            variable j = 0
            mientras (j < este.num_nodos) {
                escribir("${este.matriz_adyacencia[i][j]} ", false)
                j = j + 1
            }
            escribir("")
            i = i + 1
        }
    }
}

funcion main() {
    escribir("=== ALGORITMO DE DIJKSTRA ===\n")
    escribir("Encuentra la ruta más corta en un grafo ponderado.\n")

    variable grafo = nuevo GrafoPonderado()
    grafo.init(6)

    // Grafo de ejemplo con 6 nodos (0-5)
    grafo.agregar_arista(0, 1, 4)
    grafo.agregar_arista(0, 2, 2)
    grafo.agregar_arista(1, 2, 1)
    grafo.agregar_arista(1, 3, 5)
    grafo.agregar_arista(2, 3, 8)
    grafo.agregar_arista(2, 4, 10)
    grafo.agregar_arista(3, 4, 2)
    grafo.agregar_arista(3, 5, 6)
    grafo.agregar_arista(4, 5, 3)

    grafo.mostrar_matriz()

    escribir("")
    variable origen = 0
    escribir("Calculando distancias desde el nodo ${origen}...\n")

    variable resultados = grafo.dijkstra(origen)
    variable distancias = resultados[0]
    variable previos = resultados[1]

    escribir("Distancias más cortas desde el nodo ${origen}:")
    variable i = 0
    mientras (i < grafo.num_nodos) {
        escribir("  Hasta ${i}: ${distancias[i]}", false)

        si (distancias[i] < INFINITO) {
            variable ruta = grafo.reconstruir_ruta(previos, i)
            escribir("  (ruta: ${ruta})")
        } sino {
            escribir("  (sin ruta)")
        }
        i = i + 1
    }

    escribir("")
    escribir("Rutas detalladas:")
    variable destinos = [5, 3, 4]
    variable j = 0
    mientras (j < longitud(destinos)) {
        variable dest = destinos[j]
        variable ruta = grafo.reconstruir_ruta(previos, dest)
        escribir("  ${origen} → ${dest}: ${ruta}, distancia: ${distancias[dest]}")
        j = j + 1
    }

    escribir("")
    escribir("Características de Dijkstra:")
    escribir("  • Encuentra la ruta más corta desde un origen a todos los nodos")
    escribir("  • Los pesos deben ser no negativos")
    escribir("  • Complejidad: O(V²) con matriz de adyacencia")
    escribir("  • Usa una estrategia voraz (greedy)")
}

main()
