/// Obtener valor de retorno de un hilo
/// Conceptos: hilo, retornar, unir, valor de retorno, resultado de hilo
/// Nivel: intermedio

importar "std/io"

// hilo { ... retornar valor } devuelve un valor al unirse

funcion fib(n) -> Entero {
    si (n <= 1) {
        retornar n
    }
    retornar fib(n - 1) + fib(n - 2)
}

funcion factorial(n) -> Entero {
    si (n <= 1) {
        retornar 1
    }
    retornar n * factorial(n - 1)
}

funcion main() {
    escribir("=== Valor de retorno de hilos ===\n")

    // Hilo que calcula Fibonacci
    variable h_fib = hilo {
        variable resultado = fib(20)
        escribir("  🧵 Hilo fib: fibonacci(20) calculado")
        retornar resultado
    }

    // Hilo que calcula factorial
    variable h_fact = hilo {
        variable resultado = factorial(10)
        escribir("  🧵 Hilo fact: factorial(10) calculado")
        retornar resultado
    }

    // Hilo que suma números
    variable h_suma = hilo {
        variable total = 0
        variable i = 1
        mientras (i <= 1000) {
            total = total + i
            i = i + 1
        }
        escribir("  🧵 Hilo suma: suma de 1 a 1000 calculada")
        retornar total
    }

    escribir("Main: esperando resultados de los hilos...\n")

    variable fib_val = h_fib.unir()
    variable fact_val = h_fact.unir()
    variable suma_val = h_suma.unir()

    escribir("Resultados:")
    escribir("  Fibonacci(20)  = ${fib_val}")
    escribir("  Factorial(10)  = ${fact_val}")
    escribir("  Suma 1..1000   = ${suma_val}")

    escribir("\nCada hilo retorna un valor que se obtiene con .unir().")
}

main()
