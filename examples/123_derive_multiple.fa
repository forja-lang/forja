/// @derive(Mostrar, Igual, Debug) — múltiples derives
/// Conceptos: @derive, múltiples traits, combinación de atributos
/// Nivel: intermedio

importar "std/io"

// Se pueden combinar múltiples derives en un solo @derive

@derive(Mostrar, Igual)
clase Persona {
    nombre
    edad
    ciudad

    constructor() {
        este.nombre = ""
        este.edad = 0
        este.ciudad = ""
    }
}

@derive(Mostrar, Igual)
tipo Color = Rojo | Verde | Azul | Amarillo | Negro | Blanco

@derive(Mostrar, Igual)
clase Coche {
    marca
    modelo
    anio

    constructor() {
        este.marca = ""
        este.modelo = ""
        este.anio = 0
    }
}

funcion main() {
    escribir("=== @derive(Mostrar, Igual) múltiple ===\n")

    variable p1 = nuevo Persona()
    p1.nombre = "Carlos"
    p1.edad = 28
    p1.ciudad = "Buenos Aires"

    variable p2 = nuevo Persona()
    p2.nombre = "Carlos"
    p2.edad = 28
    p2.ciudad = "Buenos Aires"

    variable p3 = nuevo Persona()
    p3.nombre = "María"
    p3.edad = 32
    p3.ciudad = "Córdoba"

    escribir("p1 = ${p1}")
    escribir("p2 = ${p2}")
    escribir("p3 = ${p3}")
    escribir("p1 == p2? ${p1 == p2}")
    escribir("p1 == p3? ${p1 == p3}")

    escribir("")
    escribir("Colores:")
    escribir("  ${Rojo} == ${Rojo}: ${Rojo == Rojo}")
    escribir("  ${Verde} == ${Azul}: ${Verde == Azul}")

    escribir("")
    escribir("Múltiples derives: un atributo, múltiples comportamientos.")
}

main()
