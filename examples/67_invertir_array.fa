// 🎓 Lección 67: Acceder a elementos en orden inverso

variable numeros = [1, 2, 3, 4, 5]
escribir("Original: " + numeros)

// Mostrar en orden inverso usando variables
variable ultimo = numeros[4]
variable penultimo = numeros[3]
variable tercero = numeros[2]
variable segundo = numeros[1]
variable primero = numeros[0]

escribir("Invertido:")
escribir(ultimo)
escribir(penultimo)
escribir(tercero)
escribir(segundo)
escribir(primero)
