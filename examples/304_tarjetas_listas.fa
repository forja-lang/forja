# Ejemplo: Tarjetas, Listas y Tablas Material You
# Requiere: forja build --features gui

importar "gui"

funcion main() {
    variable sel_tarjeta = falso
    
    desplazable(
    columna(
        texto_grande("Tarjetas, Listas y Tablas"),
        espacio(16),
        
        texto_mediano("Tarjetas (Cards):"),
        espacio(8),
        fila_con_gap((
            tarjeta(columna((
                texto_mediano("Filled"),
                etiqueta("Contenido de tarjeta rellena"),
            ))),
            tarjeta_elevada(columna((
                texto_mediano("Elevated"),
                etiqueta("Con sombra sutil"),
            ))),
            tarjeta_perfilada(columna((
                texto_mediano("Outlined"),
                etiqueta("Con borde"),
            ))),
        ), 16, "inicio"),
        
        espacio(16),
        texto_mediano("Listas:"),
        espacio(8),
        lista_con_dividores((
            elemento_lista_doble(icono("📁"), "Documentos", "15 archivos", icono(">")),
            elemento_lista_doble(icono("🖼️"), "Imágenes", "42 archivos", icono(">")),
            elemento_lista_doble(icono("🎵"), "Música", "8 archivos", icono(">")),
        )),
        
        espacio(16),
        texto_mediano("Tabla de datos:"),
        espacio(8),
        tabla_ordenable(
            ("Nombre", "Edad", "Ciudad"),
            (
                ("Ana García", "28", "Madrid"),
                ("Carlos López", "35", "Barcelona"),
                ("María Díaz", "22", "Valencia"),
                ("Juan Pérez", "42", "Sevilla"),
            )
        ),
        
        espacio(16),
        boton_relleno("Interactuar", &accion)
    ))
}

funcion accion(valor: Texto) -> Texto {
    retornar "OK"
}
