// 🎓 Lección 201: Login con Interfaz Gráfica de Terminal (GUI)
// Una aplicación de login con estilo "GUI" usando arte ASCII.
// Muestra: clases, arrays, validación, bucles y entrada/salida.

// ─── CLASE USUARIO ───
// Almacena los datos de cada usuario del sistema
clase Usuario {
    usuario
    contrasena
    rol
    nombre_completo

    constructor() {
        este.usuario = ""
        este.contrasena = ""
        este.rol = ""
        este.nombre_completo = ""
    }
}

// ─── CLASE SISTEMA LOGIN ───
// Maneja la lógica de autenticación y el menú principal
clase SistemaLogin {
    usuarios
    sesion_activa
    usuario_actual

    constructor() {
        este.sesion_activa = falso
        este.usuario_actual = -1
        este.usuarios = []
    }

    funcion inicializar() {
        // Creamos usuarios de prueba
        // Admin
        variable admin = nuevo Usuario()
        admin.usuario = "admin"
        admin.contrasena = "1234"
        admin.rol = "Administrador"
        admin.nombre_completo = "Carlos Pérez"
        este.usuarios[longitud(este.usuarios)] = admin

        // Usuario normal 1
        variable user1 = nuevo Usuario()
        user1.usuario = "juan"
        user1.contrasena = "abcd"
        user1.rol = "Usuario"
        user1.nombre_completo = "Juan García"
        este.usuarios[longitud(este.usuarios)] = user1

        // Usuario normal 2
        variable user2 = nuevo Usuario()
        user2.usuario = "maria"
        user2.contrasena = "maria2024"
        user2.rol = "Usuario"
        user2.nombre_completo = "María López"
        este.usuarios[longitud(este.usuarios)] = user2
    }

    funcion autenticar(usuario, contrasena) -> Entero {
        para (variable i = 0; i < longitud(este.usuarios); i = i + 1) {
            variable u = este.usuarios[i]
            si (u.usuario == usuario && u.contrasena == contrasena) {
                este.sesion_activa = verdadero
                este.usuario_actual = i
                retornar i
            }
        }
        retornar -1
    }

    funcion obtener_usuario_actual() {
        retornar este.usuarios[este.usuario_actual]
    }
}

// ─── FUNCIONES DE INTERFAZ ───

// Limpia la pantalla mostrando líneas en blanco
funcion limpiar_pantalla() {
    repetir (30) {
        escribir("")
    }
}

// Muestra una línea horizontal decorativa
funcion linea_horizontal() {
    escribir("╔══════════════════════════════════════════════════╗")
}

// Muestra una línea horizontal con texto centrado
funcion linea_con_texto(texto) {
    escribir("║            " + texto + "            ║")
}

// Muestra una línea horizontal inferior
funcion linea_cierre() {
    escribir("╚══════════════════════════════════════════════════╝")
}

// Pantalla de bienvenida con decoración
funcion mostrar_bienvenida() {
    limpiar_pantalla()
    linea_horizontal()
    linea_con_texto("🏰  SISTEMA FORJA  🏰")
    linea_con_texto("")
    linea_con_texto("Bienvenido al Sistema de Login")
    linea_con_texto("Por favor, iniciá sesión para")
    linea_con_texto("acceder al sistema.")
    linea_con_texto("")
    linea_cierre()
    escribir("")
}

// Muestra el formulario de login
funcion mostrar_login() {
    linea_horizontal()
    linea_con_texto("🔐  INICIO DE SESIÓN  🔐")
    linea_con_texto("")
}

// Muestra el resultado del login
funcion mostrar_resultado(exito, nombre, rol) {
    limpiar_pantalla()
    linea_horizontal()
    si (exito) {
        linea_con_texto("✅  INGRESO EXITOSO  ✅")
    } sino {
        linea_con_texto("❌  ACCESO DENEGADO  ❌")
    }
    linea_con_texto("")
    si (exito) {
        linea_con_texto("Bienvenido, " + nombre)
        linea_con_texto("Rol: " + rol)
    } sino {
        linea_con_texto("Usuario o contraseña incorrectos")
        linea_con_texto("Por favor, intentá de nuevo.")
    }
    linea_con_texto("")
    linea_cierre()
    escribir("")
}

// Muestra el panel de control después del login exitoso
funcion mostrar_panel(nombre, rol) {
    limpiar_pantalla()
    linea_horizontal()
    linea_con_texto("📊  PANEL DE CONTROL  📊")
    linea_con_texto("")
    linea_con_texto("Usuario: " + nombre)
    linea_con_texto("Rol: " + rol)
    linea_con_texto("")
    linea_cierre()
    escribir("")
    linea_horizontal()
    linea_con_texto("📋  MENÚ DE OPCIONES  📋")
    linea_con_texto("")
    linea_con_texto("1. Ver perfil")
    linea_con_texto("2. Ver usuarios del sistema")
    linea_con_texto("3. Cambiar contraseña")
    linea_con_texto("4. Cerrar sesión")
    linea_con_texto("5. Salir del sistema")
    linea_con_texto("")
    linea_cierre()
    escribir("")
}

// Muestra el perfil del usuario
funcion mostrar_perfil(usuario, nombre, rol) {
    limpiar_pantalla()
    linea_horizontal()
    linea_con_texto("👤  PERFIL DE USUARIO  👤")
    linea_con_texto("")
    linea_con_texto("Usuario:     " + usuario)
    linea_con_texto("Nombre:      " + nombre)
    linea_con_texto("Rol:         " + rol)
    linea_con_texto("")
    linea_cierre()
    escribir("")
    escribir("Presioná Enter para volver al menú...")
    variable _ = leer()
}

// Muestra la lista de usuarios del sistema
funcion mostrar_usuarios(sistema) {
    limpiar_pantalla()
    linea_horizontal()
    linea_con_texto("👥  USUARIOS DEL SISTEMA  👥")
    linea_con_texto("")
    
    para (variable i = 0; i < longitud(sistema.usuarios); i = i + 1) {
        variable u = sistema.usuarios[i]
        variable info = (i + 1) + ". " + u.usuario + " (" + u.rol + ")"
        linea_con_texto(info)
    }
    
    linea_con_texto("")
    linea_cierre()
    escribir("")
    escribir("Presioná Enter para volver al menú...")
    variable _ = leer()
}

// ─── PROGRAMA PRINCIPAL ───

funcion main() {
    // Inicializar el sistema
    variable sistema = nuevo SistemaLogin()
    sistema.inicializar()

    // Variable de control del bucle principal
    variable salir = falso
    variable intentos_fallidos = 0
    constante MAX_INTENTOS = 3

    // ─── BUCLE PRINCIPAL DEL LOGIN ───
    mientras (!salir) {

        // --- PASO 1: PANTALLA DE BIENVENIDA ---
        mostrar_bienvenida()

        // --- PASO 2: FORMULARIO DE LOGIN ---
        mostrar_login()

        linea_con_texto("")
        linea_con_texto("Usuario:")
        linea_con_texto("")
        linea_cierre()

        escribir("")  // Espacio para el cursor
        variable usuario = leer()

        // Mostrar el formulario para contraseña
        limpiar_pantalla()
        mostrar_login()
        linea_con_texto("Usuario: " + usuario)
        linea_con_texto("Contraseña:")
        linea_con_texto("")
        linea_cierre()
        escribir("")
        variable contrasena = leer()

        // --- PASO 3: VALIDACIÓN ---
        variable resultado = sistema.autenticar(usuario, contrasena)

        si (resultado >= 0) {
            // Login exitoso
            variable u = sistema.obtener_usuario_actual()
            mostrar_resultado(verdadero, u.nombre_completo, u.rol)
            escribir("")
            escribir("Presioná Enter para continuar...")
            variable _ = leer()

            // --- PASO 4: PANEL DE CONTROL (bucle interno) ---
            variable sesion_activa = verdadero
            mientras (sesion_activa) {

                mostrar_panel(u.nombre_completo, u.rol)
                escribir("Seleccioná una opción (1-5):")
                variable opcion = leer()

                si (opcion == "1") {
                    mostrar_perfil(u.usuario, u.nombre_completo, u.rol)

                } sino {
                    si (opcion == "2") {
                        mostrar_usuarios(sistema)

                    } sino {
                        si (opcion == "3") {
                            limpiar_pantalla()
                            linea_horizontal()
                            linea_con_texto("🔑  CAMBIAR CONTRASEÑA  🔑")
                            linea_con_texto("")
                            linea_con_texto("Función no disponible en esta versión")
                            linea_con_texto("")
                            linea_cierre()
                            escribir("")
                            escribir("Presioná Enter para continuar...")
                            variable _ = leer()

                        } sino {
                            si (opcion == "4") {
                                sesion_activa = falso
                                sistema.sesion_activa = falso
                                sistema.usuario_actual = -1
                                limpiar_pantalla()
                                linea_horizontal()
                                linea_con_texto("👋  SESIÓN CERRADA  👋")
                                linea_con_texto("")
                                linea_con_texto("Has cerrado sesión correctamente.")
                                linea_con_texto("")
                                linea_cierre()
                                escribir("")
                                escribir("Presioná Enter para continuar...")
                                variable _ = leer()

                            } sino {
                                si (opcion == "5") {
                                    sesion_activa = falso
                                    salir = verdadero
                                    limpiar_pantalla()
                                    linea_horizontal()
                                    linea_con_texto("👋  HASTA LUEGO  👋")
                                    linea_con_texto("")
                                    linea_con_texto("Gracias por usar el Sistema Forja.")
                                    linea_con_texto("")
                                    linea_cierre()
                                    escribir("")

                                } sino {
                                    // Opción inválida
                                    limpiar_pantalla()
                                    linea_horizontal()
                                    linea_con_texto("⚠️  OPCIÓN INVÁLIDA  ⚠️")
                                    linea_con_texto("")
                                    linea_con_texto("Por favor, seleccioná una opción del 1 al 5")
                                    linea_con_texto("")
                                    linea_cierre()
                                    escribir("")
                                    escribir("Presioná Enter para continuar...")
                                    variable _ = leer()
                                }
                            }
                        }
                    }
                }
            }

        } sino {
            // Login fallido
            intentos_fallidos = intentos_fallidos + 1
            mostrar_resultado(falso, "", "")
            escribir("")
            escribir("Intentos fallidos: " + intentos_fallidos + " de " + MAX_INTENTOS)
            escribir("")

            si (intentos_fallidos >= MAX_INTENTOS) {
                limpiar_pantalla()
                linea_horizontal()
                linea_con_texto("🚫  SISTEMA BLOQUEADO  🚫")
                linea_con_texto("")
                linea_con_texto("Has superado el número máximo de")
                linea_con_texto("intentos permitidos.")
                linea_con_texto("")
                linea_con_texto("El sistema se cerrará por seguridad.")
                linea_con_texto("")
                linea_cierre()
                escribir("")
                salir = verdadero
            } sino {
                escribir("Presioná Enter para intentar de nuevo...")
                variable _ = leer()
            }
        }
    }

    escribir("")
    escribir("Presioná Enter para salir...")
    variable _ = leer()
}

// Punto de entrada
main()
