// 🎓 Lección 39: Factorial (con iteración)
// 5! = 5 * 4 * 3 * 2 * 1 = 120

variable n = 5
variable r = 1
variable i = 1

mientras (i <= n) {
    r = r * i
    i = i + 1
}
escribir("" + n + "! = " + r)

// 7! = 5040
n = 7
r = 1
i = 1
mientras (i <= n) {
    r = r * i
    i = i + 1
}
escribir("" + n + "! = " + r)
