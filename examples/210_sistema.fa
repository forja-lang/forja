// 🎓 Lección 210: Módulo Sistema — Información del SO y entorno
//
// Demostración del módulo std/sistema:
//   - Argumentos de línea de comandos
//   - Variables de entorno
//   - Directorio actual
//   - Timestamp en milisegundos
//   - Sistema operativo y versión

importar "std/io"
importar "std/sistema"

escribir("═══════════════════════════════════════")
escribir("  Módulo Sistema — Información del SO")
escribir("═══════════════════════════════════════")
escribir("")

// ─── 1. Argumentos de línea de comandos ──────
escribir("📋 Argumentos de línea de comandos:")
variable args = sistema.argumentos()
variable i = 0
mientras (i < longitud(args)) {
    escribir("  [" + a_texto(i) + "] " + args[i])
    i = i + 1
}
escribir("")

// ─── 2. Variable de entorno ──────────────────
escribir("🌐 Variables de entorno:")

// Leer PATH (funciona en Windows, Linux, macOS)
variable path_val = sistema.variable_entorno("PATH")
hacer_coincidir(path_val) {
    caso Some(v) -> {
        escribir("  PATH = " + v)
    }
    caso None -> {
        escribir("  PATH: no definida")
    }
}

// Leer USERNAME (Windows) o USER (Linux/Mac)
variable user = sistema.variable_entorno("USERNAME")
hacer_coincidir(user) {
    caso Some(v) -> {
        escribir("  USERNAME = " + v)
    }
    caso None -> {
        variable user2 = sistema.variable_entorno("USER")
        hacer_coincidir(user2) {
            caso Some(v) -> {
                escribir("  USER = " + v)
            }
            caso None -> {
                escribir("  USER: no definida")
            }
        }
    }
}

// Variable que no existe (demostración de None)
variable inexistente = sistema.variable_entorno("VARIABLE_QUE_NO_EXISTE_12345")
hacer_coincidir(inexistente) {
    caso Some(_) -> {
        escribir("  (inesperado) variable inexistente tiene valor")
    }
    caso None -> {
        escribir("  ✅ variable_entorno() retorna None para variables inexistentes")
    }
}
escribir("")

// ─── 3. Directorio actual ────────────────────
escribir("📁 Directorio de trabajo actual:")
variable dir_resultado = sistema.directorio_actual()
hacer_coincidir(dir_resultado) {
    caso Ok(d) -> {
        escribir("  " + d)
    }
    caso Error(e) -> {
        escribir("  Error: " + e.mensaje + " (código " + a_texto(e.codigo) + ")")
    }
}
escribir("")

// ─── 4. Timestamp en milisegundos ────────────
escribir("⏱️  Tiempo del sistema:")
variable t1 = sistema.tiempo_ms()
escribir("  Timestamp actual (ms): " + a_texto(t1))

// Medir cuánto tarda una operación simple
variable suma = 0
variable j = 0
mientras (j < 100000) {
    suma = suma + j
    j = j + 1
}
variable t2 = sistema.tiempo_ms()
variable delta = t2 - t1
escribir("  Tiempo para 100k iteraciones: " + a_texto(delta) + " ms")
escribir("")

// ─── 5. Sistema operativo y versión ──────────
escribir("💻 Información del entorno:")
escribir("  Sistema operativo: " + sistema.sistema_operativo())
escribir("  Versión de Forja:   " + sistema.version_forja())
escribir("")

escribir("═══════════════════════════════════════")
escribir("  Fin del ejemplo")
escribir("═══════════════════════════════════════")
