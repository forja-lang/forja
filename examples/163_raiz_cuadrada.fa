/// Raíz Cuadrada (Newton-Raphson)
/// Conceptos: método numérico, Newton-Raphson, iteración, convergencia cuadrática
/// Nivel: intermedio

importar "std/io"

// Implementación del método de Newton-Raphson para calcular
// raíces cuadradas sin usar funciones incorporadas.
// Fórmula: x_{n+1} = (x_n + S/x_n) / 2

funcion raiz_cuadrada_newton(S, tolerancia) -> Decimal {
    si (S == 0) {
        retornar 0
    }
    si (S < 0) {
        retornar -1  // Error: número negativo
    }

    // Estimación inicial
    variable x = S
    si (S < 1) {
        x = 1.0
    }

    variable iteraciones = 0
    variable max_iter = 100
    variable error = tolerancia + 1

    mientras (error > tolerancia && iteraciones < max_iter) {
        si (x == 0) { x = 0.001 }
        variable x_siguiente = (x + S / x) / 2.0
        error = x_siguiente - x
        si (error < 0) { error = -error }
        x = x_siguiente
        iteraciones = iteraciones + 1
    }

    escribir("  Convergió en ${iteraciones} iteraciones")
    retornar x
}

funcion raiz_cuadrada_babilonica(S, pasos) -> Decimal {
    // Método babilónico (versión más simple)
    variable x = S
    si (S < 1) { x = 1.0 }

    variable i = 0
    mientras (i < pasos) {
        si (x == 0) { x = 0.001 }
        x = (x + S / x) / 2.0
        i = i + 1
    }
    retornar x
}

funcion main() {
    escribir("=== RAÍZ CUADRADA (NEWTON-RAPHSON) ===\n")

    variable casos = [4, 9, 16, 25, 2, 3, 10]
    variable i = 0
    mientras (i < longitud(casos)) {
        variable S = casos[i]
        escribir("")
        escribir("Calculando √${S} ...")
        variable resultado = raiz_cuadrada_newton(S, 0.0001)
        variable resultado_bab = raiz_cuadrada_babilonica(S, 10)
        escribir("  Newton-Raphson: √${S} ≈ ${resultado}")
        escribir("  Babilónico:     √${S} ≈ ${resultado_bab}")

        // Verificación
        variable verificar = resultado * resultado
        si (verificar < 0) { verificar = -verificar }
        escribir("  Verificación: ${resultado}² = ${verificar}")
        i = i + 1
    }

    escribir("")
    escribir("El método de Newton-Raphson tiene convergencia cuadrática:")
    escribir("¡los dígitos correctos se duplican en cada iteración!")
}

main()
