// Bucles en Forja

// Bucle mientras
variable contador = 0
mientras (contador < 5) {
    escribir("Contador: " + contador)
    contador = contador + 1
}

// Bucle para
para (variable i = 0; i < 3; i = i + 1) {
    escribir("i = " + i)
}

// Bucle repetir
repetir (4) {
    escribir("Esto se repite 4 veces")
}
