/// Mini-Compilador en Forja
/// Conceptos: compilador, lexer, parser, AST, intérprete, auto-hospedaje
/// Nivel: experto

importar "std/io"

// Este demo implementa un mini-compilador en Forja que procesa
// un lenguaje de programación simple (MiniForja).
// Incluye: lexer, parser, AST y ejecutor.

// --- 1. LEXER: Divide el código en tokens ---

clase Token {
    tipo
    valor
    linea

    constructor() {
        este.tipo = ""
        este.valor = ""
        este.linea = 0
    }

    funcion init(t, v, l) {
        este.tipo = t
        este.valor = v
        este.linea = l
    }
}

clase Lexer {
    codigo
    posicion
    linea
    tokens

    constructor() {
        este.codigo = ""
        este.posicion = 0
        este.linea = 1
        este.tokens = []
    }

    funcion init(cod) {
        este.codigo = cod
        este.posicion = 0
        este.linea = 1
        este.tokens = []
        este.tokenizar()
    }

    funcion tokenizar() {
        mientras (este.posicion < longitud(este.codigo)) {
            variable c = este.codigo[este.posicion]

            si (c == ' ' || c == '\t') {
                este.posicion = este.posicion + 1
                continuar
            }

            si (c == '\n') {
                este.linea = este.linea + 1
                este.posicion = este.posicion + 1
                continuar
            }

            // Comentarios
            si (c == '/' && este.posicion + 1 < longitud(este.codigo) && este.codigo[este.posicion + 1] == '/') {
                mientras (este.posicion < longitud(este.codigo) && este.codigo[este.posicion] != '\n') {
                    este.posicion = este.posicion + 1
                }
                continuar
            }

            // Números
            si (c >= '0' && c <= '9') {
                variable num = ""
                mientras (este.posicion < longitud(este.codigo) && este.codigo[este.posicion] >= '0' && este.codigo[este.posicion] <= '9') {
                    num = num + este.codigo[este.posicion]
                    este.posicion = este.posicion + 1
                }
                variable idx = longitud(este.tokens)
                este.tokens[idx] = nuevo Token()
                este.tokens[idx].init("NUMERO", num, este.linea)
                continuar
            }

            // Identificadores y palabras clave
            si ((c >= 'a' && c <= 'z') || (c >= 'A' && c <= 'Z') || c == '_') {
                variable ident = ""
                mientras (este.posicion < longitud(este.codigo) &&
                        ((este.codigo[este.posicion] >= 'a' && este.codigo[este.posicion] <= 'z') ||
                         (este.codigo[este.posicion] >= 'A' && este.codigo[este.posicion] <= 'Z') ||
                         (este.codigo[este.posicion] >= '0' && este.codigo[este.posicion] <= '9') ||
                         este.codigo[este.posicion] == '_')) {
                    ident = ident + este.codigo[este.posicion]
                    este.posicion = este.posicion + 1
                }

                variable tipo = "IDENTIFICADOR"
                si (ident == "escribir" || ident == "variable" || ident == "si" ||
                    ident == "sino" || ident == "mientras" || ident == "funcion" ||
                    ident == "retornar") {
                    tipo = "PALABRA_CLAVE"
                }

                variable idx2 = longitud(este.tokens)
                este.tokens[idx2] = nuevo Token()
                este.tokens[idx2].init(tipo, ident, este.linea)
                continuar
            }

            // Símbolos
            variable simbolos = ["==", "!=", "<=", ">=", "+", "-", "*", "/",
                               "=", "(", ")", "{", "}", "<", ">", ",", ";"]
            variable encontrado = falso
            variable s = 0
            mientras (s < longitud(simbolos)) {
                variable sym = simbolos[s]
                si (longitud(sym) == 2) {
                    si (este.posicion + 1 < longitud(este.codigo) &&
                        este.codigo[este.posicion] == sym[0] &&
                        este.codigo[este.posicion + 1] == sym[1]) {
                        variable idx3 = longitud(este.tokens)
                        este.tokens[idx3] = nuevo Token()
                        este.tokens[idx3].init("OPERADOR", sym, este.linea)
                        este.posicion = este.posicion + 2
                        encontrado = verdadero
                    }
                } sino {
                    si (este.codigo[este.posicion] == sym[0]) {
                        variable idx4 = longitud(este.tokens)
                        este.tokens[idx4] = nuevo Token()
                        este.tokens[idx4].init("SIMBOLO", sym, este.linea)
                        este.posicion = este.posicion + 1
                        encontrado = verdadero
                    }
                }
                si (encontrado) { s = longitud(simbolos) }
                s = s + 1
            }

            si (!encontrado) {
                escribir("  ⚠️ Error léxico: carácter '${c}' en línea ${este.linea}")
                este.posicion = este.posicion + 1
            }
        }
    }

    funcion mostrar_tokens() {
        escribir("  Tokens generados:")
        variable i = 0
        mientras (i < longitud(este.tokens)) {
            variable t = este.tokens[i]
            escribir("    [${t.tipo}: '${t.valor}']")
            i = i + 1
        }
    }
}

// --- 2. EJECUTOR: Interpreta el programa ---

clase MiniEjecutor {
    variables

    constructor() {
        este.variables = []
    }

    funcion ejecutar(tokens) {
        escribir("  Ejecutando programa MiniForja...\n")
        variable i = 0
        mientras (i < longitud(tokens)) {
            variable t = tokens[i]

            // escribir(expresion)
            si (t.valor == "escribir") {
                i = i + 1  // saltar (
                i = i + 1
                variable valor = tokens[i].valor
                escribir("  > ${valor}")
                i = i + 1  // saltar )
            }

            // variable nombre = valor
            si (t.valor == "variable") {
                i = i + 1
                variable nombre = tokens[i].valor
                i = i + 2  // saltar =
                variable valor = tokens[i].valor
                // Almacenar variable
                variable idx = longitud(este.variables)
                este.variables[idx] = nombre + ":" + valor
                escribir("  📦 Variable '${nombre}' = ${valor}")
            }

            i = i + 1
        }
    }
}

funcion main() {
    escribir("=== FORJA DESDE FORJA (Mini-Compilador) ===\n")
    escribir("Un mini-compilador escrito en Forja que procesa MiniForja.\n")

    // Programa de ejemplo en MiniForja
    variable programa = "// Mini programa de ejemplo\n" +
                        "escribir(Hola desde MiniForja!)\n" +
                        "variable x = 42\n" +
                        "variable y = 10\n" +
                        "escribir(Fin del programa)"

    escribir("Código fuente:")
    escribir("----------------------------------------")
    escribir(programa)
    escribir("----------------------------------------\n")

    // Fase 1: Lexer
    escribir("--- Fase: Lexer ---")
    variable lexer = nuevo Lexer()
    lexer.init(programa)
    lexer.mostrar_tokens()

    // Fase 2: Ejecutor
    escribir("")
    escribir("--- Fase: Ejecutor ---")
    variable ejecutor = nuevo MiniEjecutor()
    ejecutor.ejecutar(lexer.tokens)

    escribir("")
    escribir("Un compilador real tiene más fases:")
    escribir("  1. Lexer (tokenización)")
    escribir("  2. Parser (análisis sintáctico → AST)")
    escribir("  3. Análisis semántico (tipos, alcance)")
    escribir("  4. Generación de código (bytecode, máquina)")
    escribir("  5. Optimización")
    escribir("")
    escribir("¡Forja puede compilar su propio código!")
}

main()
