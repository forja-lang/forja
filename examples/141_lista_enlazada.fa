/// Lista simplemente enlazada
/// Conceptos: lista enlazada, nodos, punteros, estructura dinámica
/// Nivel: avanzado

importar "std/io"

clase Nodo {
    valor
    siguiente

    constructor() {
        este.valor = 0
        este.siguiente = nulo
    }
}

clase ListaEnlazada {
    cabeza

    constructor() {
        este.cabeza = nulo
    }

    funcion insertar(valor) {
        variable nuevo = nuevo Nodo()
        nuevo.valor = valor
        nuevo.siguiente = este.cabeza
        este.cabeza = nuevo
    }

    funcion insertar_final(valor) {
        variable nuevo = nuevo Nodo()
        nuevo.valor = valor
        nuevo.siguiente = nulo

        si (este.cabeza == nulo) {
            este.cabeza = nuevo
            retornar
        }

        variable actual = este.cabeza
        mientras (actual.siguiente != nulo) {
            actual = actual.siguiente
        }
        actual.siguiente = nuevo
    }

    funcion eliminar(valor) -> Booleano {
        si (este.cabeza == nulo) {
            retornar falso
        }

        si (este.cabeza.valor == valor) {
            este.cabeza = este.cabeza.siguiente
            retornar verdadero
        }

        variable actual = este.cabeza
        mientras (actual.siguiente != nulo) {
            si (actual.siguiente.valor == valor) {
                actual.siguiente = actual.siguiente.siguiente
                retornar verdadero
            }
            actual = actual.siguiente
        }
        retornar falso
    }

    funcion buscar(valor) -> Booleano {
        variable actual = este.cabeza
        mientras (actual != nulo) {
            si (actual.valor == valor) {
                retornar verdadero
            }
            actual = actual.siguiente
        }
        retornar falso
    }

    funcion mostrar() {
        variable actual = este.cabeza
        variable elementos = []
        mientras (actual != nulo) {
            elementos[longitud(elementos)] = actual.valor
            actual = actual.siguiente
        }
        escribir("  Lista: ${elementos}")
    }
}

funcion main() {
    escribir("=== Lista Simplemente Enlazada ===\n")

    variable lista = nuevo ListaEnlazada()
    lista.insertar(10)
    lista.insertar(20)
    lista.insertar(30)
    lista.insertar_final(5)
    lista.insertar_final(1)

    escribir("Después de insertar:")
    lista.mostrar()

    variable buscar = [20, 99]
    variable i = 0
    mientras (i < longitud(buscar)) {
        variable encontrado = lista.buscar(buscar[i])
        escribir("  ¿${buscar[i]} está en la lista? ${encontrado}")
        i = i + 1
    }

    lista.eliminar(20)
    escribir("")
    escribir("Después de eliminar 20:")
    lista.mostrar()

    lista.eliminar(1)
    escribir("Después de eliminar 1:")
    lista.mostrar()

    escribir("")
    escribir("La lista enlazada permite inserción y eliminación eficiente O(1) al inicio.")
}

main()
