/// Pila (stack) con array y genéricos
/// Conceptos: pila, LIFO, apilar, desapilar, estructura de datos
/// Nivel: intermedio

importar "std/io"

clase Pila<T> {
    elementos

    constructor() {
        este.elementos = []
    }

    funcion apilar(valor: T) {
        este.elementos[longitud(este.elementos)] = valor
    }

    funcion desapilar() -> T {
        variable n = longitud(este.elementos)
        si (n == 0) {
            retornar nulo
        }
        variable valor = este.elementos[n - 1]
        este.elementos = este.elementos[0..n-2]
        retornar valor
    }

    funcion tope() -> T {
        variable n = longitud(este.elementos)
        si (n == 0) {
            retornar nulo
        }
        retornar este.elementos[n - 1]
    }

    funcion esta_vacia() -> Booleano {
        retornar longitud(este.elementos) == 0
    }

    funcion tamano() -> Entero {
        retornar longitud(este.elementos)
    }

    funcion mostrar() {
        escribir("  Pila: ${este.elementos}  (tope: ${este.tope()})")
    }
}

funcion evaluar_expresion_postfija(expr) -> Entero {
    variable pila = nuevo Pila()
    variable i = 0
    mientras (i < longitud(expr)) {
        variable token = expr[i]
        si (token == "+") {
            variable b = pila.desapilar()
            variable a = pila.desapilar()
            pila.apilar(a + b)
        } sino {
            si (token == "*") {
                variable b = pila.desapilar()
                variable a = pila.desapilar()
                pila.apilar(a * b)
            } sino {
                pila.apilar(token)
            }
        }
        i = i + 1
    }
    retornar pila.desapilar()
}

funcion main() {
    escribir("=== Pila (Stack) ===\n")

    variable pila = nuevo Pila()
    escribir("Apilando: 10, 20, 30, 40")
    pila.apilar(10)
    pila.apilar(20)
    pila.apilar(30)
    pila.apilar(40)
    pila.mostrar()

    escribir("Desapilando: ${pila.desapilar()}")
    escribir("Desapilando: ${pila.desapilar()}")
    pila.mostrar()
    escribir("Tope actual: ${pila.tope()}")
    escribir("Tamaño: ${pila.tamano()}")

    escribir("")
    escribir("Evaluación postfija (3 4 + 5 *):")
    variable resultado = evaluar_expresion_postfija([3, 4, "+", 5, "*"])
    escribir("  (3 + 4) * 5 = ${resultado}")

    escribir("")
    escribir("La pila sigue el principio LIFO (Last In, First Out).")
}

main()
