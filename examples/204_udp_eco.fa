

constante PUERTO_SERVER = 9090

constante PUERTO_CLIENTE = 9091

constante HOST_LOCAL = "127.0.0.1"

constante NUM_MENSAJES = 3

funcion servidor_udp(tx_confirmacion) {
escribir("  [Servidor UDP] Iniciando en puerto " + a_texto(PUERTO_SERVER) + "...")
variable resultado = sockets.udp_escuchar(PUERTO_SERVER)
}

funcion cliente_udp(rx_confirmacion) {
escribir("  [Cliente UDP] Iniciando en puerto " + a_texto(PUERTO_CLIENTE) + "...")
variable resultado = sockets.udp_escuchar(PUERTO_CLIENTE)
}

funcion main() {
escribir("╔══════════════════════════════════════╗")
escribir("║     Comunicación UDP - Forja         ║")
escribir("╚══════════════════════════════════════╝")
escribir("")
escribir("Protocolo: UDP (sin conexión)")
escribir("Servidor:  puerto " + a_texto(PUERTO_SERVER))
escribir("Cliente:   puerto " + a_texto(PUERTO_CLIENTE))
escribir("Mensajes:  " + a_texto(NUM_MENSAJES))
escribir("")
escribir("── Iniciando ───────────────────────────")
escribir("")
variable h_servidor = ?
esperar(0.2)
cliente_udp(rx)
h_servidor.unir()
escribir("")
escribir("── Resumen ─────────────────────────────")
escribir("")
escribir("✓ Comunicación UDP completada")
escribir("  Se enviaron y recibieron " + a_texto(NUM_MENSAJES) + " datagramas")
escribir("")
escribir("Características de UDP demostradas:")
escribir("  • udp_escuchar()  - crear socket en un puerto")
escribir("  • udp_enviar()    - enviar datagrama a destino")
escribir("  • udp_recibir()   - recibir datagrama completo")
escribir("  • Sin conexión    - no hay handshake previo")
escribir("  • Bidireccional   - ambos lados pueden enviar/recibir")
escribir("")
escribir("Nota: UDP no garantiza entrega ni orden. Para")
escribir("comunicación confiable, usa TCP (ejemplos 202, 203).")
}

main()

