/// Select con 3+ canales
/// Conceptos: seleccionar, múltiples canales, multiplexación, concurrencia
/// Nivel: avanzado

importar "std/io"

// Select puede manejar cualquier cantidad de canales

funcion main() {
    escribir("=== Select con múltiples canales ===\n")

    // Crear 3 canales
    variable t1, r1 = canal()
    variable t2, r2 = canal()
    variable t3, r3 = canal()

    // Hilos que envían a diferentes tiempos
    variable h1 = hilo {
        esperar(0.3)
        t1.enviar("🐢 Tortuga: llegó después de 0.3s")
        retornar 0
    }

    variable h2 = hilo {
        esperar(0.1)
        t2.enviar("🐇 Liebre: llegó después de 0.1s")
        retornar 0
    }

    variable h3 = hilo {
        esperar(0.2)
        t3.enviar("🐕 Perro: llegó después de 0.2s")
        retornar 0
    }

    escribir("Esperando 3 mensajes con select...\n")

    // Recibir 3 mensajes, select elige el más rápido cada vez
    variable i = 0
    mientras (i < 3) {
        seleccionar {
            caso r1 -> msg -> {
                escribir("  [1] ${msg}")
            }
            caso r2 -> msg -> {
                escribir("  [2] ${msg}")
            }
            caso r3 -> msg -> {
                escribir("  [3] ${msg}")
            }
        }
        i = i + 1
    }

    h1.unir()
    h2.unir()
    h3.unir()

    escribir("")
    escribir("Select multiplexa múltiples canales eligiendo el primero disponible.")
}

main()
