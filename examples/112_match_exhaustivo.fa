/// Verificación de cobertura total (exhaustividad)
/// Conceptos: coincidir, exhaustividad, cobertura total, seguridad en patrones
/// Nivel: intermedio

importar "std/io"

// El compilador verifica que todos los casos estén cubiertos
tipo Estado = Activo | Inactivo | Suspenso | Baneado

funcion mostrar_estado(e) -> Texto {
    // Si falta un caso, el compilador advierte
    coincidir (e) {
        caso Activo -> { retornar "🟢 Usuario activo" }
        caso Inactivo -> { retornar "⚪ Usuario inactivo" }
        caso Suspenso -> { retornar "🟡 Usuario suspendido" }
        caso Baneado -> { retornar "🔴 Usuario baneado" }
    }
}

// Otro ejemplo con enum de datos
tipo ResultadoPago = Exitosa | FondosInsuficientes | TarjetaVencida | Rechazada(Texto)

funcion procesar_pago(resultado) {
    coincidir (resultado) {
        caso Exitosa -> {
            escribir("  ✅ Pago exitoso")
        }
        caso FondosInsuficientes -> {
            escribir("  ❌ Fondos insuficientes")
        }
        caso TarjetaVencida -> {
            escribir("  ❌ Tarjeta vencida")
        }
        caso Rechazada(motivo) -> {
            escribir("  ❌ Rechazada: ${motivo}")
        }
    }
    // El compilador garantiza que cubrimos todas las variantes
}

funcion main() {
    escribir("=== Exhaustividad en Match ===\n")
    escribir("El compilador verifica que TODAS las variantes estén cubiertas.\n")

    escribir("Estados:")
    escribir("  ${mostrar_estado(Activo)}")
    escribir("  ${mostrar_estado(Inactivo)}")
    escribir("  ${mostrar_estado(Suspenso)}")
    escribir("  ${mostrar_estado(Baneado)}")

    escribir("")
    escribir("Pagos:")
    procesar_pago(Exitosa)
    procesar_pago(FondosInsuficientes)
    procesar_pago(TarjetaVencida)
    procesar_pago(Rechazada("Bloqueo por seguridad"))
}

main()
