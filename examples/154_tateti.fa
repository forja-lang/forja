/// Ta-Te-Ti (Tres en línea)
/// Conceptos: matrices, arrays bidimensionales, lógica de juego, turnos
/// Nivel: intermedio

importar "std/io"

// Implementación del clásico juego Ta-Te-Ti (3 en línea).
// Dos jugadores se turnan para colocar fichas en un tablero 3x3.

funcion crear_tablero() {
    variable t = []
    variable f = 0
    mientras (f < 3) {
        variable fila = []
        variable c = 0
        mientras (c < 3) {
            fila[c] = " "
            c = c + 1
        }
        t[f] = fila
        f = f + 1
    }
    retornar t
}

funcion mostrar_tablero(tablero) {
    escribir("")
    escribir("  1   2   3")
    variable f = 0
    mientras (f < 3) {
        escribir("${f + 1} ${tablero[f][0]} | ${tablero[f][1]} | ${tablero[f][2]}")
        si (f < 2) {
            escribir("  ---+---+---")
        }
        f = f + 1
    }
    escribir("")
}

funcion verificar_ganador(tablero, ficha) -> Booleano {
    // Filas
    variable i = 0
    mientras (i < 3) {
        si (tablero[i][0] == ficha && tablero[i][1] == ficha && tablero[i][2] == ficha) {
            retornar verdadero
        }
        i = i + 1
    }
    // Columnas
    variable j = 0
    mientras (j < 3) {
        si (tablero[0][j] == ficha && tablero[1][j] == ficha && tablero[2][j] == ficha) {
            retornar verdadero
        }
        j = j + 1
    }
    // Diagonales
    si (tablero[0][0] == ficha && tablero[1][1] == ficha && tablero[2][2] == ficha) {
        retornar verdadero
    }
    si (tablero[0][2] == ficha && tablero[1][1] == ficha && tablero[2][0] == ficha) {
        retornar verdadero
    }
    retornar falso
}

funcion tablero_lleno(tablero) -> Booleano {
    variable f = 0
    mientras (f < 3) {
        variable c = 0
        mientras (c < 3) {
            si (tablero[f][c] == " ") {
                retornar falso
            }
            c = c + 1
        }
        f = f + 1
    }
    retornar verdadero
}

funcion main() {
    escribir("=== TA-TE-TI (Tres en línea) ===\n")
    escribir("Jugador 1: X  |  Jugador 2: O\n")

    variable tablero = crear_tablero()
    variable turno = 1
    variable jugando = verdadero

    mientras (jugando) {
        mostrar_tablero(tablero)
        variable ficha = "X"
        si (turno == 2) {
            ficha = "O"
        }

        escribir("\nTurno del Jugador ${turno} (${ficha})")

        variable fila = pedir_numero("Fila (1-3): ")
        variable col = pedir_numero("Columna (1-3): ")

        // Validar entrada
        mientras (fila < 1 || fila > 3 || col < 1 || col > 3 || tablero[fila - 1][col - 1] != " ") {
            escribir("  Casilla inválida u ocupada. Intenta de nuevo.")
            fila = pedir_numero("Fila (1-3): ")
            col = pedir_numero("Columna (1-3): ")
        }

        tablero[fila - 1][col - 1] = ficha

        si (verificar_ganador(tablero, ficha)) {
            mostrar_tablero(tablero)
            escribir("")
            escribir("🎉 ¡Jugador ${turno} (${ficha}) GANA! 🎉")
            jugando = falso
        } sino {
            si (tablero_lleno(tablero)) {
                mostrar_tablero(tablero)
                escribir("")
                escribir("🤝 ¡EMPATE! No hay más movimientos.")
                jugando = falso
            } sino {
                // Cambiar turno
                si (turno == 1) {
                    turno = 2
                } sino {
                    turno = 1
                }
            }
        }
    }
}

main()
