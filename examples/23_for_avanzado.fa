// 🎓 Lección 23: Bucle for avanzado
// El bucle 'para' puede tener diferentes patrones

// Contar de 0 a 4
para (variable i = 0; i < 5; i = i + 1) {
    escribir("i = " + i)
}

escribir("")

// Contar de 2 en 2
para (variable i = 0; i < 10; i = i + 2) {
    escribir("Par: " + i)
}

escribir("")

// Contar hacia atrás
para (variable i = 5; i > 0; i = i - 1) {
    escribir("Descenso: " + i)
}

escribir("")

// Recorrer un array con for
variable colores = ["rojo", "verde", "azul"]
para (variable i = 0; i < 3; i = i + 1) {
    escribir("Color " + (i + 1) + ": " + colores[i])
}
