# Ejemplo 221: Cliente HTTP/2 (h2c)
#
# Uso: forja run examples/221_cliente_h2.fa
# Requiere: un servidor HTTP/2 corriendo en http://localhost:9500/
# (ver example 220)

importar "std/cliente_h2"

funcion main() {
    imprimir("=== Cliente HTTP/2 (h2c) ===")
    imprimir("Conectando a http://localhost:9500/")

    # GET simple
    variable resp = get("http://localhost:9500/")
    si (resp.exito) {
        imprimir("GET / -> Status: " + a_texto(resp.codigo))
        imprimir("  Cuerpo: " + resp.cuerpo)
    } sino {
        imprimir("Error GET /: " + resp.error)
    }

    # GET /json
    resp = get("http://localhost:9500/json")
    si (resp.exito) {
        imprimir("GET /json -> Status: " + a_texto(resp.codigo))
        imprimir("  Cuerpo: " + resp.cuerpo)
    } sino {
        imprimir("Error GET /json: " + resp.error)
    }

    # POST a /echo
    resp = post("http://localhost:9500/echo", "Hola desde Forja H2!")
    si (resp.exito) {
        imprimir("POST /echo -> Status: " + a_texto(resp.codigo))
        imprimir("  Cuerpo: " + resp.cuerpo)
    } sino {
        imprimir("Error POST /echo: " + resp.error)
    }

    # GET con parametro de ruta
    resp = get("http://localhost:9500/usuario/42")
    si (resp.exito) {
        imprimir("GET /usuario/42 -> Status: " + a_texto(resp.codigo))
        imprimir("  Cuerpo: " + resp.cuerpo)
    } sino {
        imprimir("Error GET /usuario/42: " + resp.error)
    }

    # 404
    resp = get("http://localhost:9500/no-existe")
    si (!resp.exito) {
        imprimir("GET /no-existe (esperado 404): Status " + a_texto(resp.codigo))
        imprimir("  Cuerpo: " + resp.cuerpo)
    } sino {
        imprimir("GET /no-existe -> Status: " + a_texto(resp.codigo))
        imprimir("  Cuerpo: " + resp.cuerpo)
    }

    imprimir("=== Cliente HTTP/2 finalizado ===")
}

main()
