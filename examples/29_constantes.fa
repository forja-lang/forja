// 🎓 Lección 29: Constantes
// Las constantes no pueden cambiar su valor

constante GRAVEDAD = 9
constante PI = 3
constante PAIS = "Argentina"

escribir("Gravedad: " + GRAVEDAD)
escribir("PI: " + PI)
escribir("País: " + PAIS)

// Calcular con constantes
variable radio = 5
variable areaCirculo = PI * radio * radio
escribir("Área: " + areaCirculo)

// Variables sí pueden cambiar
variable contador = 0
contador = 1
contador = 2
escribir("Contador: " + contador)
