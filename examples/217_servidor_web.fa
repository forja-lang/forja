# Ejemplo: Servidor Web HTTP
# Uso: forja ejecutar examples/217_servidor_web.fa
#
# NOTA: Para probar el servidor real, descomentar iniciar(servidor) al final.
# El servidor se ejecuta en un bucle infinito esperando conexiones.
# La VM tiene un limite de 1M instrucciones, por lo que no se muestra
# el servidor corriendo en este test rapido.

importar "std/servidor_web"

funcion manejador_inicio(solicitud) {
    variable respuesta = nuevo RespuestaHTTP()
    respuesta.cuerpo = "<h1>Hola desde Forja!</h1>"
    respuesta.tipo_contenido = "text/html; charset=utf-8"
    respuesta.cabeceras["Content-Type"] = respuesta.tipo_contenido
    retornar respuesta
}

funcion main() {
    imprimir("Creando servidor web en puerto 8080...")

    variable servidor = nuevo ServidorWeb(8080)
    get(servidor, "/", manejador_inicio)
    post(servidor, "/datos", manejador_inicio)

    imprimir("Servidor configurado correctamente!")
    imprimir("Rutas registradas:")
    variable rutas = servidor._rutas
    variable metodos = claves_mapa(rutas)
    variable i = 0
    mientras (i < longitud(metodos)) {
        variable m = metodos[i]
        variable rutas_m = claves_mapa(rutas[m])
        variable j = 0
        mientras (j < longitud(rutas_m)) {
            imprimir("  " + m + " " + rutas_m[j])
            j = j + 1
        }
        i = i + 1
    }

    # Para iniciar el servidor real (bucle infinito), descomentar:
    # iniciar(servidor)
}

main()
