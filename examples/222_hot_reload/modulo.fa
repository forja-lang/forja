# Módulo de ejemplo para demostrar Hot Reload en Forja
# Este archivo puede ser modificado durante la ejecución del REPL
# y recargado con :reload modulo o _recargar_modulo("modulo")

fun saludar(nombre) {
    escribir("¡Hola, {nombre}! — desde módulo")
}

fun sumar(a, b) -> a + b

fun version_modulo() -> 1
