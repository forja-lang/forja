/// Buffer Circular (Ring Buffer)
/// Conceptos: buffer circular, ring buffer, estructura de datos, productor-consumidor
/// Nivel: avanzado

importar "std/io"

// Un buffer circular (ring buffer) es una estructura de datos FIFO
// de tamaño fijo que reutiliza memoria. Cuando el buffer se llena,
// los datos nuevos sobrescriben los más antiguos.

clase BufferCircular {
    buffer
    capacidad
    cabeza
    cola
    lleno

    constructor() {
        este.buffer = []
        este.capacidad = 0
        este.cabeza = 0
        este.cola = 0
        este.lleno = falso
    }

    funcion init(capacidad) {
        este.capacidad = capacidad
        este.buffer = []
        este.cabeza = 0
        este.cola = 0
        este.lleno = falso

        variable i = 0
        mientras (i < capacidad) {
            este.buffer[i] = 0
            i = i + 1
        }
    }

    funcion esta_vacia() -> Booleano {
        retornar !este.lleno && este.cabeza == este.cola
    }

    funcion esta_llena() -> Booleano {
        retornar este.lleno
    }

    funcion tamano_actual() -> Entero {
        si (este.lleno) {
            retornar este.capacidad
        }
        si (este.cabeza >= este.cola) {
            retornar este.cabeza - este.cola
        }
        retornar este.capacidad - este.cola + este.cabeza
    }

    funcion espacio_libre() -> Entero {
        retornar este.capacidad - este.tamano_actual()
    }

    funcion encolar(valor) {
        este.buffer[este.cabeza] = valor

        si (este.lleno) {
            este.cola = (este.cola + 1) % este.capacidad
        }

        este.cabeza = (este.cabeza + 1) % este.capacidad
        este.lleno = (este.cabeza == este.cola)

        escribir("  📥 Encolado: ${valor}  [buff: ${este.tamano_actual()}/${este.capacidad}]")
    }

    funcion desencolar() -> Entero {
        si (este.esta_vacia()) {
            escribir("  ⚠️ Buffer vacío: no hay datos para desencolar")
            retornar nulo
        }

        variable valor = este.buffer[este.cola]
        este.lleno = falso
        este.cola = (este.cola + 1) % este.capacidad

        escribir("  📤 Desencolado: ${valor}  [buff: ${este.tamano_actual()}/${este.capacidad}]")
        retornar valor
    }

    funcion ver_frente() -> Entero {
        si (este.esta_vacia()) {
            escribir("  ⚠️ Buffer vacío")
            retornar nulo
        }
        retornar este.buffer[este.cola]
    }

    funcion mostrar() {
        escribir("  Buffer circular [${este.tamano_actual()}/${este.capacidad}]:")
        si (este.esta_vacia()) {
            escribir("    (vacío)")
            retornar
        }

        variable i = este.cola
        variable elementos_mostrados = 0
        mientras (elementos_mostrados < este.tamano_actual()) {
            escribir("    [${i}]: ${este.buffer[i]}")
            i = (i + 1) % este.capacidad
            elementos_mostrados = elementos_mostrados + 1
        }
    }
}

funcion main() {
    escribir("=== BUFFER CIRCULAR (RING BUFFER) ===\n")
    escribir("Estructura FIFO de tamaño fijo que reutiliza memoria.\n")

    variable buffer = nuevo BufferCircular()
    buffer.init(5)

    escribir("Buffer creado: capacidad = 5")

    escribir("")
    escribir("--- Encolando 3 elementos ---")
    buffer.encolar(10)
    buffer.encolar(20)
    buffer.encolar(30)
    buffer.mostrar()

    escribir("")
    escribir("--- Desencolando 2 elementos ---")
    buffer.desencolar()
    buffer.desencolar()
    buffer.mostrar()

    escribir("")
    escribir("--- Encolando 4 más (total 5, llenando) ---")
    buffer.encolar(40)
    buffer.encolar(50)
    buffer.encolar(60)
    buffer.encolar(70)
    buffer.mostrar()

    escribir("")
    escribir("--- Buffer lleno! Sobrescribiendo (encolar más) ---")
    buffer.encolar(80)
    buffer.encolar(90)
    buffer.mostrar()

    escribir("")
    escribir("--- Vaciando todo ---")
    mientras (!buffer.esta_vacia()) {
        buffer.desencolar()
    }
    buffer.mostrar()

    escribir("")
    escribir("Ventajas del buffer circular:")
    escribir("  • Tamaño fijo sin realocaciones de memoria")
    escribir("  • Operaciones de encolar/desencolar en O(1)")
    escribir("  • Ideal para streaming y buffers de audio/video")
    escribir("  • Perfecto para el patrón productor-consumidor")
}

main()
