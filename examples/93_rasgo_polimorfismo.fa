/// Usar rasgo como tipo (polimorfismo)
/// Conceptos: rasgo como tipo de parámetro, polimorfismo, abstracción
/// Nivel: avanzado

importar "std/io"

// Los rasgos pueden usarse como tipos para lograr polimorfismo

rasgo Sonido {
    funcion hacer_sonido() -> Texto
}

clase Perro {
    nombre
}

implementa Sonido para Perro {
    funcion hacer_sonido() -> Texto {
        retornar "${este.nombre} dice: ¡Guau guau!"
    }
}

clase Gato {
    nombre
}

implementa Sonido para Gato {
    funcion hacer_sonido() -> Texto {
        retornar "${este.nombre} dice: ¡Miau!"
    }
}

clase Vaca {
    nombre
}

implementa Sonido para Vaca {
    funcion hacer_sonido() -> Texto {
        retornar "${este.nombre} dice: ¡Muuuu!"
    }
}

// Función que acepta cualquier objeto que implemente Sonido
funcion presentar_animal(animal) {
    escribir(animal.hacer_sonido())
}

funcion main() {
    escribir("=== Polimorfismo con Rasgos ===\n")
    
    variable perro = nuevo Perro()
    perro.nombre = "Rex"
    
    variable gato = nuevo Gato()
    gato.nombre = "Mishi"
    
    variable vaca = nuevo Vaca()
    vaca.nombre = "Lola"
    
    // La misma función funciona con cualquier animal
    presentar_animal(perro)
    presentar_animal(gato)
    presentar_animal(vaca)
    
    escribir("")
    escribir("Todos implementan el rasgo Sonido")
}

main()
