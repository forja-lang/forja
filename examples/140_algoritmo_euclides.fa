/// Algoritmo de Euclides (MCD ampliado)
/// Conceptos: Euclides, MCD, algoritmo extendido, combinación lineal, teoría de números
/// Nivel: intermedio

importar "std/io"

funcion mcd(a, b) -> Entero {
    // Algoritmo de Euclides básico
    mientras (b != 0) {
        variable temp = b
        b = a % b
        a = temp
    }
    retornar a
}

funcion mcd_recursivo(a, b) -> Entero {
    // Versión recursiva
    si (b == 0) {
        retornar a
    }
    retornar mcd_recursivo(b, a % b)
}

funcion mcm(a, b) -> Entero {
    // Mínimo común múltiplo usando MCD
    retornar (a / mcd(a, b)) * b
}

funcion mcd_extendido(a, b) {
    // Algoritmo de Euclides extendido
    variable x0 = 1
    variable x1 = 0
    variable y0 = 0
    variable y1 = 1

    mientras (b != 0) {
        variable cociente = a / b
        variable temp_a = a
        a = b
        b = temp_a % b

        variable temp_x = x0
        x0 = x1
        x1 = temp_x - cociente * x1

        variable temp_y = y0
        y0 = y1
        y1 = temp_y - cociente * y1
    }

    escribir("  MCD = ${a}")
    escribir("  Coeficientes: x = ${x0}, y = ${y0}")
    escribir("  Combinación: ${a} = ${x0}*a + ${y0}*b")
}

funcion main() {
    escribir("=== Algoritmo de Euclides ===\n")

    variable pares = [[48, 18], [56, 42], [101, 10], [99, 36], [17, 13]]

    escribir("MCD básico (iterativo):\n")
    variable i = 0
    mientras (i < longitud(pares)) {
        variable a = pares[i][0]
        variable b = pares[i][1]
        escribir("  mcd(${a}, ${b}) = ${mcd(a, b)}")
        i = i + 1
    }

    escribir("")
    escribir("MCD recursivo:\n")
    variable j = 0
    mientras (j < longitud(pares)) {
        variable a = pares[j][0]
        variable b = pares[j][1]
        escribir("  mcd_rec(${a}, ${b}) = ${mcd_recursivo(a, b)}")
        j = j + 1
    }

    escribir("")
    escribir("MCM (mínimo común múltiplo):\n")
    variable k = 0
    mientras (k < longitud(pares)) {
        variable a = pares[k][0]
        variable b = pares[k][1]
        escribir("  mcm(${a}, ${b}) = ${mcm(a, b)}")
        k = k + 1
    }

    escribir("")
    escribir("MCD extendido (coeficientes de Bezout):")
    mcd_extendido(48, 18)

    escribir("")
    escribir("El algoritmo de Euclides calcula el MCD eficientemente O(log n).")
}

main()
