/// Patrón Singleton
/// Conceptos: singleton, instancia única, variable global controlada, patrón de creación
/// Nivel: intermedio

importar "std/io"

// El patrón Singleton garantiza que una clase tenga una única instancia
// y proporciona un punto de acceso global a ella.

clase Configuracion {
    // Variable estática que almacena la única instancia
    nombre_app
    version
    idioma

    constructor() {
        este.nombre_app = ""
        este.version = ""
        este.idioma = ""
    }
}

// Variable global para almacenar el singleton
variable instancia_unica = nulo

funcion obtener_configuracion() {
    si (instancia_unica == nulo) {
        instancia_unica = nuevo Configuracion()
        instancia_unica.nombre_app = "ForjaApp"
        instancia_unica.version = "1.0.0"
        instancia_unica.idioma = "es"
        escribir("  🔨 Primera vez: creando instancia única...")
    } sino {
        escribir("  ♻️ Instancia ya existente: reutilizando...")
    }
    retornar instancia_unica
}

funcion main() {
    escribir("=== PATRÓN SINGLETON ===\n")
    escribir("Garantiza una única instancia de una clase.\n")

    escribir("Intentando obtener configuración (primera vez):")
    variable config1 = obtener_configuracion()
    escribir("  App: ${config1.nombre_app} v${config1.version}")
    escribir("  Idioma: ${config1.idioma}")

    escribir("")
    escribir("Modificando configuración...")
    config1.idioma = "en"

    escribir("")
    escribir("Intentando obtener configuración (segunda vez):")
    variable config2 = obtener_configuracion()
    escribir("  App: ${config2.nombre_app} v${config2.version}")
    escribir("  Idioma: ${config2.idioma}")

    escribir("")
    escribir("¿Son la misma instancia?")
    si (config1 == config2) {
        escribir("  ✅ Sí, config1 y config2 son el mismo objeto.")
    } sino {
        escribir("  ❌ No, son objetos diferentes.")
    }

    escribir("")
    escribir("El Singleton es útil para:")
    escribir("  • Configuración global de la aplicación")
    escribir("  • Pool de conexiones a base de datos")
    escribir("  • Logger o sistema de logging")
    escribir("  • Cache compartido")
}

main()
