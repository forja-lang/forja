// ═══════════════════════════════════════════════════════════════════
//  FORJA PERSONAL DASHBOARD
//  Aplicacion GUI completa con Xilem 0.4
//  Demuestra: formularios, validacion, sliders, checkboxes, layouts
// ═══════════════════════════════════════════════════════════════════
//
//  Ejecutar (nativo):  forja ejecutar --native examples/210_forja_dashboard.fa
//  Ejecutar (normal):  forja ejecutar examples/210_forja_dashboard.fa
//
//  Requiere: cargo build --features gui
//
// ═══════════════════════════════════════════════════════════════════

importar "gui"

// ─── Callbacks de validacion ──────────────────────────────────────
// Los parametros DEBEN coincidir con nombres de variables en main()
// para que el native runner pueda leer los valores del estado.

funcion validar_nombre(nombre: Texto) -> Texto {
    si (nombre == "") {
        retornar "=> El nombre es obligatorio"
    }
    si (nombre == "admin") {
        retornar "=> Ese nombre no esta disponible"
    }
    si (nombre == "root") {
        retornar "=> Nombre reservado del sistema"
    }
    retornar "=> Nombre valido: " + nombre
}

funcion validar_email(email: Texto) -> Texto {
    si (email == "") {
        retornar "=> El email es obligatorio"
    }
    retornar "=> Email registrado correctamente"
}

funcion calcular_progreso(experiencia: Texto) -> Texto {
    retornar "=> Nivel de experiencia: " + experiencia + "%"
}

funcion calcular_puntuacion(experiencia: Texto, edad: Texto) -> Texto {
    retornar "=> Puntuacion calculada: " + experiencia + "/" + edad
}

funcion guardar_cambios() -> Texto {
    retornar "=> Datos guardados exitosamente"
}

funcion limpiar() -> Texto {
    retornar ""
}

// ─── Aplicacion principal ─────────────────────────────────────────

funcion main() {
    // ─── Variables de estado (AppState dinamico) ───
    variable nombre = ""
    variable email = ""
    variable bio = ""
    variable edad = 28
    variable experiencia = 45
    variable volumen = 80
    variable notificaciones = verdadero
    variable modo_oscuro = falso
    variable resultado = ""
    variable puntuacion = 65
    variable progreso = 50

    // ─── Interfaz completa ───
    desplazable(
        columna(

            // ═══════════════════════════════════════════════
            //  HEADER
            // ═══════════════════════════════════════════════
            etiqueta("================================================================"),
            etiqueta("                                                                  "),
            etiqueta("              *  F O R J A   D A S H B O A R D  *              "),
            etiqueta("         Panel de control personal con GUI nativa Xilem           "),
            etiqueta("                                                                  "),
            etiqueta("================================================================"),
            espacio(15),

            // ═══════════════════════════════════════════════
            //  SECCION 1: PERFIL
            // ═══════════════════════════════════════════════
            etiqueta("  +---------------------------------------------------------------+"),
            etiqueta("  |  >>>  PERFIL DEL USUARIO                                     |"),
            etiqueta("  +---------------------------------------------------------------+"),
            separador(),
            espacio(5),

            etiqueta("     Nombre completo:"),
            etiqueta("     --------------------------------------------------------------"),
            entrada_texto("nombre"),
            espacio(3),

            etiqueta("     Correo electronico:"),
            etiqueta("     --------------------------------------------------------------"),
            entrada_texto("email"),
            espacio(3),

            etiqueta("     Biografia (area de texto multilinea):"),
            etiqueta("     --------------------------------------------------------------"),
            area_texto("bio"),
            espacio(10),

            // ═══════════════════════════════════════════════
            //  SECCION 2: PREFERENCIAS
            // ═══════════════════════════════════════════════
            etiqueta("  +---------------------------------------------------------------+"),
            etiqueta("  |  >>>  PREFERENCIAS                                           |"),
            etiqueta("  +---------------------------------------------------------------+"),
            separador(),
            espacio(5),

            etiqueta("     Edad:"),
            fila(
                deslizante("edad", 1, 100),
                espacio(10),
                etiqueta("    Edad: "),
                escribir(edad),
                etiqueta(" anios")
            ),
            espacio(3),

            etiqueta("     Nivel de experiencia:"),
            fila(
                deslizante("experiencia", 0, 100),
                espacio(10),
                etiqueta("    "),
                escribir(experiencia),
                etiqueta(" %")
            ),
            espacio(3),

            etiqueta("     Volumen del sistema:"),
            fila(
                deslizante("volumen", 0, 100),
                espacio(10),
                etiqueta("    >>> "),
                escribir(volumen),
                etiqueta(" %")
            ),
            espacio(5),

            etiqueta("     Preferencias de cuenta:"),
            casilla("=>  Recibir notificaciones por email", "notificaciones"),
            casilla("=>  Modo oscuro (interfaz)", "modo_oscuro"),
            espacio(10),

            // ═══════════════════════════════════════════════
            //  SECCION 3: ESTADISTICAS
            // ═══════════════════════════════════════════════
            etiqueta("  +---------------------------------------------------------------+"),
            etiqueta("  |  >>>  ESTADISTICAS Y PROGRESO                                |"),
            etiqueta("  +---------------------------------------------------------------+"),
            separador(),
            espacio(5),

            etiqueta("     Progreso general del perfil:"),
            fila(
                barra_progreso("progreso"),
                espacio(10),
                escribir(progreso),
                etiqueta(" %")
            ),
            espacio(3),

            etiqueta("     Puntuacion acumulada:"),
            fila(
                barra_progreso("puntuacion"),
                espacio(10),
                escribir(puntuacion),
                etiqueta(" pts")
            ),
            espacio(3),

            etiqueta("     Estado de cuenta:"),
            escribir(notificaciones),
            espacio(10),

            // ═══════════════════════════════════════════════
            //  SECCION 4: ACCIONES
            // ═══════════════════════════════════════════════
            etiqueta("  +---------------------------------------------------------------+"),
            etiqueta("  |  >>>  ACCIONES                                               |"),
            etiqueta("  +---------------------------------------------------------------+"),
            separador(),
            espacio(5),

            etiqueta("     Validacion de formulario:"),
            fila(
                boton(">>  Validar nombre", &validar_nombre),
                espacio(8),
                boton(">>  Validar email", &validar_email)
            ),
            espacio(3),

            etiqueta("     Calculos:"),
            fila(
                boton(">>  Calcular progreso", &calcular_progreso),
                espacio(8),
                boton(">>  Calcular puntuacion", &calcular_puntuacion)
            ),
            espacio(3),

            etiqueta("     Acciones generales:"),
            fila(
                boton(">>  Guardar cambios", &guardar_cambios),
                espacio(8),
                boton(">>  Limpiar resultado", &limpiar)
            ),
            espacio(10),

            // ═══════════════════════════════════════════════
            //  SECCION 5: RESULTADOS
            // ═══════════════════════════════════════════════
            etiqueta("  +---------------------------------------------------------------+"),
            etiqueta("  |  >>>  RESULTADO DE OPERACIONES                               |"),
            etiqueta("  +---------------------------------------------------------------+"),
            separador(),
            espacio(5),

            etiqueta("     +---------------------------------------------------------+"),
            escribir(resultado),
            etiqueta("     +---------------------------------------------------------+"),
            espacio(15),

            // ═══════════════════════════════════════════════
            //  SECCION 6: DEMO DE WIDGETS
            // ═══════════════════════════════════════════════
            etiqueta("  +---------------------------------------------------------------+"),
            etiqueta("  |  >>>  GALERIA DE WIDGETS                                    |"),
            etiqueta("  +---------------------------------------------------------------+"),
            separador(),
            espacio(5),

            etiqueta("     >> Texto enriquecido (Markdown):"),
            texto_enriquecido("       **Forja** es un lenguaje *educativo*"),
            texto_enriquecido("       que usa **Xilem** para GUI nativa"),
            espacio(5),

            etiqueta("     >> Indicador de carga (spinner):"),
            fila(
                cargando(),
                espacio(10),
                etiqueta("    Procesando...")
            ),
            espacio(5),

            etiqueta("     Layout horizontal (fila) con widgets:"),
            fila(
                etiqueta("  [..]  "),
                etiqueta("  [##]  "),
                etiqueta("  [**]  "),
                etiqueta("  [!!]  ")
            ),
            espacio(5),

            etiqueta("     Layout superpuesto (pila / ZStack):"),
            pila(
                etiqueta("     +--------------------------+"),
                etiqueta("     |   CAPA SUPERIOR          |"),
                etiqueta("     +--------------------------+")
            ),
            espacio(10),

            // ═══════════════════════════════════════════════
            //  FOOTER
            // ═══════════════════════════════════════════════
            etiqueta("================================================================"),
            etiqueta("                                                                  "),
            etiqueta("     Forja v0.7  -  GUI Nativa Xilem 0.4  -  Rust + GPU (Vello)"),
            etiqueta("     Copyright (c) 2026 - Language designed by lococoi"),
            etiqueta("                                                                  "),
            etiqueta("================================================================"),
            espacio(20)
        )
    )
}
