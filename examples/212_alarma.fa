/// ALARMAS — App interactiva con alarmas editables
///
/// 3 alarmas configurables con checkbox, hora y titulo editables.
/// Escribi la hora y presiona VERIFICAR.
///
/// Ejecutar:
///   cargo run --bin forja --features gui -- ejecutar examples\212_alarma.fa --native

importar "gui"

funcion verificar(tiempo_str: Texto, a1: Texto, h1: Texto, t1: Texto, a2: Texto, h2: Texto, t2: Texto, a3: Texto, h3: Texto, t3: Texto) -> Texto {
    si (a1 == verdadero) {
        si (tiempo_str == h1) {
            retornar "🔔 " + t1 + " a las " + h1
        }
    }
    si (a2 == verdadero) {
        si (tiempo_str == h2) {
            retornar "🔔 " + t2 + " a las " + h2
        }
    }
    si (a3 == verdadero) {
        si (tiempo_str == h3) {
            retornar "🔔 " + t3 + " a las " + h3
        }
    }
    retornar "✅ " + tiempo_str + " — Sin alarmas"
}

funcion main() {
    variable tiempo_str = "08:00"
    variable a1 = "verdadero"
    variable h1 = "08:00"
    variable t1 = "Reunion equipo"
    variable a2 = "verdadero"
    variable h2 = "12:00"
    variable t2 = "Almuerzo"
    variable a3 = "falso"
    variable h3 = "16:30"
    variable t3 = "Recordatorio"
    variable resultado = "Escribi una hora y presiona VERIFICAR"

    desplazable(
        columna(

            etiqueta("🔔 Alarmas"),

            etiqueta(""),
            etiqueta("🕐 Hora:"),
            fila(
                entrada_texto("tiempo_str"),
                etiqueta("  (HH:MM)")
            ),

            etiqueta(""),
            etiqueta("--- Alarma 1 ---"),
            fila(casilla("", "a1"), entrada_texto("h1"), entrada_texto("t1")),

            etiqueta("--- Alarma 2 ---"),
            fila(casilla("", "a2"), entrada_texto("h2"), entrada_texto("t2")),

            etiqueta("--- Alarma 3 ---"),
            fila(casilla("", "a3"), entrada_texto("h3"), entrada_texto("t3")),

            etiqueta(""),
            boton("VERIFICAR", &verificar),

            etiqueta(""),
            escribir(resultado)
        )
    )
}
