/// Metaprogramación: Código que genera código
/// Conceptos: metaprogramación, generación de código, reflexión, macros
/// Nivel: experto

importar "std/io"

// La metaprogramación consiste en escribir programas que
// generan, analizan o transforman otros programas (o sí mismos).
// Esto incluye macros, templates y generación de código.

// NOTA: Este ejemplo demuestra el CONCEPTO de metaprogramación
// mediante funciones que generan código Forja como texto.

funcion generar_getter_setter(nombre_propiedad, tipo) -> Texto {
    // Genera código de getter y setter para una propiedad
    variable getter = "  funcion obtener_${nombre_propiedad}() -> ${tipo} {\n"
    getter = getter + "        retornar este.${nombre_propiedad}\n"
    getter = getter + "    }"

    variable setter = "  fijar_${nombre_propiedad}(valor: ${tipo}) {\n"
    setter = setter + "        este.${nombre_propiedad} = valor\n"
    setter = setter + "    }"

    retornar "${getter}\n    ${setter}"
}

funcion generar_clase(nombre, propiedades) -> Texto {
    // Genera una clase completa a partir de una lista de propiedades
    variable codigo = "clase ${nombre} {\n"

    // Declaraciones
    variable i = 0
    mientras (i < longitud(propiedades)) {
        variable prop = propiedades[i]
        codigo = codigo + "    ${prop}\n"
        i = i + 1
    }

    // Constructor vacío
    codigo = codigo + "\n    constructor() {\n"
    variable j = 0
    mientras (j < longitud(propiedades)) {
        variable prop = propiedades[j]
        codigo = codigo + "        este.${prop} = 0\n"
        j = j + 1
    }
    codigo = codigo + "    }\n"

    // Métodos generados
    variable k = 0
    mientras (k < longitud(propiedades)) {
        variable prop = propiedades[k]
        codigo = codigo + "\n    " + generar_getter_setter(prop, "Entero")
        k = k + 1
    }

    codigo = codigo + "\n}"
    retornar codigo
}

funcion generar_estructura_repetitiva(patron, veces) -> Texto {
    // Genera código repetitivo para evitar escribirlo manualmente
    variable resultado = ""
    variable i = 0
    mientras (i < veces) {
        variable reemplazo = "#{i}"
        variable linea = patron
        // Reemplazar #{i} por el número de iteración
        // (simulación de template)
        resultado = resultado + "    caso ${i} -> { retornar \"valor_${i}\" }\n"
        i = i + 1
    }
    retornar resultado
}

funcion evaluar_expresion(expr) -> Entero {
    // Evaluador de expresiones simple (meta: analizar código como datos)
    // Soporta: número, suma, resta
    variable resultado = 0
    variable operador = "+"
    variable num_actual = 0
    variable i = 0

    mientras (i < longitud(expr)) {
        variable c = expr[i]
        si (c >= '0' && c <= '9') {
            num_actual = num_actual * 10 + (c - 48)
        } sino {
            si (c == '+' || c == '-') {
                si (operador == "+") {
                    resultado = resultado + num_actual
                } sino {
                    resultado = resultado - num_actual
                }
                num_actual = 0
                operador = c
            }
        }
        i = i + 1
    }

    si (operador == "+") {
        resultado = resultado + num_actual
    } sino {
        resultado = resultado - num_actual
    }

    retornar resultado
}

funcion main() {
    escribir("=== METAPROGRAMACIÓN ===\n")
    escribir("Código que genera código.\n")

    escribir("--- 1. Generación de clases ---")
    variable propiedades = ["x", "y", "z"]
    variable codigo_clase = generar_clase("Punto3D", propiedades)
    escribir("  Código generado para clase Punto3D:")
    escribir("  --------------------------------")
    escribir(codigo_clase)
    escribir("  --------------------------------")

    escribir("")
    escribir("--- 2. Generación de patrones repetitivos ---")
    escribir("  Match generado para 5 casos:")
    variable patron_match = generar_estructura_repetitiva("caso", 5)
    escribir(patron_match)

    escribir("--- 3. Evaluación de expresiones (código como datos) ---")
    variable expr1 = "10 + 20 + 30"
    variable expr2 = "100 - 25 + 15"
    variable expr3 = "5 + 10 - 3 + 8"
    escribir("  '${expr1}' = ${evaluar_expresion(expr1)}")
    escribir("  '${expr2}' = ${evaluar_expresion(expr2)}")
    escribir("  '${expr3}' = ${evaluar_expresion(expr3)}")

    escribir("")
    escribir("--- 4. Plantillas de código ---")
    variable plantilla = "funcion operacion_#{i}() { retornar #{i} * 2 }"
    escribir("  Plantilla: ${plantilla}")
    escribir("  Generando 3 funciones:")
    variable f = 0
    mientras (f < 3) {
        variable func_gen = "  funcion operacion_${f}() { retornar ${f} * 2 }"
        escribir(func_gen)
        f = f + 1
    }

    escribir("")
    escribir("Usos de la metaprogramación:")
    escribir("  • Generar código boilerplate automáticamente")
    escribir("  • Crear DSLs (Domain Specific Languages)")
    escribir("  • Implementar aspectos transversales (logging, serialización)")
    escribir("  • Optimizaciones en tiempo de compilación")
    escribir("  • Generar adaptadores para APIs externas")
}

main()
