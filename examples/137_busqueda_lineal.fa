/// Búsqueda lineal en array
/// Conceptos: búsqueda lineal, arrays, recorrido secuencial, sin orden requerido
/// Nivel: básico

importar "std/io"

funcion busqueda_lineal(arr, objetivo) -> Entero {
    variable i = 0
    mientras (i < longitud(arr)) {
        si (arr[i] == objetivo) {
            retornar i
        }
        i = i + 1
    }
    retornar -1
}

funcion contar_ocurrencias(arr, objetivo) -> Entero {
    variable contador = 0
    variable i = 0
    mientras (i < longitud(arr)) {
        si (arr[i] == objetivo) {
            contador = contador + 1
        }
        i = i + 1
    }
    retornar contador
}

funcion main() {
    escribir("=== Búsqueda Lineal ===\n")

    variable numeros = [45, 12, 78, 23, 56, 12, 89, 34, 12, 67]
    escribir("Array: ${numeros}")

    variable busquedas = [12, 89, 99]
    variable i = 0
    mientras (i < longitud(busquedas)) {
        variable target = busquedas[i]
        variable pos = busqueda_lineal(numeros, target)
        variable count = contar_ocurrencias(numeros, target)
        si (pos >= 0) {
            escribir("  ${target} → primera vez en índice ${pos}, aparece ${count} vez/veces")
        } sino {
            escribir("  ${target} → no encontrado")
        }
        i = i + 1
    }

    escribir("")
    escribir("Búsqueda lineal: O(n), funciona con arrays desordenados.")
}

main()
