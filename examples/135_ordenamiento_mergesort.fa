/// Merge sort
/// Conceptos: ordenamiento mezcla, dividir y conquistar, recursividad, fusión
/// Nivel: avanzado

importar "std/io"

funcion merge(arr, izquierda, medio, derecha) {
    variable n1 = medio - izquierda + 1
    variable n2 = derecha - medio

    variable arr_izq = []
    variable arr_der = []

    variable i = 0
    mientras (i < n1) {
        arr_izq[i] = arr[izquierda + i]
        i = i + 1
    }
    variable j = 0
    mientras (j < n2) {
        arr_der[j] = arr[medio + 1 + j]
        j = j + 1
    }

    i = 0
    j = 0
    variable k = izquierda
    mientras (i < n1 && j < n2) {
        si (arr_izq[i] <= arr_der[j]) {
            arr[k] = arr_izq[i]
            i = i + 1
        } sino {
            arr[k] = arr_der[j]
            j = j + 1
        }
        k = k + 1
    }

    mientras (i < n1) {
        arr[k] = arr_izq[i]
        i = i + 1
        k = k + 1
    }
    mientras (j < n2) {
        arr[k] = arr_der[j]
        j = j + 1
        k = k + 1
    }
}

funcion merge_sort(arr, izquierda, derecha) {
    si (izquierda < derecha) {
        variable medio = (izquierda + derecha) / 2
        merge_sort(arr, izquierda, medio)
        merge_sort(arr, medio + 1, derecha)
        merge(arr, izquierda, medio, derecha)
    }
}

funcion ordenar(arr) {
    merge_sort(arr, 0, longitud(arr) - 1)
    retornar arr
}

funcion main() {
    escribir("=== Merge Sort ===\n")

    variable numeros = [38, 27, 43, 3, 9, 82, 10, 55, 1]
    escribir("Original: ${numeros}")

    numeros = ordenar(numeros)
    escribir("Ordenado: ${numeros}")

    escribir("")
    escribir("Merge sort divide el array en mitades, ordena y fusiona. O(n log n) estable.")
}

main()
