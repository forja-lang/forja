// ═══════════════════════════════════════════════════════════════════
//  LAYOUT RESPONSIVE — Window Size Classes + Layout avanzado
//  Demuestra: adaptable, columna_con_gap, fila_con_gap, flujo,
//             caja_relativa, flex_layout
// ═══════════════════════════════════════════════════════════════════
//
//  Ejecutar (nativo): forja ejecutar --native examples/301_layout_responsive.fa
//
//  Requiere: cargo build --features gui
//
//  NOTA: La detección automática del tamaño de ventana se añadirá
//        en una versión futura. Por ahora, window_size se inicializa
//        como Compact (modo responsivo básico).
//
// ═══════════════════════════════════════════════════════════════════

importar "gui"

// Callback para incrementar contador
funcion incrementar(n: Texto) -> Texto {
    variable val = convertir(n, Entero) + 1
    retornar convertir(val, Texto)
}

funcion main() {
    variable contador = 0

    desplazable(
        columna(
            // ═══════════════════════════════════════════════
            //  HEADER
            // ═══════════════════════════════════════════════
            texto_grande("Layout Responsive"),
            espacio(10),
            texto_mediano("Este layout cambia segun el tamano de ventana"),
            separador(),
            espacio(10),

            // ═══════════════════════════════════════════════
            //  CONTENIDO ADAPTABLE (Window Size Classes)
            // ═══════════════════════════════════════════════
            // adaptable recibe 3 layouts:
            //   1. Compact   (< 600px)  — columna vertical
            //   2. Medium    (600-840px) — mixto
            //   3. Expanded  (> 840px)  — fila horizontal
            etiqueta(">>> Contenido adaptable (Window Size Classes):"),
            espacio(8),
            adaptable(

                // ─── Compact ───
                columna(
                    etiqueta("[Compact] Una columna vertical"),
                    espacio(8),
                    boton("Click", &incrementar),
                    espacio(4),
                    etiqueta_dinamica("contador")
                ),

                // ─── Medium ───
                columna(
                    fila_con_gap((
                        etiqueta("[Medium] Dos columnas"),
                        boton("+", &incrementar)
                    ), 8, "centro"),
                    espacio(4),
                    etiqueta_dinamica("contador")
                ),

                // ─── Expanded ───
                fila_con_gap((
                    etiqueta("[Expanded] Layout horizontal completo"),
                    boton("Incrementar", &incrementar),
                    etiqueta_dinamica("contador")
                ), 12, "centro")
            ),

            espacio(16),
            separador(),
            espacio(10),

            // ═══════════════════════════════════════════════
            //  FLOW LAYOUT (wrap automático)
            // ═══════════════════════════════════════════════
            texto_mediano("Flow Layout (wrap automatico):"),
            espacio(8),
            flujo((
                etiqueta("  Tag 1  "),
                etiqueta("  Tag 2  "),
                etiqueta("  Tag 3  "),
                etiqueta("  Tag 4  "),
                etiqueta("  Tag 5  "),
                etiqueta("  Tag 6  "),
                etiqueta("  Tag 7  "),
                etiqueta("  Tag 8  ")
            ), 8),

            espacio(16),
            separador(),
            espacio(10),

            // ═══════════════════════════════════════════════
            //  COLUMNA CON GAP
            // ═══════════════════════════════════════════════
            texto_mediano("Columna con gap personalizado:"),
            espacio(8),
            columna_con_gap((
                etiqueta("Elemento 1"),
                etiqueta("Elemento 2"),
                etiqueta("Elemento 3")
            ), 4, "centro"),

            espacio(16),
            separador(),
            espacio(10),

            // ═══════════════════════════════════════════════
            //  FILA CON GAP
            // ═══════════════════════════════════════════════
            texto_mediano("Fila con gap y alineacion:"),
            espacio(8),
            fila_con_gap((
                boton("Izq", &incrementar),
                boton("Centro", &incrementar),
                boton("Der", &incrementar)
            ), 16, "start"),

            espacio(16),
            espacio(20)
        )
    )
}
