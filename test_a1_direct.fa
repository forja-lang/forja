// Test A1: member[index] = value
clase Caja {
    items
}

funcion main() {
    variable c = Caja()
    c.items = [1, 2, 3]
    // Test the fix: c.items[1] = 99
    c.items[1] = 99
    escribir("c.items[0] = ${c.items[0]}\n")
    escribir("c.items[1] = ${c.items[1]}\n")
    escribir("A1 OK\n")
}

main()
