// Test A1: este.elementos[indice] = valor
clase Pila {
    elementos

    constructor() {
        este.elementos = []
    }

    funcion probar() {
        variable x = 42
        este.elementos[0] = x
        escribir("OK: asignación por índice a miembro funciona\n")
    }
}

funcion main() {
    variable p = Pila()
    p.probar()
    escribir("Prueba A1 completada\n")
}

main()
