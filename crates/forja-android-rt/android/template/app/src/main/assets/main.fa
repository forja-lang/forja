funcion main() {
    escribir("¡Hola desde Forja en Android!")
    escribir("")
    escribir("Podés escribir tu app acá.")
    escribir("")

    // Ejemplo: calcular primos hasta 50
    variable primos = []
    para (variable n = 2; n <= 50; n = n + 1) {
        si (es_primo(n)) {
            primos.empujar(n)
        }
    }
    escribir("Primos hasta 50: " + primos)
}

funcion es_primo(n: Entero) -> Booleano {
    si (n < 2) { retornar falso }
    variable i = 2
    mientras (i * i <= n) {
        si (n % i == 0) { retornar falso }
        i = i + 1
    }
    retornar verdadero
}

main()
