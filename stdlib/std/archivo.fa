# módulo: archivo
# Descripción: Operaciones del sistema de archivos
#
# Uso: importar "std/archivo"
#
# Todas las funciones que pueden fallar retornan Resultado<T, ErrorArchivo>
# donde ErrorArchivo contiene:
#   .mensaje — descripción del error
#   .codigo  — 0=Exito, 1=archivo_no_encontrado, 2=permiso_denegado,
#              3=ruta_invalida, 4=es_directorio, 5=error_interno

# ═════════════════════════════════════════════════════════════════════════
# Clase ErrorArchivo
# ═════════════════════════════════════════════════════════════════════════

clase ErrorArchivo {
    mensaje: Texto
    codigo: Entero

    constructor(mensaje: Texto, codigo: Entero) {
        este.mensaje = mensaje
        este.codigo = codigo
    }
}

# ═════════════════════════════════════════════════════════════════════════
# Operaciones con Archivos
# ═════════════════════════════════════════════════════════════════════════

funcion leer_archivo(ruta: Texto) {
    variable res = _archivo_leer(ruta)
    si (res == -1) {
        retornar Error(nuevo ErrorArchivo("No se pudo leer el archivo: " + ruta, 1))
    }
    retornar Ok(res)
}

funcion escribir_archivo(ruta: Texto, contenido: Texto) {
    variable res = _archivo_escribir(ruta, contenido)
    si (res == -1) {
        retornar Error(nuevo ErrorArchivo("No se pudo escribir el archivo: " + ruta, 2))
    }
    retornar Ok(nulo)
}

funcion existe_archivo(ruta: Texto) -> Booleano {
    retornar _archivo_existe(ruta)
}

funcion eliminar_archivo(ruta: Texto) {
    variable res = _archivo_eliminar(ruta)
    si (res == -1) {
        retornar Error(nuevo ErrorArchivo("No se pudo eliminar el archivo: " + ruta, 1))
    }
    retornar Ok(nulo)
}

funcion copiar_archivo(origen: Texto, destino: Texto) {
    si (longitud(origen) == 0 || longitud(destino) == 0) {
        retornar Error(nuevo ErrorArchivo("Las rutas no pueden estar vacías", 3))
    }
    variable res = _archivo_copiar(origen, destino)
    si (res == -1) {
        retornar Error(nuevo ErrorArchivo("No se pudo copiar de '" + origen + "' a '" + destino + "'", 1))
    }
    retornar Ok(nulo)
}

funcion mover_archivo(origen: Texto, destino: Texto) {
    si (longitud(origen) == 0 || longitud(destino) == 0) {
        retornar Error(nuevo ErrorArchivo("Las rutas no pueden estar vacías", 3))
    }
    variable res = _archivo_mover(origen, destino)
    si (res == -1) {
        retornar Error(nuevo ErrorArchivo("No se pudo mover de '" + origen + "' a '" + destino + "'", 1))
    }
    retornar Ok(nulo)
}

funcion tamano_archivo(ruta: Texto) {
    variable res = _archivo_tamano(ruta)
    si (res == -1) {
        retornar Error(nuevo ErrorArchivo("No se pudo obtener el tamaño de: " + ruta, 1))
    }
    retornar Ok(res)
}

# ═════════════════════════════════════════════════════════════════════════
# Operaciones con Directorios
# ═════════════════════════════════════════════════════════════════════════

funcion crear_directorio(ruta: Texto) {
    variable res = _directorio_crear(ruta)
    si (res == -1) {
        retornar Error(nuevo ErrorArchivo("No se pudo crear el directorio: " + ruta, 2))
    }
    retornar Ok(nulo)
}

funcion eliminar_directorio(ruta: Texto) {
    variable res = _directorio_eliminar(ruta)
    si (res == -1) {
        retornar Error(nuevo ErrorArchivo("No se pudo eliminar el directorio: " + ruta, 1))
    }
    retornar Ok(nulo)
}

funcion listar_directorio(ruta: Texto) {
    variable res = _directorio_listar(ruta)
    si (res == -1) {
        retornar Error(nuevo ErrorArchivo("No se pudo listar el directorio: " + ruta, 1))
    }
    retornar Ok(dividir(res, "\n"))
}

# ═════════════════════════════════════════════════════════════════════════
# Funciones de Consulta Adicionales
# ═════════════════════════════════════════════════════════════════════════

funcion info_archivo(ruta: Texto) {
    variable res = _archivo_info(ruta)
    si (res == -1) {
        retornar Error(nuevo ErrorArchivo("No se pudo obtener información de: " + ruta, 1))
    }

    # Parsear el formato "clave:valor;clave:valor;..."
    variable info = {}
    variable partes = dividir(res, ";")
    variable i = 0
    mientras (i < longitud(partes)) {
        variable par = dividir(partes[i], ":")
        si (longitud(par) == 2) {
            info[par[0]] = par[1]
        }
        i = i + 1
    }
    retornar Ok(info)
}

funcion es_directorio(ruta: Texto) -> Booleano {
    variable res = _archivo_info(ruta)
    si (res == -1) {
        retornar falso
    }

    variable partes = dividir(res, ";")
    variable i = 0
    mientras (i < longitud(partes)) {
        variable par = dividir(partes[i], ":")
        si (longitud(par) == 2 && par[0] == "es_directorio") {
            retornar par[1] == "true"
        }
        i = i + 1
    }
    retornar falso
}
