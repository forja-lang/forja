# módulo: codificacion
# Codificación y decodificación Base64, URL y Hexadecimal
#
# Uso: importar "std/codificacion"
#
# Proporciona:
#   - base64_codificar(texto)              — codifica a Base64
#   - base64_decodificar(texto)            — decodifica desde Base64
#   - hex_codificar(texto)                 — codifica a hexadecimal
#   - hex_decodificar(hex)                 — decodifica desde hexadecimal
#   - url_codificar(texto)                 — codifica a URL (percent-encoding)
#   - url_decodificar(texto)               — decodifica desde URL (percent-encoding)
#
# Base64 usa implementación nativa Rust (crate base64).
# Hex y URL son implementados en Forja puro.

clase ErrorCodificacion {
    mensaje: Texto
    codigo: Entero
}

# ═════════════════════════════════════════════════════════════════════════
# BASE64
# ═════════════════════════════════════════════════════════════════════════

# Codifica un texto a Base64
# Implementación nativa Rust (crate base64)
funcion base64_codificar(texto: Texto) -> Texto {
    retornar _base64_codificar(texto)
}

# Decodifica un texto desde Base64
# Retorna Error si el texto no es Base64 válido
funcion base64_decodificar(texto: Texto) -> Resultado<Texto, ErrorCodificacion> {
    variable resultado = _base64_decodificar(texto)
    si (resultado == "") {
        retornar Error(nuevo ErrorCodificacion("Texto base64 inválido", -1))
    }
    retornar Ok(resultado)
}

# ═════════════════════════════════════════════════════════════════════════
# HEXADECIMAL
# ═════════════════════════════════════════════════════════════════════════

# Codifica un texto a hexadecimal (cada byte → 2 dígitos hex)
# Usa dígitos en mayúscula (A-F)
funcion hex_codificar(texto: Texto) -> Texto {
    variable resultado = ""
    variable i = 0
    mientras (i < longitud(texto)) {
        variable codigo = a_codigo(texto[i])
        resultado = resultado + _digito_hex((codigo >> 4) & 15)
        resultado = resultado + _digito_hex(codigo & 15)
        i = i + 1
    }
    retornar resultado
}

# Decodifica un texto hexadecimal a texto plano
# Retorna Error si el texto no es hexadecimal válido
funcion hex_decodificar(hex: Texto) -> Resultado<Texto, ErrorCodificacion> {
    variable resultado = ""
    variable i = 0
    mientras (i < longitud(hex)) {
        variable alto = _hex_a_valor(hex[i])
        variable bajo = _hex_a_valor(hex[i + 1])
        si (alto < 0 || bajo < 0) {
            retornar Error(nuevo ErrorCodificacion("Texto hexadecimal inválido", -2))
        }
        resultado = resultado + a_caracter(alto * 16 + bajo)
        i = i + 2
    }
    retornar Ok(resultado)
}

# ═════════════════════════════════════════════════════════════════════════
# URL (Percent-Encoding)
# ═════════════════════════════════════════════════════════════════════════

# Codifica un texto a URL (percent-encoding)
# Caracteres seguros (no se codifican): letras, dígitos, _, -, ., ~
# Todo lo demás se codifica como %XX
funcion url_codificar(texto: Texto) -> Texto {
    variable resultado = ""
    variable i = 0
    mientras (i < longitud(texto)) {
        variable c = texto[i]
        # Caracteres seguros: letras, dígitos, _, -, ., ~
        si ((c >= "a" && c <= "z") || (c >= "A" && c <= "Z") || (c >= "0" && c <= "9") || c == "_" || c == "-" || c == "." || c == "~") {
            resultado = resultado + c
        } sino {
            variable codigo = a_codigo(c)
            resultado = resultado + "%" + _digito_hex((codigo >> 4) & 15) + _digito_hex(codigo & 15)
        }
        i = i + 1
    }
    retornar resultado
}

# Decodifica un texto desde URL (percent-encoding)
# Convierte %XX a su caracter correspondiente y + a espacio
# Retorna Error si encuentra un % sin 2 dígitos hex válidos
funcion url_decodificar(texto: Texto) -> Resultado<Texto, ErrorCodificacion> {
    variable resultado = ""
    variable i = 0
    mientras (i < longitud(texto)) {
        variable c = texto[i]
        si (c == "+") {
            resultado = resultado + " "
            i = i + 1
        } sino si (c == "%") {
            # Verificar que haya al menos 2 caracteres después del %
            si (i + 2 >= longitud(texto)) {
                retornar Error(nuevo ErrorCodificacion("Texto URL inválido: % sin 2 dígitos hexadecimales", -3))
            }
            variable alto = _hex_a_valor(texto[i + 1])
            variable bajo = _hex_a_valor(texto[i + 2])
            si (alto < 0 || bajo < 0) {
                retornar Error(nuevo ErrorCodificacion("Texto URL inválido: dígito hexadecimal inválido después de %", -3))
            }
            resultado = resultado + a_caracter(alto * 16 + bajo)
            i = i + 3
        } sino {
            resultado = resultado + c
            i = i + 1
        }
    }
    retornar Ok(resultado)
}

# ═════════════════════════════════════════════════════════════════════════
# HELPERS INTERNOS
# ═════════════════════════════════════════════════════════════════════════

# Convierte un dígito (0-15) a su caracter hexadecimal en mayúscula
# 0-9 → '0'-'9', 10-15 → 'A'-'F'
funcion _digito_hex(d: Entero) -> Texto {
    si (d < 10) { retornar a_caracter(48 + d) }
    retornar a_caracter(65 + d - 10)  # A-F mayúscula
}

# Convierte un caracter hexadecimal a su valor numérico (0-15)
# Acepta mayúsculas y minúsculas
# Retorna -1 si el caracter no es un dígito hex válido
funcion _hex_a_valor(c: Texto) -> Entero {
    si (c >= "0" && c <= "9") { retornar a_codigo(c) - 48 }
    si (c >= "A" && c <= "F") { retornar a_codigo(c) - 65 + 10 }
    si (c >= "a" && c <= "f") { retornar a_codigo(c) - 97 + 10 }
    retornar -1
}
