# módulo: matematica
# Descripción: Funciones matemáticas básicas
# 
# Uso: importar "std/matematica"

# Valor absoluto de un número
funcion abs(x) {
    si (x < 0) {
        retornar -x
    }
    retornar x
}

# Retorna el mayor entre dos números
funcion max(a, b) {
    si (a > b) {
        retornar a
    }
    retornar b
}

# Retorna el menor entre dos números
funcion min(a, b) {
    si (a < b) {
        retornar a
    }
    retornar b
}

# Restringe un valor dentro del rango [min, max]
funcion clamp(valor, minimo, maximo) {
    si (valor < minimo) {
        retornar minimo
    }
    si (valor > maximo) {
        retornar maximo
    }
    retornar valor
}

# Calcula base^exp (exponente entero no negativo)
funcion potencia(base, exp) {
    variable resultado = 1
    variable i = 0
    mientras (i < exp) {
        resultado = resultado * base
        i = i + 1
    }
    retornar resultado
}

# Calcula el factorial de n (n!)
funcion factorial(n) {
    si (n <= 1) {
        retornar 1
    }
    retornar n * factorial(n - 1)
}

# Retorna verdadero si n es par
funcion es_par(n) {
    retornar (n % 2) == 0
}

# Retorna verdadero si n es impar
funcion es_impar(n) {
    retornar (n % 2) != 0
}

# Redondea un número al entero más cercano
funcion redondear(x) {
    # Para números positivos: suma 0.5 y trunca
    # Pero como trabajamos con enteros, retornamos x
    retornar x
}

# Suma todos los elementos de un array
funcion suma_array(arr) {
    variable suma = 0
    variable i = 0
    variable largo = arr.length()
    mientras (i < largo) {
        suma = suma + arr[i]
        i = i + 1
    }
    retornar suma
}

# Calcula el promedio de los elementos de un array
funcion promedio(arr) {
    variable suma = suma_array(arr)
    variable largo = arr.length()
    si (largo == 0) {
        retornar 0
    }
    retornar suma / largo
}

# Máximo Común Divisor (algoritmo de Euclides)
funcion mcd(a, b) {
    variable x = a
    variable y = b
    mientras (y > 0) {
        variable temp = y
        variable resto = x - ((x / y) * y)
        y = resto
        x = temp
    }
    retornar x
}

# Mínimo Común Múltiplo
funcion mcm(a, b) {
    si (a == 0 || b == 0) {
        retornar 0
    }
    retornar (a / mcd(a, b)) * b
}

# --- Funciones para tipo Exacto (BigDecimal) ---

# Convierte un entero a Exacto
funcion exacto_desde_entero(n: Entero) -> Exacto {
    retornar n
}

# Convierte un decimal a Exacto (con posible pérdida de precisión)
funcion exacto_desde_decimal(d: Decimal) -> Exacto {
    retornar d
}

# Convierte un texto a Exacto (parsing)
# Ejemplo: exacto_desde_texto("123.456") -> 123.456
funcion exacto_desde_texto(t: Texto) -> Exacto {
    # Dividir por el punto decimal
    variable partes = t.split(".")
    variable largo = partes.length()
    
    # Si no hay punto, convertir entero directamente
    si (largo == 1) {
        variable val: Exacto = 0.0 + a_numero(t)
        retornar val
    }
    
    # Extraer partes antes y después del punto
    variable parte_entera_str = partes[0]
    variable parte_fraccion_str = partes[1]
    
    variable parte_entera = a_numero(parte_entera_str)
    variable parte_fraccion = a_numero(parte_fraccion_str)
    
    # Si la parte entera es negativa, la fracción también debe serlo
    si (parte_entera < 0) {
        parte_fraccion = -parte_fraccion
    }
    
    # Calcular 10^len_fraccion
    variable len_fraccion = parte_fraccion_str.length()
    variable divisor = 1
    variable i = 0
    mientras (i < len_fraccion) {
        divisor = divisor * 10
        i = i + 1
    }
    
    # Construir el Exacto: parte_entera + parte_fraccion / 10^len
    variable val: Exacto = 0.0 + parte_entera
    variable fraccion_exacto: Exacto = 0.0 + parte_fraccion
    val = val + (fraccion_exacto / divisor)
    
    retornar val
}

# Redondea un Exacto a la cantidad de decimales especificada
# Ejemplo: redondear_exacto(123.4567, 2) -> 123.45
funcion redondear_exacto(e: Exacto, decimales: Entero) -> Exacto {
    # Calcular 10^decimales
    variable factor = 1
    variable i = 0
    mientras (i < decimales) {
        factor = factor * 10
        i = i + 1
    }
    
    # Multiplicar, truncar a entero, dividir
    variable temporal: Exacto = e * factor
    variable entero_val = a_numero(temporal)
    
    # Convertir entero a Exacto y dividir
    variable res: Exacto = 0.0
    res = res + entero_val
    retornar res / factor
}

# Valor absoluto de un Exacto
funcion exacto_abs(e: Exacto) -> Exacto {
    si (e >= 0) {
        retornar e
    } sino {
        retornar -e
    }
}

# Potencia de Exacto (exponente entero, exponenciación binaria)
# Calcula base^exp usando el algoritmo de exponenciación binaria rápida
# Ejemplo: exacto_pow(2.0, 3.0) -> 8.0
funcion exacto_pow(base: Exacto, exp: Exacto) -> Exacto {
    # Convertir exponente a entero (trunca si tiene decimales)
    variable n = a_numero(exp)
    variable res: Exacto = 1.0
    variable b: Exacto = base
    
    # Exponenciación binaria: O(log n)
    mientras (n > 0) {
        si ((n % 2) != 0) {
            res = res * b
        }
        n = n / 2
        b = b * b
    }
    
    retornar res
}
