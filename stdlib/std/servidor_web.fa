# modulo: servidor_web
# Descripcion: Servidor HTTP/1.1 completo para Forja
#
# Uso: importar "std/servidor_web"
#
# Nota: Este modulo usa funciones nativas _http_* y _socket_*
#       proporcionadas por la VM de Forja.

# ─── Constantes HTTP ────────────────────────────────────────────────
constante BUFFER_LECTURA = 8192

# ─── Clase ErrorHTTP ────────────────────────────────────────────────
clase ErrorHTTP {
    codigo
    mensaje

    constructor(codigo: Entero, mensaje: Texto) {
        este.codigo = codigo
        este.mensaje = mensaje
    }
}

# ─── Clase SolicitudHTTP ────────────────────────────────────────────
clase SolicitudHTTP {
    metodo
    ruta
    cabeceras
    cuerpo
    parametros
    params_ruta
    ip
    cookies
    archivos

    constructor() {
        este.metodo = "GET"
        este.ruta = "/"
        este.cabeceras = {}
        este.cuerpo = ""
        este.parametros = {}
        este.params_ruta = {}
        este.ip = ""
        este.cookies = {}
        este.archivos = {}
    }
}

# ─── Clase RespuestaHTTP ────────────────────────────────────────────
clase RespuestaHTTP {
    codigo
    cabeceras
    cuerpo
    tipo_contenido

    constructor() {
        este.codigo = 200
        este.cabeceras = {}
        este.cuerpo = ""
        este.tipo_contenido = "text/plain"
    }
}

# ─── Clase ServidorWeb ──────────────────────────────────────────────
clase ServidorWeb {
    _puerto
    _host
    _rutas
    _rutas_params
    _middlewares
    _static_rutas
    _cors
    _corriendo
    _max_cuerpo

    constructor(puerto: Entero) {
        este._puerto = puerto
        este._host = "0.0.0.0"
        este._rutas = {}
        este._rutas_params = {}
        este._middlewares = []
        este._static_rutas = {}
        este._cors = falso
        este._corriendo = falso
        este._max_cuerpo = 10485760
    }
}

# ─── Funciones Helper internas ──────────────────────────────────────

funcion _cabeceras_a_texto(cabeceras) -> Texto {
    variable partes = []
    variable claves = claves_mapa(cabeceras)
    variable i = 0
    mientras (i < longitud(claves)) {
        partes = partes + [claves[i], cabeceras[claves[i]]]
        i = i + 1
    }
    retornar unir(partes, "|")
}

funcion _texto_a_mapa(texto: Texto) {
    variable mapa = {}
    variable partes = dividir(texto, "|")
    variable i = 0
    mientras (i + 1 < longitud(partes)) {
        mapa[partes[i]] = partes[i + 1]
        i = i + 2
    }
    retornar mapa
}

funcion _parsear_cookies(texto_cookie: Texto) {
    variable cookies = {}
    variable partes = dividir(texto_cookie, ";")
    variable i = 0
    mientras (i < longitud(partes)) {
        variable par = dividir(partes[i], "=")
        si (longitud(par) == 2) {
            cookies[recortar(par[0])] = recortar(par[1])
        }
        i = i + 1
    }
    retornar cookies
}

# ─── Funciones de creacion de respuestas ────────────────────────────

funcion html(respuesta, contenido: Texto) {
    respuesta.tipo_contenido = "text/html; charset=utf-8"
    respuesta.cuerpo = contenido
    respuesta.cabeceras["Content-Type"] = respuesta.tipo_contenido
    retornar respuesta
}

funcion texto_plano(respuesta, contenido: Texto) {
    respuesta.tipo_contenido = "text/plain; charset=utf-8"
    respuesta.cuerpo = contenido
    respuesta.cabeceras["Content-Type"] = respuesta.tipo_contenido
    retornar respuesta
}

funcion redirigir(respuesta, url: Texto) {
    respuesta.codigo = 302
    respuesta.cabeceras["Location"] = url
    retornar respuesta
}

funcion error_respuesta(respuesta, codigo: Entero) {
    respuesta.codigo = codigo
    respuesta.tipo_contenido = "text/plain; charset=utf-8"
    respuesta.cuerpo = _http_texto_status(codigo)
    respuesta.cabeceras["Content-Type"] = respuesta.tipo_contenido
    retornar respuesta
}

# ─── Funciones de enrutamiento ──────────────────────────────────────

funcion _registrar_ruta(servidor, metodo: Texto, ruta: Texto, manejador) {
    variable partes_ruta = dividir(ruta, "/")
    variable params_encontrados = []
    variable patron = []
    variable i = 0
    mientras (i < longitud(partes_ruta)) {
        variable parte = partes_ruta[i]
        si (longitud(parte) > 0 && parte[0] == ":") {
            params_encontrados = params_encontrados + [parte[1..]]
            patron = patron + ["(:param)"]
        } sino {
            patron = patron + [parte]
        }
        i = i + 1
    }

    variable patron_str = unir(patron, "/")

    si (servidor._rutas[metodo] == nulo) {
        servidor._rutas[metodo] = {}
        servidor._rutas_params[metodo] = {}
    }

    si (longitud(params_encontrados) > 0) {
        servidor._rutas_params[metodo][patron_str] = {
            "params": params_encontrados,
            "manejador": manejador
        }
    } sino {
        servidor._rutas[metodo][ruta] = manejador
    }
}

funcion get(servidor, ruta: Texto, manejador) {
    _registrar_ruta(servidor, "GET", ruta, manejador)
}

funcion post(servidor, ruta: Texto, manejador) {
    _registrar_ruta(servidor, "POST", ruta, manejador)
}

funcion put(servidor, ruta: Texto, manejador) {
    _registrar_ruta(servidor, "PUT", ruta, manejador)
}

funcion eliminar(servidor, ruta: Texto, manejador) {
    _registrar_ruta(servidor, "DELETE", ruta, manejador)
}

funcion patch(servidor, ruta: Texto, manejador) {
    _registrar_ruta(servidor, "PATCH", ruta, manejador)
}

# ─── Middleware y Configuracion ─────────────────────────────────────

funcion usar(servidor, middleware) {
    servidor._middlewares = servidor._middlewares + [middleware]
}

funcion servir_estaticos(servidor, prefijo: Texto, directorio: Texto) {
    servidor._static_rutas[prefijo] = directorio
}

funcion habilitar_cors(servidor) {
    servidor._cors = verdadero
}

funcion fijar_max_cuerpo(servidor, max_bytes: Entero) {
    servidor._max_cuerpo = max_bytes
}

# ─── Resolucion de rutas ────────────────────────────────────────────

funcion _resolver_ruta(servidor, metodo: Texto, ruta: Texto) {
    variable rutas_metodo = servidor._rutas[metodo]
    si (rutas_metodo != nulo && rutas_metodo[ruta] != nulo) {
        retornar {"manejador": rutas_metodo[ruta], "params": {}}
    }

    variable rutas_params = servidor._rutas_params[metodo]
    si (rutas_params != nulo) {
        variable claves = claves_mapa(rutas_params)
        variable i = 0
        mientras (i < longitud(claves)) {
            variable info = rutas_params[claves[i]]
            variable partes_ruta = dividir(ruta, "/")
            variable partes_clave = dividir(claves[i], "/")

            si (longitud(partes_ruta) == longitud(partes_clave)) {
                variable params_encontrados = {}
                variable coincide = verdadero
                variable j = 0
                variable idx_param = 0
                mientras (j < longitud(partes_ruta)) {
                    variable pr = partes_ruta[j]
                    variable pc = partes_clave[j]
                    si (pc == "(:param)") {
                        si (idx_param < longitud(info["params"])) {
                            params_encontrados[info["params"][idx_param]] = pr
                        }
                        idx_param = idx_param + 1
                    } sino {
                        si (pr != pc) {
                            coincide = falso
                            romper
                        }
                    }
                    j = j + 1
                }
                si (coincide) {
                    retornar {"manejador": info["manejador"], "params": params_encontrados}
                }
            }
            i = i + 1
        }
    }

    retornar nulo
}

# ─── Manejo de solicitudes ──────────────────────────────────────────

funcion _manejar_solicitud(servidor, socket, datos_raw: Texto) {
    variable parseado = _http_parsear_solicitud(datos_raw)
    si (parseado == nulo) {
        retornar
    }

    variable partes = _texto_a_mapa(parseado)
    variable metodo = partes["metodo"]
    variable ruta_completa = partes["ruta"]
    variable cabeceras_texto = partes["cabeceras"]
    variable cuerpo = partes["cuerpo"]

    variable cabeceras_raw = _http_parsear_cabeceras(cabeceras_texto)
    variable cabeceras = {}
    si (cabeceras_raw != -1) {
        cabeceras = _texto_a_mapa(cabeceras_raw)
    }

    variable ruta = ruta_completa
    variable query = ""
    variable pos_q = buscar(ruta_completa, "?")
    si (pos_q >= 0) {
        ruta = ruta_completa[..pos_q]
        query = ruta_completa[pos_q+1..]
    }

    variable parametros = {}
    si (longitud(query) > 0) {
        variable query_parseado = _query_parsear(query)
        si (query_parseado != -1) {
            parametros = _texto_a_mapa(query_parseado)
        }
    }

    variable solicitud = nuevo SolicitudHTTP()
    solicitud.metodo = metodo
    solicitud.ruta = ruta
    solicitud.cabeceras = cabeceras
    solicitud.cuerpo = cuerpo
    solicitud.parametros = parametros

    variable ip_local = _socket_direccion_local(socket)
    solicitud.ip = ip_local

    si (cabeceras["cookie"] != nulo) {
        solicitud.cookies = _parsear_cookies(cabeceras["cookie"])
    }

    si (metodo == "OPTIONS" && servidor._cors) {
        variable res_cors = nuevo RespuestaHTTP()
        res_cors.codigo = 204
        res_cors.cabeceras["Access-Control-Allow-Origin"] = "*"
        res_cors.cabeceras["Access-Control-Allow-Methods"] = "GET, POST, PUT, DELETE, PATCH, OPTIONS"
        res_cors.cabeceras["Access-Control-Allow-Headers"] = "Content-Type, Authorization"
        _enviar_respuesta(socket, res_cors)
        retornar
    }

    variable ruta_info = _resolver_ruta(servidor, metodo, ruta)
    variable manejador = nulo

    si (ruta_info == nulo) {
        variable claves_static = claves_mapa(servidor._static_rutas)
        variable i = 0
        mientras (i < longitud(claves_static)) {
            variable prefijo = claves_static[i]
            si (empieza_con(ruta, prefijo)) {
                variable dir = servidor._static_rutas[prefijo]
                variable ruta_archivo = dir + "/" + ruta[longitud(prefijo)..]
                variable respuesta = nuevo RespuestaHTTP()
                respuesta = error_respuesta(respuesta, 404)
                _enviar_respuesta(socket, respuesta)
                retornar
            }
            i = i + 1
        }

        variable respuesta_404 = nuevo RespuestaHTTP()
        respuesta_404.codigo = 404
        respuesta_404.cuerpo = "Ruta no encontrada: " + metodo + " " + ruta
        respuesta_404.tipo_contenido = "text/plain; charset=utf-8"
        _enviar_respuesta(socket, respuesta_404)
        retornar
    }

    solicitud.params_ruta = ruta_info["params"]
    manejador = ruta_info["manejador"]

    variable respuesta = nuevo RespuestaHTTP()
    variable ejecutar = verdadero
    variable j = 0
    mientras (j < longitud(servidor._middlewares) && ejecutar) {
        variable mw = servidor._middlewares[j]
        variable res_mw = mw(solicitud)
        si (res_mw != nulo) {
            respuesta = res_mw
            ejecutar = falso
        }
        j = j + 1
    }

    si (ejecutar && manejador != nulo) {
        respuesta = manejador(solicitud)
    }

    si (servidor._cors) {
        respuesta.cabeceras["Access-Control-Allow-Origin"] = "*"
        respuesta.cabeceras["Access-Control-Allow-Methods"] = "GET, POST, PUT, DELETE, PATCH, OPTIONS"
        respuesta.cabeceras["Access-Control-Allow-Headers"] = "Content-Type, Authorization"
    }

    _enviar_respuesta(socket, respuesta)
}

# ─── Envio de respuestas ────────────────────────────────────────────

funcion _enviar_respuesta(socket, respuesta) {
    variable cabeceras_mapa = respuesta.cabeceras

    si (respuesta.tipo_contenido != "" && cabeceras_mapa["Content-Type"] == nulo) {
        cabeceras_mapa["Content-Type"] = respuesta.tipo_contenido
    }

    cabeceras_mapa["Server"] = "Forja-Web/1.0"
    cabeceras_mapa["Connection"] = "close"

    variable fecha = _http_fecha_texto(0)
    si (fecha != -1) {
        cabeceras_mapa["Date"] = fecha
    }

    variable cabeceras_texto = _cabeceras_a_texto(cabeceras_mapa)
    variable respuesta_raw = _http_crear_respuesta_raw(respuesta.codigo, cabeceras_texto, respuesta.cuerpo)

    si (respuesta_raw != -1) {
        _socket_enviar(socket, respuesta_raw)
    }
}

# ─── Inicio del servidor ────────────────────────────────────────────

funcion iniciar(servidor) {
    servidor._corriendo = verdadero
    imprimir("Servidor web Forja iniciado en http://" + servidor._host + ":" + a_texto(servidor._puerto) + "/")
    imprimir("Presiona Ctrl+C para detener")

    variable servidor_socket = _socket_tcp_escuchar(servidor._puerto, 128)
    si (servidor_socket == nulo) {
        imprimir("Error al iniciar servidor en puerto " + a_texto(servidor._puerto))
        servidor._corriendo = falso
        retornar
    }

    mientras (servidor._corriendo) {
        variable cliente = _socket_aceptar(servidor_socket)
        si (cliente == nulo) {
            siguiente
        }
        si (cliente == -1) {
            siguiente
        }

        variable datos = _socket_recibir(cliente, BUFFER_LECTURA)
        si (datos == nulo) {
            _socket_cerrar(cliente)
            siguiente
        }
        si (datos == "") {
            _socket_cerrar(cliente)
            siguiente
        }

        _manejar_solicitud(servidor, cliente, datos)
        _socket_cerrar(cliente)
    }

    _socket_cerrar(servidor_socket)
}

funcion detener(servidor) {
    servidor._corriendo = falso
    imprimir("Servidor web detenido")
}
