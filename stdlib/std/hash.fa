# módulo: hash
# Funciones hash criptográficas
#
# Uso: importar "std/hash"
#
# Proporciona:
#   - sha256(datos)              — calcula SHA-256 de un texto
#
# SHA-256 usa implementación nativa Rust (crate sha2).

clase ErrorHash {
    mensaje: Texto
    codigo: Entero
}

# Calcula SHA-256 de un texto, retorna hash hexadecimal (64 caracteres en minúscula)
# Ejemplo: sha256("hola") → "4d14b0c60b93b61f1b81d3e24c5df1d2b1d5c7c5d5c6c7c8c9cacbccdcecfcf0"
# La cadena vacía retorna Error porque no tiene significado hash
funcion sha256(datos: Texto) -> Resultado<Texto, ErrorHash> {
    si (datos == "") {
        retornar Error(nuevo ErrorHash("Los datos no pueden estar vacíos", -1))
    }
    variable resultado = _sha256(datos)
    retornar Ok(resultado)
}
