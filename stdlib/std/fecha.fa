# módulo: fecha
# Funciones de fecha y hora
#
# Uso: importar "std/fecha"

clase ErrorFecha {
    mensaje: Texto
    codigo: Entero

    constructor(mensaje: Texto, codigo: Entero) {
        este.mensaje = mensaje
        este.codigo = codigo
    }
}

# Obtiene componentes como arreglo: [año, mes, dia, hora, minuto, segundo, nombre_dia, nombre_mes]
funcion _comp(ts: Entero) {
    retornar _fecha_desde_timestamp(ts).split("|")
}

# Formatea número con ceros a la izquierda
funcion _fmt(valor, digitos: Entero) -> Texto {
    variable texto = a_texto(valor)
    mientras (longitud(texto) < digitos) {
        texto = "0" + texto
    }
    retornar texto
}

funcion ahora() -> Texto {
    variable ts = tiempo_actual()
    variable c = _fecha_desde_timestamp(ts).split("|")
    retornar _fmt(c[0],4) + "-" + _fmt(c[1],2) + "-" + _fmt(c[2],2) + " " + _fmt(c[3],2) + ":" + _fmt(c[4],2) + ":" + _fmt(c[5],2)
}

funcion hoy() -> Texto {
    variable ts = tiempo_actual()
    variable c = _fecha_desde_timestamp(ts).split("|")
    retornar _fmt(c[0],4) + "-" + _fmt(c[1],2) + "-" + _fmt(c[2],2)
}

funcion hora_actual() -> Texto {
    variable ts = tiempo_actual()
    variable c = _fecha_desde_timestamp(ts).split("|")
    retornar _fmt(c[3],2) + ":" + _fmt(c[4],2) + ":" + _fmt(c[5],2)
}

funcion formatear(ts: Entero, formato: Texto) -> Texto {
    variable c = _fecha_desde_timestamp(ts).split("|")
    variable res = ""
    variable i = 0
    variable n = longitud(formato)
    mientras (i < n) {
        variable ch = formato[i]
        si (ch == "%") {
            i = i + 1
            si (i >= n) { retornar res }
            variable d = formato[i]
            si (d == "Y") { res = res + _fmt(c[0], 4) }
            si (d == "y") { res = res + _fmt(a_numero(c[0]) % 100, 2) }
            si (d == "m") { res = res + _fmt(c[1], 2) }
            si (d == "d") { res = res + _fmt(c[2], 2) }
            si (d == "H") { res = res + _fmt(c[3], 2) }
            si (d == "M") { res = res + _fmt(c[4], 2) }
            si (d == "S") { res = res + _fmt(c[5], 2) }
            si (d == "B") { res = res + c[7] }
            si (d == "A") { res = res + c[6] }
            si (d == "%") { res = res + "%" }
        } sino {
            res = res + ch
        }
        i = i + 1
    }
    retornar res
}

funcion parsear(texto: Texto, formato: Texto) -> Resultado<Entero, ErrorFecha> {
    variable año = 0
    variable mes = 1
    variable dia = 1
    variable hora = 0
    variable minuto = 0
    variable segundo = 0
    variable i = 0
    variable n = longitud(formato)
    variable t = 0
    variable tn = longitud(texto)
    mientras (i < n && t < tn) {
        variable ch = formato[i]
        si (ch == "%") {
            i = i + 1
            si (i >= n) { retornar Error(nuevo ErrorFecha("Formato truncado", 2)) }
            variable d = formato[i]
            si (d == "Y") { si (t+4>tn){retornar Error(nuevo ErrorFecha("corto",1))} año=a_numero(subcadena(texto,t,4)); t=t+4 }
            si (d == "y") { si (t+2>tn){retornar Error(nuevo ErrorFecha("corto",1))} año=2000+a_numero(subcadena(texto,t,2)); t=t+2 }
            si (d == "m") { si (t+2>tn){retornar Error(nuevo ErrorFecha("corto",1))} mes=a_numero(subcadena(texto,t,2)); t=t+2 }
            si (d == "d") { si (t+2>tn){retornar Error(nuevo ErrorFecha("corto",1))} dia=a_numero(subcadena(texto,t,2)); t=t+2 }
            si (d == "H") { si (t+2>tn){retornar Error(nuevo ErrorFecha("corto",1))} hora=a_numero(subcadena(texto,t,2)); t=t+2 }
            si (d == "M") { si (t+2>tn){retornar Error(nuevo ErrorFecha("corto",1))} minuto=a_numero(subcadena(texto,t,2)); t=t+2 }
            si (d == "S") { si (t+2>tn){retornar Error(nuevo ErrorFecha("corto",1))} segundo=a_numero(subcadena(texto,t,2)); t=t+2 }
            si (d == "%") { si (t < tn && texto[t] == "%") { t = t + 1 } }
        } sino {
            si (t < tn && texto[t] == ch) { t = t + 1 }
            sino { retornar Error(nuevo ErrorFecha("No coincide", 1)) }
        }
        i = i + 1
    }
    retornar Ok(_fecha_a_timestamp(año, mes, dia, hora, minuto, segundo))
}

funcion formato_largo(ts: Entero) -> Texto {
    variable c = _fecha_desde_timestamp(ts).split("|")
    retornar a_texto(c[2]) + " de " + c[7] + " de " + a_texto(c[0])
}

funcion formato_corto(ts: Entero) -> Texto {
    variable c = _fecha_desde_timestamp(ts).split("|")
    retornar _fmt(c[2],2) + "/" + _fmt(c[1],2) + "/" + _fmt(c[0],4)
}
