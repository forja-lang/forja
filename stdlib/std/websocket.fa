# modulo: websocket
# Descripcion: WebSocket (RFC 6455) para Forja
#
# Uso: importar "std/websocket"
#
# Nota: Usa funciones nativas _ws_* y _socket_*

# ─── Constantes WebSocket ──────────────────────────────────────────
constante OP_CONTINUACION = 0
constante OP_TEXTO = 1
constante OP_BINARIO = 2
constante OP_CERRAR = 8
constante OP_PING = 9
constante OP_PONG = 10
constante WS_BUFFER = 8192

# ─── Clase FrameWS ─────────────────────────────────────────────────
clase FrameWS {
    opcode
    datos
    fin
    longitud

    constructor() {
        este.opcode = OP_TEXTO
        este.datos = ""
        este.fin = verdadero
        este.longitud = 0
    }
}

funcion _frame_completo(opcode, datos, fin) {
    variable f = nuevo FrameWS()
    f.opcode = opcode
    f.datos = datos
    f.fin = fin
    f.longitud = longitud(datos)
    retornar f
}

    funcion es_texto() -> Booleano {
        retornar este.opcode == OP_TEXTO
    }

    funcion es_binario() -> Booleano {
        retornar este.opcode == OP_BINARIO
    }

    funcion es_cierre() -> Booleano {
        retornar este.opcode == OP_CERRAR
    }

    funcion es_ping() -> Booleano {
        retornar este.opcode == OP_PING
    }

    funcion es_pong() -> Booleano {
        retornar este.opcode == OP_PONG
    }
}

# ─── Clase ConexionWS ──────────────────────────────────────────────
clase ConexionWS {
    _socket
    _abierta
    _ultimo_ping

    constructor() {
        este._socket = nulo
        este._abierta = falso
        este._ultimo_ping = ""
    }

    # ─── Handshake Servidor ───────────────────────────────────────────────
    funcion aceptar_conexion(socket, key: Texto) -> Booleano {
        variable accept_key = _ws_handshake_aceptar(key)
        si (accept_key == nulo || accept_key == -1) {
            retornar falso
        }

        variable respuesta = "HTTP/1.1 101 Switching Protocols\r\n"
        respuesta = respuesta + "Upgrade: websocket\r\n"
        respuesta = respuesta + "Connection: Upgrade\r\n"
        respuesta = respuesta + "Sec-WebSocket-Accept: " + accept_key + "\r\n\r\n"

        variable resultado = _socket_enviar(socket, respuesta)
        si (resultado == nulo) {
            retornar falso
        }

        este._socket = socket
        este._abierta = verdadero
        retornar verdadero
    }

    # ─── Handshake Cliente ────────────────────────────────────────────────
    funcion conectar(host: Texto, puerto: Entero, ruta: Texto) -> Booleano {
        variable socket = _socket_tcp_conectar(host, puerto)
        si (socket == nulo) {
            retornar falso
        }
        _socket_fijar_timeout(socket, 5000)

        variable key_raw = ""
        variable i = 0
        mientras (i < 16) {
            key_raw = key_raw + caracter(_aleatorio_entero(255))
            i = i + 1
        }
        variable key = _base64_codificar(key_raw)

        variable solicitud = "GET " + ruta + " HTTP/1.1\r\n"
        solicitud = solicitud + "Host: " + host + ":" + a_texto(puerto) + "\r\n"
        solicitud = solicitud + "Upgrade: websocket\r\n"
        solicitud = solicitud + "Connection: Upgrade\r\n"
        solicitud = solicitud + "Sec-WebSocket-Key: " + key + "\r\n"
        solicitud = solicitud + "Sec-WebSocket-Version: 13\r\n\r\n"

        _socket_enviar(socket, solicitud)

        variable respuesta = ""
        variable intento = 0
        mientras (intento < 100) {
            variable datos = _socket_recibir(socket, WS_BUFFER)
            si (datos == nulo || datos == "") {
                romper
            }
            respuesta = respuesta + datos
            si (contiene(respuesta, "\r\n\r\n")) {
                romper
            }
            intento = intento + 1
        }

        si (empieza_con(respuesta, "HTTP/1.1 101")) {
            este._socket = socket
            este._abierta = verdadero
            retornar verdadero
        }

        _socket_cerrar(socket)
        retornar falso
    }

    # ─── Enviar Frame ─────────────────────────────────────────────────────
    funcion enviar_frame(opcode: Entero, datos: Texto) -> Booleano {
        si (!este._abierta) {
            retornar falso
        }

        variable frame = _ws_frame_codificar(datos, opcode, verdadero)
        si (frame == nulo) {
            retornar falso
        }

        variable resultado = _socket_enviar(este._socket, frame)
        si (resultado == nulo) {
            este._abierta = falso
            retornar falso
        }
        retornar verdadero
    }

    # ─── Enviar Texto ─────────────────────────────────────────────────────
    funcion enviar_texto(mensaje: Texto) -> Booleano {
        retornar este.enviar_frame(OP_TEXTO, mensaje)
    }

    # ─── Enviar Binario ───────────────────────────────────────────────────
    funcion enviar_binario(datos: Texto) -> Booleano {
        retornar este.enviar_frame(OP_BINARIO, datos)
    }

    # ─── Enviar Ping ──────────────────────────────────────────────────────
    funcion enviar_ping() -> Booleano {
        este._ultimo_ping = "ping"
        retornar este.enviar_frame(OP_PING, "ping")
    }

    # ─── Enviar Pong ──────────────────────────────────────────────────────
    funcion enviar_pong() -> Booleano {
        retornar este.enviar_frame(OP_PONG, "pong")
    }

    # ─── Recibir Frame ───────────────────────────────────────────────────
    funcion recibir_frame() {
        si (!este._abierta) {
            retornar nulo
        }

        variable datos = _socket_recibir(este._socket, WS_BUFFER)
        si (datos == nulo || datos == "") {
            este._abierta = falso
            retornar nulo
        }

        variable parseado = _ws_frame_decodificar(datos)
        si (parseado == nulo || parseado == -1) {
            retornar nulo
        }

        variable frame = nuevo FrameWS()
        variable partes = _texto_a_mapa(parseado)
        frame.opcode = a_entero(partes["opcode"])
        frame.datos = partes["datos"]
        frame.fin = partes["fin"] == "true"
        frame.longitud = a_entero(partes["longitud"])

        si (frame.es_ping()) {
            este.enviar_frame(OP_PONG, frame.datos)
        }

        retornar frame
    }

    # ─── Recibir Texto ───────────────────────────────────────────────────
    funcion recibir_texto() -> Texto {
        variable frame = este.recibir_frame()
        si (frame == nulo) {
            retornar ""
        }
        retornar frame.datos
    }

    # ─── Recibir hasta recibir texto ─────────────────────────────────────
    funcion recibir_texto_ignorando() -> Texto {
        mientras (este._abierta) {
            variable frame = este.recibir_frame()
            si (frame == nulo) {
                retornar ""
            }
            si (frame.es_texto()) {
                retornar frame.datos
            }
            si (frame.es_cierre()) {
                este._abierta = falso
                retornar ""
            }
        }
        retornar ""
    }

    # ─── Cerrar Conexion ────────────────────────────────────────────────
    funcion cerrar(mensaje: Texto) {
        si (este._abierta) {
            este.enviar_frame(OP_CERRAR, mensaje)
            este._abierta = falso
        }
        si (este._socket != nulo) {
            _socket_cerrar(este._socket)
        }
    }

    # ─── Estado ──────────────────────────────────────────────────────────
    funcion esta_abierta() -> Booleano {
        retornar este._abierta
    }
}

# ─── Funciones auxiliares ──────────────────────────────────────────

funcion _texto_a_mapa(texto: Texto) {
    variable mapa = {}
    variable partes = dividir(texto, "|")
    variable i = 0
    mientras (i + 1 < longitud(partes)) {
        mapa[partes[i]] = partes[i + 1]
        i = i + 2
    }
    retornar mapa
}

# ─── API de alto nivel (conveniencia) ──────────────────────────────

funcion aceptar(socket, cabeceras) {
    variable key = cabeceras["sec-websocket-key"]
    si (key == nulo) {
        key = cabeceras["Sec-WebSocket-Key"]
    }
    si (key == nulo) {
        retornar nulo
    }

    variable ws = nuevo ConexionWS()
    si (ws.aceptar_conexion(socket, key)) {
        retornar ws
    }
    retornar nulo
}

funcion conectar(url: Texto) {
    variable resto = url
    variable host = ""
    variable puerto = 80
    variable ruta = "/"

    si (empieza_con(url, "wss://")) {
        puerto = 443
        resto = url[6..]
    } sino {
        si (empieza_con(url, "ws://")) {
            resto = url[5..]
        } sino {
            retornar nulo
        }
    }

    variable pos_barra = buscar(resto, "/")
    variable host_parte = resto
    si (pos_barra >= 0) {
        host_parte = resto[..pos_barra]
        ruta = resto[pos_barra..]
    }

    variable pos_dos_puntos = buscar(host_parte, ":")
    si (pos_dos_puntos >= 0) {
        host = host_parte[..pos_dos_puntos]
        puerto = a_entero(host_parte[pos_dos_puntos + 1..])
    } sino {
        host = host_parte
    }

    variable ws = nuevo ConexionWS()
    si (ws.conectar(host, puerto, ruta)) {
        retornar ws
    }
    retornar nulo
}
