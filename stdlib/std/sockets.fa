# módulo: sockets
# Soporte nativo de sockets TCP/UDP para Forja
# Proporciona una API segura y robusta para comunicación en red
#
# Las funciones internas _socket_* son proporcionadas por la VM
# y no deben llamarse directamente desde código de usuario.
#
# Uso: importar "std/sockets"

importar "std/resultado"

# ══════════════════════════════════════════════════════════════════════
# Tipos de Error
# ══════════════════════════════════════════════════════════════════════

# Representa un error en operaciones de red
# Contiene un mensaje descriptivo y un código numérico
clase ErrorConexion {
    mensaje: Texto
    codigo: Entero

    constructor(mensaje: Texto, codigo: Entero) {
        este.mensaje = mensaje
        este.codigo = codigo
    }
}

# ══════════════════════════════════════════════════════════════════════
# Constantes
# ══════════════════════════════════════════════════════════════════════

# Tiempo de espera por defecto en segundos para operaciones de red
constante TIMEOUT_DEFECTO = 30

# Máximo de conexiones en cola de espera para servidores TCP
constante BACKLOG_DEFECTO = 128

# Tamaño de buffer por defecto para recibir datos (4 KB)
constante BUFFER_TAMANO = 4096

# ══════════════════════════════════════════════════════════════════════
# Funciones Auxiliares Internas
# ══════════════════════════════════════════════════════════════════════

# Crea un ErrorConexion con mensaje y código
funcion _error_conexion(mensaje: Texto, codigo: Entero) -> ErrorConexion {
    variable err = nuevo ErrorConexion(mensaje, codigo)
    retornar err
}

# Valida que un puerto esté en rango (1-65535)
funcion _puerto_valido(puerto: Entero) -> Booleano {
    retornar puerto >= 1 && puerto <= 65535
}

# Valida que un tamaño de buffer esté en rango (1-65536)
funcion _tamano_valido(tamano: Entero) -> Booleano {
    retornar tamano > 0 && tamano <= 65536
}

# ══════════════════════════════════════════════════════════════════════
# TCP Cliente
# ══════════════════════════════════════════════════════════════════════

# Conecta a un servidor TCP usando el timeout por defecto (30 segundos).
#
# Parámetros:
#   direccion: IP o nombre de host (ej: "192.168.1.1", "google.com")
#   puerto: número de puerto (1-65535)
#
# Retorna: Ok(socket) si se conectó exitosamente,
#          Error(ErrorConexion) si falló la conexión.
#
# Ejemplo:
#   variable socket = conectar("google.com", 80)?
#   # socket listo para enviar/recibir
funcion conectar(direccion: Texto, puerto: Entero) -> Resultado<Entero, ErrorConexion> {
    si (no _puerto_valido(puerto)) {
        retornar Error(_error_conexion("puerto_invalido: debe estar entre 1 y 65535", -2))
    }

    variable socket = _socket_tcp_conectar(direccion, puerto)
    retornar Ok(socket)
}

# Conecta a un servidor TCP con timeout personalizado en milisegundos.
#
# Parámetros:
#   direccion: IP o nombre de host
#   puerto: número de puerto (1-65535)
#   timeout_ms: tiempo máximo de espera en milisegundos (>= 0)
#
# Retorna: Ok(socket) o Error(ErrorConexion)
funcion conectar_con_timeout(direccion: Texto, puerto: Entero, timeout_ms: Entero) -> Resultado<Entero, ErrorConexion> {
    si (no _puerto_valido(puerto)) {
        retornar Error(_error_conexion("puerto_invalido: debe estar entre 1 y 65535", -2))
    }
    si (timeout_ms < 0) {
        retornar Error(_error_conexion("timeout_invalido: debe ser >= 0", -4))
    }

    variable socket = _socket_tcp_conectar(direccion, puerto)
    retornar Ok(socket)
}

# Envía datos por un socket TCP conectado.
#
# Parámetros:
#   socket: el socket obtenido de conectar()
#   datos: texto a enviar
#
# Retorna: Ok(cantidad de bytes enviados) o Error(ErrorConexion)
#
# Ejemplo:
#   variable bytes = enviar(socket, "Hola servidor!")
#   # bytes contiene la cantidad de datos enviados
funcion enviar(socket, datos: Texto) -> Resultado<Entero, ErrorConexion> {
    variable bytes = _socket_enviar(socket, datos)
    retornar Ok(bytes)
}

# Recibe datos de un socket TCP conectado.
#
# Parámetros:
#   socket: el socket obtenido de conectar()
#   tamano: tamaño máximo del buffer (1-65536)
#
# Retorna: Ok(datos recibidos como Texto) o Error(ErrorConexion)
#          Si el peer cerró la conexión, retorna Ok("")
#
# Ejemplo:
#   variable respuesta = recibir(socket, 4096)
#   si (longitud(respuesta) > 0) {
#       imprimir("Recibido: " + respuesta)
#   }
funcion recibir(socket, tamano: Entero) -> Resultado<Texto, ErrorConexion> {
    si (no _tamano_valido(tamano)) {
        retornar Error(_error_conexion("tamano_invalido: debe estar entre 1 y 65536", -3))
    }

    variable datos = _socket_recibir(socket, tamano)
    retornar Ok(datos)
}

# Recibe datos usando el tamaño de buffer por defecto (4096 bytes).
#
# Parámetros:
#   socket: el socket obtenido de conectar()
#
# Retorna: Ok(datos) o Error(ErrorConexion)
funcion recibir_simple(socket) -> Resultado<Texto, ErrorConexion> {
    variable datos = _socket_recibir(socket, BUFFER_TAMANO)
    retornar Ok(datos)
}

# Cierra un socket TCP (cliente o servidor).
#
# Es seguro llamar a cerrar múltiples veces sobre el mismo socket.
# Una vez cerrado, el socket no puede reutilizarse.
#
# Parámetros:
#   socket: el socket a cerrar
#
# Retorna: Ok(verdadero) si se cerró correctamente,
#          Error(ErrorConexion) si ocurrió un error
funcion cerrar(socket) -> Resultado<Booleano, ErrorConexion> {
    _socket_cerrar(socket)
    retornar Ok(verdadero)
}

# ══════════════════════════════════════════════════════════════════════
# TCP Servidor
# ══════════════════════════════════════════════════════════════════════

# Crea un servidor TCP que escucha en el puerto especificado.
#
# El servidor acepta conexiones entrantes usando la función aceptar().
# Por defecto, se usa un backlog de 128 conexiones en cola.
#
# Parámetros:
#   puerto: número de puerto (1-65535)
#
# Retorna: Ok(servidor) si se pudo iniciar la escucha,
#          Error(ErrorConexion) si falló (ej: puerto ocupado)
#
# Ejemplo:
#   variable servidor = escuchar(8080)?
#   variable cliente = aceptar(servidor)?
funcion escuchar(puerto: Entero) -> Resultado<Entero, ErrorConexion> {
    si (no _puerto_valido(puerto)) {
        retornar Error(_error_conexion("puerto_invalido: debe estar entre 1 y 65535", -2))
    }

    variable servidor = _socket_tcp_escuchar(puerto, BACKLOG_DEFECTO)
    retornar Ok(servidor)
}

# Crea un servidor TCP con backlog personalizado.
#
# El backlog define la cantidad máxima de conexiones que pueden
# esperar en cola antes de ser aceptadas.
#
# Parámetros:
#   puerto: número de puerto (1-65535)
#   backlog: máx. conexiones en cola (>= 1)
#
# Retorna: Ok(servidor) o Error(ErrorConexion)
funcion escuchar_con_backlog(puerto: Entero, backlog: Entero) -> Resultado<Entero, ErrorConexion> {
    si (no _puerto_valido(puerto)) {
        retornar Error(_error_conexion("puerto_invalido: debe estar entre 1 y 65535", -2))
    }
    si (backlog < 1) {
        retornar Error(_error_conexion("backlog_invalido: debe ser >= 1", -5))
    }

    variable servidor = _socket_tcp_escuchar(puerto, backlog)
    retornar Ok(servidor)
}

# Acepta una conexión entrante en el servidor.
#
# Esta función es bloqueante: espera hasta que un cliente se conecte.
# Si no hay conexiones pendientes, retorna Error con código -6.
#
# Parámetros:
#   servidor: el socket servidor obtenido de escuchar()
#
# Retorna: Ok(cliente) para comunicarse con el cliente conectado,
#          Error(ErrorConexion) si no hay conexiones pendientes
#
# Ejemplo:
#   variable cliente = aceptar(servidor)
#   coincidir cliente {
#       caso c -> {
#           variable datos = recibir(c, 1024)?
#           # procesar datos...
#           cerrar(c)
#       }
#       caso err -> {
#           imprimir("Error: " + err.mensaje)
#       }
#   }
funcion aceptar(servidor) -> Resultado<Entero, ErrorConexion> {
    variable cliente = _socket_aceptar(servidor)
    si (cliente == -1) {
        retornar Error(_error_conexion("sin_conexiones_pendientes", -6))
    }
    retornar Ok(cliente)
}

# ══════════════════════════════════════════════════════════════════════
# UDP
# ══════════════════════════════════════════════════════════════════════

# Crea un socket UDP para escuchar en un puerto.
#
# Si se especifica puerto = 0, el sistema operativo asigna
# un puerto disponible automáticamente.
#
# Parámetros:
#   puerto: número de puerto (0 = asignado por SO, 1-65535)
#
# Retorna: Ok(socket UDP) o Error(ErrorConexion)
#
# Ejemplo:
#   variable socket = udp_escuchar(0)?
#   # socket UDP listo para enviar/recibir
funcion udp_escuchar(puerto: Entero) -> Resultado<Entero, ErrorConexion> {
    si (puerto < 0 || puerto > 65535) {
        retornar Error(_error_conexion("puerto_invalido: debe estar entre 0 y 65535", -2))
    }

    variable socket = _socket_udp_escuchar(puerto)
    retornar Ok(socket)
}

# Envía datos por UDP a una dirección específica.
#
# A diferencia de TCP, UDP no requiere conexión previa.
# Los datos se envían como datagramas individuales.
#
# Parámetros:
#   socket: socket UDP obtenido de udp_escuchar()
#   datos: texto a enviar
#   direccion: IP o nombre de host destino
#   puerto: puerto destino (1-65535)
#
# Retorna: Ok(cantidad de bytes enviados) o Error(ErrorConexion)
funcion udp_enviar(socket, datos: Texto, direccion: Texto, puerto: Entero) -> Resultado<Entero, ErrorConexion> {
    si (no _puerto_valido(puerto)) {
        retornar Error(_error_conexion("puerto_invalido: debe estar entre 1 y 65535", -2))
    }

    variable bytes = _socket_udp_enviar(socket, datos, direccion, puerto)
    retornar Ok(bytes)
}

# Recibe datos por UDP.
#
# UDP es orientado a datagramas: cada llamada a udp_recibir
# obtiene un datagrama completo enviado por un peer.
#
# Parámetros:
#   socket: socket UDP obtenido de udp_escuchar()
#   tamano: tamaño máximo del buffer (1-65536)
#
# Retorna: Ok(datos recibidos como Texto) o Error(ErrorConexion)
funcion udp_recibir(socket, tamano: Entero) -> Resultado<Texto, ErrorConexion> {
    si (no _tamano_valido(tamano)) {
        retornar Error(_error_conexion("tamano_invalido: debe estar entre 1 y 65536", -3))
    }

    variable datos = _socket_udp_recibir(socket, tamano)
    retornar Ok(datos)
}

# Recibe datos UDP usando el tamaño de buffer por defecto (4096 bytes).
#
# Parámetros:
#   socket: socket UDP obtenido de udp_escuchar()
#
# Retorna: Ok(datos) o Error(ErrorConexion)
funcion udp_recibir_simple(socket) -> Resultado<Texto, ErrorConexion> {
    variable datos = _socket_udp_recibir(socket, BUFFER_TAMANO)
    retornar Ok(datos)
}

# ══════════════════════════════════════════════════════════════════════
# Utilidades
# ══════════════════════════════════════════════════════════════════════

# Verifica si un socket está válido y conectado.
#
# Útil para comprobar el estado de un socket antes de usarlo.
#
# Parámetros:
#   socket: el socket a verificar
#
# Retorna: verdadero si el socket está activo y conectado,
#          falso si fue cerrado o es inválido
funcion es_valido(socket) -> Booleano {
    retornar _socket_activo(socket)
}

# Obtiene información completa del socket (direcciones local y remota).
#
# Parámetros:
#   socket: el socket a consultar
#
# Retorna: Ok(texto con "local: IP:puerto, remoto: IP:puerto")
#          o Error(ErrorConexion) si no se puede obtener la info
funcion obtener_info(socket) -> Resultado<Texto, ErrorConexion> {
    variable local = _socket_direccion_local(socket)
    variable remota = _socket_direccion_remota(socket)
    variable info = "local: " + local + ", remoto: " + remota
    retornar Ok(info)
}

# Obtiene la dirección local del socket (IP:puerto local).
#
# Parámetros:
#   socket: el socket a consultar
#
# Retorna: Ok(dirección local como Texto) o Error(ErrorConexion)
funcion direccion_local(socket) -> Resultado<Texto, ErrorConexion> {
    variable local = _socket_direccion_local(socket)
    retornar Ok(local)
}

# Obtiene la dirección remota del socket (IP:puerto del peer).
#
# Solo aplica a sockets TCP conectados.
# Para servidores y sockets UDP, puede no estar disponible.
#
# Parámetros:
#   socket: el socket a consultar
#
# Retorna: Ok(dirección remota como Texto) o Error(ErrorConexion)
funcion direccion_remota(socket) -> Resultado<Texto, ErrorConexion> {
    variable remota = _socket_direccion_remota(socket)
    retornar Ok(remota)
}

# Configura el timeout de lectura/escritura de un socket.
#
# Parámetros:
#   socket: el socket a configurar
#   segundos: timeout en segundos (0 = espera infinita)
#
# Retorna: Ok(verdadero) si se configuró correctamente,
#          Error(ErrorConexion) si el timeout es inválido
#
# Ejemplo:
#   configurar_timeout(socket, 10)?  # 10 segundos de timeout
funcion configurar_timeout(socket, segundos: Entero) -> Resultado<Booleano, ErrorConexion> {
    si (segundos < 0) {
        retornar Error(_error_conexion("timeout_invalido: debe ser >= 0", -4))
    }

    _socket_fijar_timeout(socket, segundos * 1000)
    retornar Ok(verdadero)
}
