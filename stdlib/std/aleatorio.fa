# módulo: aleatorio
# Generación de números aleatorios (xorshift32)
#
# Uso: importar "std/aleatorio"
#
# Proporciona:
#   - semilla(valor)    — establece la semilla del generador
#   - entero(max)       — entero aleatorio en [0, max)
#   - decimal()         — decimal aleatorio en [0.0, 1.0)
#   - elemento(arr)     — elemento aleatorio de un arreglo
#   - mezclar(arr)      — mezcla aleatoria (Fisher-Yates) de un arreglo
#
# Implementación nativa: xorshift32 — rápido, simple, buena distribución
# para uso no criptográfico.

# Establece la semilla del generador aleatorio
# Útil para obtener secuencias reproducibles
funcion semilla(valor: Entero) {
    _aleatorio_semilla(valor)
}

# Retorna un entero aleatorio en [0, max)
# Implementación nativa xorshift32
funcion entero(max: Entero) -> Entero {
    retornar _aleatorio_entero(max)
}

# Retorna un decimal aleatorio en [0.0, 1.0)
# Usa entero(max=1000000) y divide para obtener precisión de 6 decimales
funcion decimal() -> Decimal {
    variable max = 1000000
    variable val = entero(max)
    retornar val / 1000000.0
}

# Retorna un elemento aleatorio de un arreglo
# El arreglo debe tener al menos un elemento
funcion elemento(arr) {
    variable idx = entero(longitud(arr))
    retornar arr[idx]
}

# Retorna un arreglo mezclado aleatoriamente (algoritmo Fisher-Yates)
# No modifica el arreglo original; retorna una copia mezclada
funcion mezclar(arr) {
    variable res = arr  # copia superficial
    variable i = longitud(res) - 1
    mientras (i > 0) {
        variable j = entero(i + 1)
        variable temp = res[i]
        res[i] = res[j]
        res[j] = temp
        i = i - 1
    }
    retornar res
}
