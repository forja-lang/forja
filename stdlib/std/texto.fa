# módulo: texto
# Descripción: Funciones de manipulación de texto

funcion longitud_texto(s) {
    retornar longitud(s)
}

funcion a_mayusculas(s) {
    # Itera sobre cada caracter y convierte a mayúscula
    variable resultado = ""
    variable i = 0
    mientras (i < longitud(s)) {
        variable c = s[i]
        si (c >= "a" && c <= "z") {
            # Convertir a mayúscula: resta 32 en ASCII
            variable codigo = a_codigo(c) - 32
            resultado = resultado + a_caracter(codigo)
        } sino {
            resultado = resultado + c
        }
        i = i + 1
    }
    retornar resultado
}

funcion a_minusculas(s) {
    variable resultado = ""
    variable i = 0
    mientras (i < longitud(s)) {
        variable c = s[i]
        si (c >= "A" && c <= "Z") {
            variable codigo = a_codigo(c) + 32
            resultado = resultado + a_caracter(codigo)
        } sino {
            resultado = resultado + c
        }
        i = i + 1
    }
    retornar resultado
}

funcion capitalizar(s) {
    si (longitud(s) == 0) {
        retornar s
    }
    variable primero = a_mayusculas(s[0])
    variable resto = subcadena(s, 1, longitud(s) - 1)
    retornar primero + resto
}

funcion invertir(s) {
    variable resultado = ""
    variable i = longitud(s) - 1
    mientras (i >= 0) {
        resultado = resultado + s[i]
        i = i - 1
    }
    retornar resultado
}

funcion contar_ocurrencias(texto, patron) {
    variable contador = 0
    variable i = 0
    variable lp = longitud(patron)
    mientras (i <= longitud(texto) - lp) {
        si (subcadena(texto, i, lp) == patron) {
            contador = contador + 1
            i = i + lp
        } sino {
            i = i + 1
        }
    }
    retornar contador
}

funcion esta_vacio(s) {
    retornar longitud(s) == 0
}

funcion repetir_texto(s, veces) {
    variable resultado = ""
    variable i = 0
    mientras (i < veces) {
        resultado = resultado + s
        i = i + 1
    }
    retornar resultado
}

funcion contiene(texto, patron) {
    retornar contar_ocurrencias(texto, patron) > 0
}

funcion reemplazar(texto, original, nuevo) {
    variable resultado = ""
    variable i = 0
    variable lo = longitud(original)
    mientras (i < longitud(texto)) {
        si (subcadena(texto, i, lo) == original) {
            resultado = resultado + nuevo
            i = i + lo
        } sino {
            resultado = resultado + texto[i]
            i = i + 1
        }
    }
    retornar resultado
}

funcion trim(s) {
    variable inicio = 0
    variable fin = longitud(s) - 1
    mientras (inicio <= fin && (s[inicio] == " " || s[inicio] == "\t" || s[inicio] == "\n")) {
        inicio = inicio + 1
    }
    mientras (fin >= inicio && (s[fin] == " " || s[fin] == "\t" || s[fin] == "\n")) {
        fin = fin - 1
    }
    retornar subcadena(s, inicio, fin - inicio + 1)
}
