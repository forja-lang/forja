      <tr><td><strong>Lexer + Parser</strong></td><td>Recursive Descent</td><td><code>src/lexer.rs</code>, <code>src/parser.rs</code></td></tr>
      <tr><td><strong>Semántica</strong></td><td>Type Checker + Borrow Checker</td><td><code>src/semantics.rs</code></td></tr>
      <tr><td><strong>Bytecode</strong></td><td>40+ opcodes stack-based</td><td><code>src/bytecode.rs</code> (1206 líneas)</td></tr>
      <tr><td><strong>Micro-opcodes</strong></td><td>Expansión + optimización de opcodes</td><td><code>src/uops.rs</code> (463 líneas)</td></tr>
      <tr><td><strong>VM v1</strong></td><td>Stack-based original</td><td><code>src/vm.rs</code> (2038 líneas)</td></tr>
      <tr><td><strong>VM v3 Opt</strong></td><td>Índices numéricos, buffer de output</td><td><code>src/vm_opt.rs</code> (1091 líneas)</td></tr>
