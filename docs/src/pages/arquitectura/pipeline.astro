  <h2>API pГәblica (lib.rs)</h2>

  <p>Estas son las funciones principales que expone la biblioteca:</p>

  <div class="code-block-wrapper">
    <div class="code-header"><span>рҹ“„ API de compilaciГіn</span></div>
    <pre><code><span class="co">/// Compila .fa вҶ’ cГіdigo Rust</span>
<span class="kw">pub fn</span> compilar(source: &str) -> Result&#60;String, Vec&#60;ErrorForja&#62;&#62; &lbrace;
    <span class="kw">let mut</span> lexer = lexer::Lexer::new(source);
    <span class="kw">let</span> tokens = lexer.tokenize()?;
    <span class="kw">let mut</span> parser = parser::Parser::new(tokens);
    <span class="kw">let</span> programa = parser.parse()?;
    <span class="kw">let mut</span> type_checker = semantics::TypeChecker::new();
    type_checker.analizar(&programa)?;
    <span class="kw">let mut</span> checker = semantics::BorrowChecker::new();
    checker.analizar(&programa)?;
    <span class="kw">let mut</span> transpiler = transpiler::Transpiler::new();
    <span class="kw">let</span> rust_code = transpiler.transpilar(&programa)?;
    Ok(rust_code)
&rbrace;

<span class="co">/// Ejecuta .fa en la VM</span>
<span class="kw">pub fn</span> ejecutar(source: &str) -> Result&#60;Vec&#60;String&#62;, String&#62; &lbrace;
    <span class="co">// ... lexer + parser (igual) ...</span>
    <span class="kw">let mut</span> gen = BytecodeGenerator::new();
    <span class="kw">let</span> bytecode = gen.generar(&programa)?;
    <span class="kw">let mut</span> vm = ForjaVM::new();
    vm.cargar_bytecode(bytecode);
    vm.ejecutar()?;
    Ok(vm.obtener_output().to_vec())
&rbrace;</code></pre>
