    <tr><td>4b. Borrow Checker</td><td><code>semantics.rs</code></td><td>Programa (AST)</td><td>AST verificado</td></tr>
    <tr><td>5a. Transpilador</td><td><code>transpiler.rs</code></td><td>Programa (AST)</td><td>CГіdigo Rust</td></tr>
