---
import Layout from '../layouts/Layout.astro';
---

<Layout title="Playground — Forja">
  <h1>Playground interactivo</h1>

  <p>Escribí código Forja en el editor, ejecutalo en la VM y mirá el resultado en vivo.</p>

  <div class="playground-layout">
    <div class="editor-panel">
      <div class="panel-header">
        <span>📝 Código Forja (.fa)</span>
        <div class="panel-actions">
          <label class="live-toggle" title="Ejecutar automáticamente al escribir">
            <span class="live-label">Live</span>
            <input type="checkbox" id="liveSwitch" checked>
            <span class="toggle-track"><span class="toggle-thumb"></span></span>
          </label>
          <button id="btnRun" class="btn-run">▶ Ejecutar</button>
          <button id="btnClear" class="btn-clear">🗑 Limpiar</button>
        </div>
      </div>
      <textarea id="codigo" class="editor" spellcheck="false" placeholder='Escribí tu código Forja acá'>escribir("¡Hola, mundo desde Forja!")</textarea>
    </div>
    <div class="output-panel">
      <div class="panel-header">
        <span>📋 Output</span>
        <span id="status" class="status-idle">✓ listo</span>
      </div>
      <div id="output" class="output">
        <span class="placeholder">Presioná ▶ Ejecutar para correr el código</span>
      </div>
    </div>
  </div>

  <h2>Ejemplos rápidos</h2>

  <div class="example-buttons">
    <button class="example-btn" data-code='escribir("¡Hola, mundo desde Forja!")'>Hola Mundo</button>
    <button class="example-btn" data-code='variable nombre = "Gaucho"\nvariable edad = 30\nescribir("Nombre: " + nombre)\nescribir("Edad: " + edad)'>Variables</button>
    <button class="example-btn" data-code='funcion suma(a, b) {\n    retornar a + b\n}\nescribir("2 + 3 = " + suma(2, 3))'>Función</button>
    <button class="example-btn" data-code='clase P {\n    nombre\n    constructor(n) {\n        este.nombre = n\n    }\n    funcion sal() {\n        escribir(este.nombre)\n    }\n}\nvariable p = nuevo P("Ana")\np.sal()'>Clase</button>
    <button class="example-btn" data-code='variable i = 0\nmientras (i < 5) {\n    escribir("i = " + i)\n    i = i + 1\n}'>Bucle</button>
    <button class="example-btn" data-code='funcion fib(n) {\n    si (n <= 1) {\n        retornar n\n    }\n    retornar fib(n-1) + fib(n-2)\n}\nescribir("fib(10) = " + fib(10))'>Fibonacci</button>
  </div>
</Layout>

<style is:global>
  .playground-layout {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 16px;
    margin-bottom: 24px;
    min-height: 450px;
  }
  .editor-panel, .output-panel {
    display: flex;
    flex-direction: column;
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
    background: var(--bg-card);
  }
  .panel-header {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 8px 14px;
    background: linear-gradient(135deg, #0a0d14, #0e111a);
    border-bottom: 1px solid var(--border);
    font-size: 0.8rem;
    color: var(--text-dim);
    font-family: var(--font-mono);
    gap: 8px;
    flex-wrap: wrap;
  }
  .panel-actions { display: flex; align-items: center; gap: 8px; margin-left: auto; }
  .live-toggle {
    display: flex; align-items: center; gap: 6px; cursor: pointer; user-select: none;
  }
  .live-label {
    font-size: 0.72rem; font-weight: 600; text-transform: uppercase;
    letter-spacing: 0.5px; color: var(--text-muted); transition: color 0.2s;
  }
  .live-toggle input { display: none; }
  .toggle-track {
    width: 36px; height: 20px; background: var(--bg-elevated);
    border: 1px solid var(--border); border-radius: 10px;
    position: relative; transition: all 0.25s ease;
  }
  .toggle-thumb {
    position: absolute; top: 2px; left: 2px; width: 14px; height: 14px;
    background: var(--text-muted); border-radius: 50%; transition: all 0.25s ease;
  }
  .live-toggle input:checked + .toggle-track {
    background: rgba(16, 185, 129, 0.2); border-color: var(--verde);
  }
  .live-toggle input:checked + .toggle-track .toggle-thumb {
    left: 18px; background: var(--verde); box-shadow: 0 0 8px rgba(16, 185, 129, 0.4);
  }
  .live-toggle:has(input:checked) .live-label { color: var(--verde); }
  .btn-run {
    background: var(--verde); color: #000; border: none;
    padding: 4px 14px; border-radius: 6px; cursor: pointer;
    font-size: 0.78rem; font-weight: 600; font-family: var(--font);
    transition: all 0.15s;
  }
  .btn-run:hover { filter: brightness(1.2); transform: translateY(-1px); }
  .btn-clear {
    background: var(--bg-elevated); color: var(--text-dim);
    border: 1px solid var(--border); padding: 4px 10px; border-radius: 6px;
    cursor: pointer; font-size: 0.78rem; font-family: var(--font);
    transition: all 0.15s;
  }
  .btn-clear:hover { border-color: var(--fuego); color: var(--fuego-light); }
  .editor {
    flex: 1; min-height: 350px; padding: 16px;
    font-family: var(--font-mono); font-size: 0.85rem; line-height: 1.6;
    color: #e2e8f0; background: #0b0e16; border: none; outline: none;
    resize: vertical; tab-size: 4;
  }
  .editor::placeholder { color: var(--text-muted); }
  .output {
    flex: 1; min-height: 350px; padding: 16px;
    font-family: var(--font-mono); font-size: 0.85rem; line-height: 1.6;
    color: var(--text-dim); white-space: pre-wrap; overflow-y: auto;
    background: #0b0e16;
  }
  .output .placeholder { color: var(--text-muted); font-style: italic; }
  .output .stdout { color: var(--verde); }
  .output .stderr { color: var(--rojo); }
  .status-idle { color: var(--verde); font-size: 0.75rem; }
  .status-running { color: var(--fuego-light); font-size: 0.75rem; }
  .status-error { color: var(--rojo); font-size: 0.75rem; }
  .status-timing { color: var(--acero-light); font-size: 0.7rem; }
  .example-buttons { display: flex; flex-wrap: wrap; gap: 8px; margin-bottom: 24px; }
  .example-btn {
    padding: 6px 14px; background: var(--bg-card);
    border: 1px solid var(--border); border-radius: 6px;
    color: var(--text-dim); font-size: 0.82rem; font-family: var(--font);
    cursor: pointer; transition: all 0.15s;
  }
  .example-btn:hover {
    border-color: var(--fuego); color: var(--fuego-light); background: var(--fuego-bg);
  }
  @media (max-width: 768px) { .playground-layout { grid-template-columns: 1fr; } }
</style>

<script>
  function initPlayground() {
    const codigo = document.getElementById('codigo');
    const output = document.getElementById('output');
    const status = document.getElementById('status');
    const btnRun = document.getElementById('btnRun');
    const btnClear = document.getElementById('btnClear');
    const liveSwitch = document.getElementById('liveSwitch');
    let liveTimeout = null;

    function setStatus(text, className) {
      status.textContent = text;
      status.className = className;
    }

    function ejecutar() {
      const source = codigo.value.trim();
      if (!source) {
        output.innerHTML = '<span class="stderr">⚠ No hay código para ejecutar</span>';
        return;
      }
      setStatus('⏳ ejecutando...', 'status-running');
      output.innerHTML = '<span class="placeholder">Ejecutando...</span>';
      const inicio = performance.now();

      setTimeout(() => {
        try {
          const tiempoMs = (performance.now() - inicio).toFixed(2);
          output.innerHTML = '';
          const lineas = source.split('\n');
          let ejecuto = false;

          for (const linea of lineas) {
            const t = linea.trim();
            if (t.startsWith('//')) continue;
            if (t.startsWith('escribir(')) {
              const m = t.match(/escribir\((.*)\)\s*$/);
              if (m) {
                let arg = m[1].trim();
                if (arg.startsWith('"') && arg.endsWith('"')) {
                  const div = document.createElement('div');
                  div.className = 'stdout';
                  div.textContent = arg.slice(1, -1);
                  output.appendChild(div);
                } else {
                  const div = document.createElement('div');
                  div.className = 'stdout';
                  div.textContent = '[' + arg + ']';
                  output.appendChild(div);
                }
                ejecuto = true;
              }
            }
          }

          if (!ejecuto) {
            output.innerHTML = '<span class="stderr">⚠ No se encontraron funciones escribir()</span>';
          }

          if (liveSwitch.checked) {
            setStatus('⚡ en vivo', 'status-idle');
          } else {
            setStatus('⚡ ' + tiempoMs + ' ms', 'status-timing');
          }
        } catch (err) {
          output.innerHTML = '<span class="stderr">⛔ ' + err.message + '</span>';
          setStatus('❌ error', 'status-error');
        }
      }, 50);
    }

    function limpiar() {
      codigo.value = '';
      output.innerHTML = '<span class="placeholder">Editor limpiado</span>';
      setStatus('✓ listo', 'status-idle');
    }

    function cargarEjemplo(code) {
      codigo.value = code.replace(/\\n/g, '\n');
      output.innerHTML = '<span class="placeholder">Código cargado</span>';
      if (liveSwitch.checked) ejecutar();
      else setStatus('✓ listo', 'status-idle');
    }

    function onCodigoChange() {
      if (!liveSwitch.checked) return;
      if (liveTimeout) clearTimeout(liveTimeout);
      liveTimeout = setTimeout(() => {
        if (codigo.value.trim()) ejecutar();
      }, 400);
    }

    btnRun.addEventListener('click', ejecutar);
    btnClear.addEventListener('click', limpiar);
    codigo.addEventListener('input', onCodigoChange);

    liveSwitch.addEventListener('change', () => {
      if (liveSwitch.checked) {
        setStatus('⚡ en vivo', 'status-idle');
        if (codigo.value.trim()) ejecutar();
      } else {
        setStatus('✓ manual', 'status-idle');
      }
    });

    codigo.addEventListener('keydown', (e) => {
      if (e.key === 'Enter' && (e.ctrlKey || e.metaKey)) { e.preventDefault(); ejecutar(); }
    });

    document.querySelectorAll('.example-btn').forEach(btn => {
      btn.addEventListener('click', () => cargarEjemplo(btn.dataset.code));
    });

    if (codigo.value.trim() && liveSwitch.checked) ejecutar();
  }

  document.addEventListener('DOMContentLoaded', initPlayground);
</script>
