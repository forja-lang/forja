constante N = 100

variable suma = 0.0
variable divisor_pos = 1.0
variable divisor_neg = 3.0
variable i = 0

mientras (i < 50) {
    suma = suma + 1.0 / divisor_pos
    suma = suma - 1.0 / divisor_neg
    divisor_pos = divisor_pos + 4.0
    divisor_neg = divisor_neg + 4.0
    i = i + 1
}

variable pi = suma * 4.0
escribir(pi)
