// Benchmark Forja Heavy — con acumulador para evitar optimización
funcion fib_iterativo(n) {
    si (n <= 1) {
        retornar n
    }
    variable a = 0
    variable b = 1
    variable i = 2
    mientras (i <= n) {
        variable temp = a + b
        a = b
        b = temp
        i = i + 1
    }
    retornar b
}

funcion suma_bucle(n) {
    variable total = 0
    variable i = 0
    mientras (i < n) {
        total = total + i
        i = i + 1
    }
    retornar total
}

funcion bucle_anidado(n) {
    variable total = 0
    variable i = 0
    mientras (i < n) {
        variable j = 0
        mientras (j < 100) {
            total = total + (i * j)
            j = j + 1
        }
        i = i + 1
    }
    retornar total
}

variable ITERS = 100
variable acumulador = 0

// Test 1: Fibonacci(40) x 100
variable i = 0
mientras (i < ITERS) {
    variable r = fib_iterativo(40)
    acumulador = acumulador + r
    i = i + 1
}

// Test 2: Suma 10M x 100
variable i2 = 0
mientras (i2 < ITERS) {
    variable r2 = suma_bucle(10000000)
    acumulador = acumulador + r2
    i2 = i2 + 1
}

// Test 3: Nested loop 1000 x 100
variable i3 = 0
mientras (i3 < ITERS) {
    variable r3 = bucle_anidado(1000)
    acumulador = acumulador + r3
    i3 = i3 + 1
}

escribir(acumulador)
